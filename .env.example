# ─── Sextent Automation — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed to source control.
#
# Usage:
#   cp .env.example .env
#   Edit .env with your credentials
#
# In CI (Jenkins / GitHub Actions / Azure DevOps):
#   Set TEST_USERNAME and TEST_PASSWORD as pipeline secrets — no .env needed.
# ────────────────────────────────────────────────────────────────────────────

# Sextent application login credentials
TEST_USERNAME=your_username_here
TEST_PASSWORD=your_password_here
