/* CSS ECW GRID */

.ecwGrid {
  background-color:#EFEFEF;
  border-style : outset; 
  border-width : thin;
  border-color : #7C7C7C; /*gris !*/
  border-width:1px 1px 1px 2px;
}

.ecwGridActive {
	border-left: 2px solid #FECE00;
}

.ecwGridHead {
	text-align: left;
}

.ecwGridBody {
  overflow: auto;
}

.ecwGrid TABLE {
}

.ecwGrid THEAD {
  border-color : #7C7C7C; /*gris !*/
  background-color : #D5D6E4;
}


.ecwGrid TH {
	color: black !important;
	background-color: #D5D6E4 !important;
	font-family: "Arial", "Liberation Sans";
	font-size: 12px;
	font-weight: bold;
	text-align: center;
	cursor: default;
  border-collapse : collapse; 
  border:1px solid #8C83C5;
	white-space: nowrap;
	box-sizing: border-box;
} 


.ecwGridLineEmpty {
	cursor: default !important;
}

.ecwGridAlternateLine1 {
	background-color: white;
}

.ecwGridAlternateLine2 {
	background-color: #F2F2F2;
}

.ecwGridLineOver {
	background-color: #FFDE5C;
	box-sizing: border-box;
}


.ecwGridLineActive {
	cursor: pointer;
	background-color: #FECE00;
	box-sizing: border-box;
}


.ecwGrid TD {
  font-size:12px;
  text-align:left;
}

.ecwGridCellActive {
	cursor: pointer;
	background-color: rgb(255,102,0) !important;
	box-sizing: border-box;
}

.ecwGridLineActive TD {
	border-right-color: #FECE00;	
	box-sizing: border-box;
}

.ecwGridLineSelect {
	cursor: pointer;
	background-color: #D3D3D3 !important;
	box-sizing: border-box;
}

.ecwGridCellSelect {
	cursor: pointer;
	background-color: #B3B3B3 !important;
	box-sizing: border-box;
}

.ecwGridLineSelect TD {
	empty-cells: show;	
	box-sizing: border-box;
}

