/* les marges IE et mozilla ne sont pas les memes pour les FORM */
FORM {
	margin:0;  
}

.ecwUnderLayPopup, .ecwUnderLayPopupWait {
	cursor:not-allowed;
	position: absolute;
	width: 110%;
	height: 110%;
	cursor: wait;
	bottom: 0;
	right: 0;
	z-index: 98;
	background: white;
	filter: alpha(opacity=50);
	opacity: .5;	
}

.ecwUnderLayPopupFullScreen {
	cursor:default;
	position: absolute;
	width: 110%;
	height: 110%;
	bottom: 0;
	right: 0;
	z-index: 98;
	background: white;
}

.ecwUnderLayPopupWait {	
	background-image: url(sablier.gif);
	background-position:center center;
	background-repeat:no-repeat;
}

