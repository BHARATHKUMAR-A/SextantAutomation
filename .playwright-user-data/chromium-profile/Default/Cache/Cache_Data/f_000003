/**
 * Constructeur de ECW.UI
 * @private
 */
ECW.UI.prototype.constructeur = function(divContainer) {

  if (document.getElementById("ecwAutoId")) {
    this.autoId = document.getElementById("ecwAutoId").value;
  }
  
  if (document.getElementById("uiTokenParam")) {
    this.uiTokenParam = document.getElementById("uiTokenParam").value;
  }
  
  /* Si un container est indique au constructeur de ECW.UI */
  if (divContainer != null) {
    this.createEcwLayout(divContainer);

  } else {

    /* Recherche des Layout dans document.body */
    var allDiv = document.body.getElementsByTagName("DIV");
    for (var i = 0; i < allDiv.length; i++) {
      var currentDiv = allDiv[i];
      var divClass = currentDiv.className;
      if (divClass == "ecwLayout") {
      	this.createEcwLayout(currentDiv);
      }
    }

    /* Si aucun ecwLayout, on prend le document.body */
    if (this.listeEcwLayout.length == 0) {
      this.createEcwLayout(document.body);
    }
  }

  /* Objet ECW.UI */
  ecwActiveUI = this;

  /* Suppression du sablier d'attente au chargement */
  if (document.getElementById("sablier")) {
    document.getElementById("sablier").style.display = "none";
  }
  
  /* Evenement onkeydown sur la page */
  document.onkeydown = OnKey;
  // reactivation de la fonction onEnter sur relachement de la touche
  document.onkeyup   = function() {ecwActiveUI.activeUIEnterKey();};

  /* Pour Mozilla 1.7.5, probleme de rafraichissement */
  /* si on utilise des fieldset */
  if (ECW_isGecko) {
    document.body.style.display = "none";
    document.body.style.display = "";
  }
  
  /* Recherche la hauteur de l ihm */
  for (i = 0 ; i < this.listeEcwLayout.length ; i++) {
    var noeud = this.listeEcwLayout[i].noeudDOM;
    if (ECW_isIE) {
      if (noeud.scrollHeight > this.ihmHeight)
        this.ihmHeight = noeud.scrollHeight;
    } else {
      if (noeud.offsetHeight > this.ihmHeight)
        this.ihmHeight = noeud.offsetHeight;
    }
  }
}

/**
 * Affiche la div sablier de chargement.
 */
