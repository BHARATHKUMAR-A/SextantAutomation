  if(!getInstancePopupManager().existPopup(ecwIdPopupBlockIHM)){
    var html = "";
    html += "<script src='"+ecwBaseRef+"/ecw.js'></script>";
    html += "<script>";
    html += "with(ecwActivePopup) {";
    html += "UI.onEnter = function(){return false;};"; 
    html += "UI.onEscape = function(){return false;};";    
    html += "}";
    html += "</script>";
    html += "<input type='text'>";
    ecwOpenPopupHTML(html, ecwIdPopupBlockIHM, false);   
    getInstancePopupManager().forceHiddenPopup();   
    //getInstancePopupManager().setFullHeightUnderLay(true); //affichage avec sablier sur l'ecran
    getInstancePopupManager().setFullHeightUnderLay();  
  }
}

