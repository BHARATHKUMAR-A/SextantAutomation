}

/**
 * Supprime les enfants du noeud specifie qui sont invisibles
 * @private
 */
ECW.UI.prototype.filtreHtmlInvisible = function(noeudDOM, noeudDOMCopy) {
  for (var i = noeudDOM.childNodes.length - 1; i >= 0; i--) {
    /* Suppression si l'enfant n'est pas visible OU champ de classe 'ecwInvisible' */
    /* OU balise DIV de classe 'ecwTableHead' */
    if ((noeudDOM.childNodes[i].style && noeudDOM.childNodes[i].style.display == "none") ||
      (noeudDOM.childNodes[i].className && isClass(noeudDOM.childNodes[i], "ecwInvisible")) ||
      (noeudDOM.childNodes[i].nodeName == "DIV" && isClass(noeudDOM.childNodes[i],
      "ecwTableHead"))) {
      noeudDOMCopy.removeChild(noeudDOMCopy.childNodes[i]);
    } else {
      /* Suppression des lignes invisibles dans une liste */
      if (noeudDOM.childNodes[i].nodeName == "TR" && noeudDOM.nodeName == "TBODY" && isClass
        (noeudDOM.parentNode.parentNode, "ecwTableBody")) {
        var entete = noeudDOM.parentNode.parentNode.getElementsByTagName("THEAD");
        var enteteHauteur = 0;
        if (entete != null) {
          enteteHauteur = entete[0].offsetHeight;
        }
        var scrollTopDIV = noeudDOM.parentNode.parentNode.scrollTop;
        var offsetHeightDIV = noeudDOM.parentNode.parentNode.offsetHeight;
        if (noeudDOM.childNodes[i].offsetTop < scrollTopDIV + enteteHauteur ||
          noeudDOM.childNodes[i].offsetTop >= scrollTopDIV + offsetHeightDIV) {
          noeudDOMCopy.removeChild(noeudDOMCopy.childNodes[i]);
        }
      } else {
        /* Suppression des balises invisibles de l'enfant */
        this.filtreHtmlInvisible(noeudDOM.childNodes[i], noeudDOMCopy.childNodes[i]);
      }
    }
  }
}

/**
 * Controle si l'element est considere comme un ECW.Control. 
 * @param id Identifiant de l'element du DOM.
 * @param methodName Nom de la methode.
 * @private
 */
ECW.UI.prototype.getAndCheckEcwControl = function(id, methodName) {
  var elt = document.getElementById(id);
  /* Absence */
  if (!elt) {
    alert("Erreur ECW\nMethode [" + methodName + "]\n"
      + "L'identifiant id=[" + id + "] n'existe pas !!!");
  }
  /* Mauvais type */
  else if (!elt.ecwControl) {
    alert("Erreur ECW\nMethode [" + methodName + "]\n"
      + "L'identifiant id=[" + id + "] ne reference pas un objet ECW.Control !!!");
    elt = null;
  }
  return elt;
}

/**
 * Renseigne que la saisie du champ est obligatoire
 * @param id (int) du champ
 * @param message Message d'erreur
 */
ECW.UI.prototype.addRequired = function(id, message) {
  /* Recherche le champ */
  var elt = this.getAndCheckEcwControl(id, "addRequired");
  /* Si on a trouve le champ */
  if (elt) {
    /* On renseigne le fait que la saisie est obligatoire */
    elt.ecwControl.setRequired(message);
  }
}

/**
 * Suppression de l'aspect obligatoire pour un champ
 * @param id (int) du champ
 */
ECW.UI.prototype.removeRequired = function(id) {
  /* Recherche le champ */
  var elt = this.getAndCheckEcwControl(id, "removeRequired");
  /* Si on a trouve le champ */
  if (elt) {
    /* On renseigne le fait que la saisie n'est pas obligatoire */
    elt.ecwControl.removeRequired();
  }
}

/**
 * Ajoute un <i>validator</i> &agrave; un champ. Le <i>validator</i> est un pattern
 * (expression r&eacute;guli&eagrave;re) ou une fonction.
 * <br>
 * Il est possible d'ajouter plusieurs <i>validators</i>.
 * @param id (int) du champ
 * @param validator un pattern (string) ou une fonction
 * @param message Message d'erreur
 */
ECW.UI.prototype.addValidator = function(id, validator, message) {
  /* Recherche le champ */
  var elt = this.getAndCheckEcwControl(id, "addValidator");
  /* Si on a trouve le champ */
  if (elt && elt.ecwControl) {
    if ("string" == typeof validator) {
      if ("date" == validator) {
        elt.ecwControl.addValidator(ecwDateValidator, message);
      } else {
        /* On regarde si on trouve une traduction pour le pattern */
        transPattern = ecw.I18N.get(validator);
        /* si ce n'est pas le cas */
        /* i18n retourne la chaine entoure de "" */
        if (transPattern == '"' + validator + '"') {
          /* On prend le pattern tel quel */
          transPattern = validator;
        }
        /* On renseigne le pattern */
        elt.ecwControl.addValidator("^" + transPattern + "$", message);
      }
    } else if ("function" == typeof validator) {
      elt.ecwControl.addValidator(validator, message);
    }
  }
}

/**
 * Suppression d'un <i>validator</i> sur un champ. Si le <i>validator</i> n'est
 * pas pr&eacute;cis&eacute;, tous les <i>validators</i> sont supprim&eacute;s.
 * @param id (int) du champ
 * @param validator un pattern (string) ou une fonction &agrave; supprimer.
 */
ECW.UI.prototype.removeValidator = function(id, validator) {
  /* Recherche le champ */
  var elt = this.getAndCheckEcwControl(id, "removeValidator");
  /* Si on a trouve le champ */
  if (elt && elt.ecwControl) {
    if ("string" == typeof validator) {
      /* On regarde si on trouve une traduction pour le pattern */
      transPattern = ecw.I18N.get(validator);
      /* si ce n'est pas le cas */
      /* i18n retourne la chaine entoure de "" */
      if (transPattern == '"' + validator + '"') {
        /* On prend le pattern tel quel */
        transPattern = validator;
      }
      /* On renseigne le pattern */
      elt.ecwControl.removeValidator("^" + transPattern + "$");
    } else if ("function" == typeof validator) {
      elt.ecwControl.removeValidator(validator);
    } else {
      elt.ecwControl.clearValidators();
    }
  }
}

/**
 * Test de validation des champs
 * @type boolean
 */
ECW.UI.prototype.validate = function() {

  var result = true;
  /* Parcours des layouts */
  for (var i = 0; i < this.listeEcwLayout.length; i++) {
    var result = this.listeEcwLayout[i].validate();
    if (!result) {
      break;
    }
  }
  return result;
}

/**
 * Test de validation d'un champ
 * @param idControl Identifiant du champ
 * @type boolean
 */
ECW.UI.prototype.validateControl = function(idControl) {

  var input = document.getElementById(idControl);
  var result = this.isValidate(input);
  if (result) {
    this.clearMessage();
  } else {
    /* focus sur le champ et affichage du message */
    this.setFocusAndMessageError(input);
  }
  /* Cas d'une zone de saisie distante */
  if(input.ecwControl && input.ecwControl.remoteInputArea){
    var ecwLayout = input.ecwControl.ecwLayout;
    ecwLayout.controlRemoteInputArea(input.ecwControl.remoteInputArea);
  }
  return result;
}

/**
 * Test de validation d'un champ.
 * @param noeud Noeud DOM du champ.
 * @type boolean
 * @private
 */
ECW.UI.prototype.isValidate = function(noeud) {

  /* C'est un control */
  if (noeud.ecwControl) {
    /* si le control n'est pas valide */
    if (!noeud.ecwControl.validate()) {
      return false;
    }
  }
  return true;
}

/**
 * Positionnement du focus sur le champ en erreur
 * et affichage du message
 * @param noeud : input du champ
 * @private
 */
ECW.UI.prototype.setFocusAndMessageError = function(noeud) {
  /* Si contenu dans un onglet, focus sur onglet */
  if (noeud.ecwControl.ecwTabItem) {
    noeud.ecwControl.ecwTabItem.ecwTabFolder.activateItem(noeud.ecwControl.ecwTabItem.noeudDOM.id);
  }
    
  /* Focus sur champ */
  noeud.ecwControl.setFocusAndSelect();
  
  /* Affichage du message */
  if (noeud.ecwControl.messageError) {
    this.setMessage("W", noeud.ecwControl.messageError);
  }
}

/**
 * Active la gestion des raccourcis clavier
 */
ECW.UI.prototype.activeAccessKey = function(idNodeToUse) {

  var nodeToUse = document.body;
  if (idNodeToUse != null) {
    nodeToUse = document.getElementById(idNodeToUse);
  }
  if (!this.ecwAccessKey) {
    ecwSetAttribute(this, "ecwAccessKey", new ECW.AccessKey(nodeToUse));
  } else {
    this.ecwAccessKey.activate();
  }
  
  /**
   * Dans le cas ou il y a des onglets dans la page, il faut recalculer la taille des onglets
   * car il est possible que l'ajout d'accessKey augmente la taille d'affichage
   */
   this.refreshTabInLayout();
}

/**
 * D&eacute;sactive la gestion des raccourcis clavier
 */
ECW.UI.prototype.desactiveAccessKey = function() {
  if (this.ecwAccessKey) {
    this.ecwAccessKey.desactivate();
  }
}

