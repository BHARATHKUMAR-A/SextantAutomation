}

/**
 * Sollicitation Ajax et interpretation par le moteur XML.
 * @param url Url a solliciter.
 * @param param Parametre.
 * @param idPosition Identifiant dans le DOM pour eventuellement positionner la reponse.
 * @param debug Mode debug.
 * @param asynchronous mode .
 */
ECW.UI.prototype.sendForm = function(url, param, idPosition, debug,asynchronous) {

  if (asynchronous == null) {
    asynchronous=true;
  }
  /* Affichage de l'url */
  if (debug || this.modeDebug) {
    this.modeDebug = debug;
    alert('Requete ajax \nurl : '+url+'\nparam : '+param);
  }

  this.underLay.show(); 
	
  if (idPosition != null && idPosition!='') {
    ecwIdPosition = idPosition;
  }else{
    ecwIdPosition = null;
  }

  window.ajaxRequest = $.ajax({
    type: "POST",
    url: url,
    data: param,
    dataType: "xml",
    async: asynchronous,
    success: function(resultAJAX) {
      ecwActiveUI.underLay.hide();
      if (typeof(resultAJAX) == "string"){
        alert("String result :\n"+resultAJAX);
      }
      /* Message XML */
      else {
        if (this.modeDebug) {
          var serializer = new XMLSerializer();
          var str = serializer.serializeToString(resultAJAX);
          alert('Resultat requete ajax \n'+str);
        }
        ecwActiveUI.processAction(resultAJAX);
      }
    },
    error: function(request, error) {
      ecwActiveUI.underLay.hide();
      if (request.status != "0") {
        alert("ERROR :\n" + error + " / status=" + request.status + "\n" + request.responseText);
      }
    }
  });
}

/**
 * Interpretation du message XML par le moteur.
 * @param xmlAction Message XML des actions a realiser.
 * @private
 */
ECW.UI.prototype.processAction = function(xmlAction) {

  for (var i = 0; i < xmlAction.childNodes.length; i++) {

    var currentRoot = xmlAction.childNodes[i];
    if ((currentRoot.nodeType == 1) && (currentRoot.nodeName == "action")) {

      for (var j = 0; j < currentRoot.childNodes.length; j++) {

        var currentAction = currentRoot.childNodes[j];
        if ((currentAction.nodeType == 1)) {
          new ECW.Action(currentAction, this);
        }
      }
    }
  }
}

