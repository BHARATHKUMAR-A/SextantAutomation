/**
 * Affiche une aide contextuelle (appelee par Champ.activer())
 * @private
 */
ECW.UI.prototype.setHelpContext = function(text) {

  /* Calcul pour que le message ne soit pas sur les bouttons en pied de page */
  var height = ecwHelpContextHeight;
  var messageBar = document.getElementById("EcwMessageBar");
  if (messageBar && messageBar.style.display == "") {
    height += ecwMessageBarHeight;
  }
  if(this.ihmHeight + height > document.body.scrollHeight){
    // avoid superficial scrollbars on frames in IE11
    if (!ECW_isIE11) {
        document.body.style.height = document.body.scrollHeight+height;
    }
    if (ECW_isIE) {
      var div = document.createElement("div");
      document.body.appendChild(div);
      div.style.height = height;
    }
  }

  /* Test si l'aide contextuelle a ete desactivee */
  if(this.helpContextDisabled){
	  return;
  }
  
  /* Creation si necessaire de la DIV d'aide */
  var helpContext = document.getElementById("EcwHelpContext");
  if (!helpContext) {
    helpContext = document.createElement("DIV");
    helpContext.id = "EcwHelpContext";
    document.body.appendChild(helpContext);
  }
  /* Positionner l'aide au dessus de la barre de message si elle existe */
  if (messageBar && messageBar.style.display == "") {
    helpContext.style.bottom = messageBar.offsetHeight;
  } else {
    helpContext.style.bottom = "0";
  }

  /* IFRAME ajoutee sous IE pour corriger le bug d'affichage */
  var iframe = null;
  if (ECW_isIE) {
    iframe = document.getElementById("EcwHelpIFrame");
    if (!iframe) {
      iframe = document.createElement("IFRAME");
      iframe.id = "EcwHelpIFrame";
      document.body.appendChild(iframe);
    }
  }
  
  /* Affiche ou masque la zone d'aide selon que le texte est rempli */
  if (text == "") {
    helpContext.style.display = "none";
    if (iframe) {
      iframe.style.display = "none";
    }
    if (document.getElementById("helpContext")) {
      document.getElementById("helpContext").innerHTML = "vide";
      document.getElementById("helpContext").className = "styleHiddenHelpContext";
    }
  } else {
    helpContext.style.display = "";
    helpContext.innerHTML = text;
    if (iframe) {
      iframe.style.display = "";
    }
    if (document.getElementById("helpContext")) {
      document.getElementById("helpContext").innerHTML = text;
      document.getElementById("helpContext").className = "styleHelpContext";
    }
  }
}


