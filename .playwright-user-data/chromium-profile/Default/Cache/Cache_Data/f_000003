 * Efface le message si il existe
 */
ECW.UI.prototype.clearMessage = function() {
  var messageBar = document.getElementById("EcwMessageBar");
  if (messageBar) {
    messageBar.style.display = "none";
  }
  var iframe = document.getElementById("EcwMessageIFrame");
  if (iframe) {
    iframe.style.display = "none";
  }
  this.message = null;
  this.msgGravite = null;
}

/**
