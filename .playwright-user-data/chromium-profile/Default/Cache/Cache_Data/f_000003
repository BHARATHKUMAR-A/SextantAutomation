/**
 * Creation des objets ECW.Layout
 * @private
 */
ECW.UI.prototype.createEcwLayout = function(noeudDOM) {
  
  var ecwLayout = new ECW.Layout(noeudDOM, this, this.listeEcwLayout.length);
  var precedent = null;
  if(this.listeEcwLayout.length>0){
    precedent = this.listeEcwLayout[this.listeEcwLayout.length - 1];
    ecwSetAttribute(precedent, "suivant", ecwLayout);
  }
  ecwSetAttribute(ecwLayout, "precedent", precedent);
  this.listeEcwLayout[this.listeEcwLayout.length] = ecwLayout;
}

