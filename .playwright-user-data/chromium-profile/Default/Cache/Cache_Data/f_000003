/**
 * Methode de redimensionnement de la zone body d'une ihm ECW
 * @private
 */
ECW.UI.prototype.processEcwBodyIhmAutoHeight = function() {	
	var bodyLayoutEcw = $('tr td.ecwBodyIhm')[0];   	
    if (bodyLayoutEcw) {
    	var titleLayoutEcw = $('tr td.ecwTitleZoneIhm')[0];
