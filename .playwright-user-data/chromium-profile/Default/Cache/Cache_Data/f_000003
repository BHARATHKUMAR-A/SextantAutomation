/**
 * D&eacute;fini l'objet <b>ECW.UI</b>
 */
ECW.UI = function() {

  ecwStartTimer("ECW.UI");

  /* Recuperation de la zone vue par ECW, selon l'argument passe au constructeur */
  var divContainer = null;
  if (arguments.length > 0) {
    divContainer = document.getElementById(arguments[0]);
  }
  this.init(divContainer);
  
  //Premier redimensionnement
  if (ecwAutoHeightIhm) this.processEcwBodyIhmAutoHeight();  
 
  /* Mode debug */
  this.modeDebug = false;
  
  ecwStopTimer("ECW.UI");
}

/**
 * Prise en compte de nouveaux composants dans ECW.UI.
 */
ECW.UI.prototype.update = function() {
  if(this.listeEcwLayout && this.listeEcwLayout.length != 0){
    this.listeEcwLayout[0].update();
  }
}

/**
 * Initialisation.
 * @private
 */
ECW.UI.prototype.init = function(divContainer) {

  ecwSetAttribute(this, "listeEcwLayout", new Array);
  ecwSetAttribute(this, "ecwAccessKey", null);
  
  ecwSetAttribute(this, "activeFlag", true);
  
  ecwSetAttribute(this, "uiEnterKeyActive", true);
  
  ecwSetAttribute(this, "autovalidateOnTableRefresh", false);
  
  ecwSetAttribute(this, "onEnter", null);
  ecwSetAttribute(this, "onEscape", null);

  ecwSetAttribute(this, "underLay", new ECW.UnderLay());

  /* Compte les champs qui demande un warning de validation */
  this.patternMsg = 0;

  /* Constructeur */
  this.constructeur(divContainer);

  /* Surcharge le(s) submit(s) */
  //ecwOverrideSubmits();

  /* Positionne le focus */
  if (this.listeEcwLayout.length != 0) {
    this.listeEcwLayout[0].computeFocus();
  }
}

