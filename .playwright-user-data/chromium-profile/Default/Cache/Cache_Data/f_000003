}

/**
 * Methode attribuant un poid a une gravite
 * @private
 */
ECW.UI.prototype.getLevel = function(gravite) {
	var level=0;
	if (gravite) {
		if (gravite=='I') level=1;
		else if (gravite=='W') level=2;
		else if (gravite=='E') level=3;
	}
	return level;
}

/**
 * Ajout d'un message avec un code gravit&eacute; (I,E,W)
 * Si la gravite du message a ajoute est superieur au message courant
 * alors le bandeau prend la gravite la plus critique
 */
ECW.UI.prototype.addMessage = function(gravite, text) {	
	if (this.message) {
		var grvMsg='O';
		if (this.getLevel(gravite)>this.getLevel(this.msgGravite))
			grvMsg = gravite;
		else
			grvMsg = this.msgGravite;
		this.setMessage(grvMsg,this.message+"<BR>"+text);		
	} else {
		this.setMessage(gravite,text);
	}	
}

/**
 * Cr&eacute;e un document HTML qui peut &ecirc;tre imprimable
 */
ECW.UI.prototype.softCopy = function() {
  var htmlActuel = document.getElementsByTagName("HTML");
  var htmlCopy = document.createElement("HTML");
  // Recuperation des balises LINK pour les styles
  /*  var cloneHead=htmlActuel[0].getElementsByTagName("HEAD")[0].cloneNode(true);
