/**
 * Affiche un message avec un code gravit&eacute; (I,E,W)
 */
ECW.UI.prototype.setMessage = function(gravite, text) {
  
  /* Calcul pour que le message ne soit pas sur les bouttons en pied de page */
  var height = ecwMessageBarHeight;
  var helpContext = document.getElementById("EcwHelpContext");
  if (helpContext && helpContext.style.display == "") {
    height += ecwHelpContextHeight;
  }
  if(this.ihmHeight + height > document.body.scrollHeight){
    document.body.style.height = document.body.offsetHeight+height;
    if (ECW_isIE) {
      var div = document.createElement("div");
      document.body.appendChild(div);
      div.style.height = height;
    }
  }
  
  /* Creation si necessaire de la DIV de message */
  var messageBar = document.getElementById("EcwMessageBar");
  if (!messageBar) {
    messageBar = document.createElement("DIV");
    messageBar.id = "EcwMessageBar";
    messageBar.style.zIndex = 2147483647;//Affichage au niveau maxi (cas de popup)
    document.body.appendChild(messageBar);
  }
  /* Fixe en majuscule la gravite et verifie si le code existe sinon > O */
  gravite = gravite.toUpperCase();
  if ("IWE" .indexOf(gravite) ==  - 1) {
    gravite = "O";
  }
  /* Fixe la classe CSS au text et rend visible la barre de message */
  messageBar.className = "EcwMessageBar" + gravite;
  messageBar.innerHTML = text;
  messageBar.style.display = "";

  /* IFRAME ajoutee sous IE pour corriger le bug d'affichage */
  if (ECW_isIE) {
    var iframe = document.getElementById("EcwMessageIFrame");
    if (!iframe) {
      iframe = document.createElement("IFRAME");
      iframe.id = "EcwMessageIFrame";
      document.body.appendChild(iframe);
    }
    iframe.style.display = "block";
  }

  this.message = text;
  this.msgGravite = gravite;
}

