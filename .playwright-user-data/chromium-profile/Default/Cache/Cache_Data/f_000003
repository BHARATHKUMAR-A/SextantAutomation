	var divSablier = document.getElementById("sablier");
	divSablier.style.display = "block";
	document.body.lastScrollTop = document.body.scrollTop;
	document.body.scrollTop = 0;
}

/**
 * Masque la div sablier de chargement.
 */
ECW.UI.prototype.hideSablier = function() {
	document.getElementById("sablier").style.display = "none";
	var value = 0;
	if(document.body.lastScrollTop){
      value = document.body.lastScrollTop;
	}
	setTimeout('document.body.scrollTop = '+value+';', 0);
}


/**
 * Affiche un calque qui grise la page et qui verrouille les raccourcis claviers.
 */
