/**
 * Positionne le focus sur le layout
 * @private
 */
ECW.Layout.prototype.computeFocus = function() {

  /* S'il existe un premier et dernier champ visible accessible */
  if (this.firstControl && this.lastControl) {

    /* Champ a focuser */
    if (this.ecwUI.ecwControlToFocus) {
      this.ecwUI.ecwControlToFocus.setFocus();
      this.ecwUI.ecwControlToFocus = null;
    }
    else {
      /* Gestion du tabindex */
      if (this.firstControlTabindex) {
        this.firstControlTabindex.setFocus();
        this.firstControl = this.firstControlTabindex;
      } else {
        this.firstControl.setFocus();
      }
      if (this.lastControlTabindex) {
        this.lastControl = this.lastControlTabindex;
      }
    }
  }
}

/**
 * Test de validation des champs
 * @type boolean
 */
ECW.Layout.prototype.validate = function() {
  var listeInputAndSelect = [];
  var listeInput = this.noeudDOM.getElementsByTagName("INPUT");
  for (var i = 0; i < listeInput.length; ++i) {
    listeInputAndSelect.push(listeInput[i]);
  }
  /* On ajoute les champs SELECT a la liste des champs a parcourir */
  var listeSelect = this.noeudDOM.getElementsByTagName("SELECT");
  for (var i = 0; i < listeSelect.length; ++i) {
    listeInputAndSelect.push(listeSelect[i]);
  }
  var inputFirstError = null;
  this.ecwUI.clearMessage();
  /* Parcours de tous les champs de la page et declenchement du validate de chaque champ */
  for (var i = 0; i < listeInputAndSelect.length; i++) {
    var input = listeInputAndSelect[i];
    /* Desactivation de l'helpContent avant de valider le champ */
    if (input.ecwControl) {
      input.ecwControl.disableHelpContent();
    }
    var result = this.ecwUI.isValidate(input);
    /* Re-activation de l'helpContent apres avoir valide le champ */
    if (input.ecwControl) {
      input.ecwControl.enableHelpContent();
    }
    if (!result && inputFirstError == null) {
      inputFirstError = input;  
    }
  }
  
  /* Parcours de toutes les zones de saisie distantes */
  for (var i = 0; i < this.listeDivRemoteInputArea.length; i++) {
    this.controlRemoteInputArea(this.listeDivRemoteInputArea[i]);
  }
  
  if (inputFirstError != null) {
    /* Focus sur le champ et affichage du message */
    this.ecwUI.setFocusAndMessageError(inputFirstError);
    return false;
  }
  return true;
}

/**
 * Recherche s'il existe un input en erreur dans la zone de saisie distante.
 * @param div 
 * @private
 */
ECW.Layout.prototype.controlRemoteInputArea = function(div) {
  var inputs = div.getElementsByTagName("INPUT");
  var existError = false;
  var size = inputs.length;
  var ecwControl, i;
  /* Premier parcours pour determiner s'il existe au moins une erreur */
  for (i = 0 ; i < size && !existError; i++) {
    ecwControl = inputs[i].ecwControl;
    if (ecwControl && ecwControl.validValue==false) {
      existError = true;
    }
  }

  if (existError) {
    if (!isClass(div, "ecwRemoteInputAreaError")) {
      addClass(div, "ecwRemoteInputAreaError");
    }
  } else {
    removeClass(div, "ecwRemoteInputAreaError");
  }

  /* Second parcours pour ajouter/retirer le style */
  for (i = 0 ; i < size ; i++) {
    ecwControl = inputs[i].ecwControl;
    if (ecwControl && ecwControl.ecwLabel) {
      if (existError) {
        if (ecwControl.validValue==false) {
          addClass(ecwControl.ecwLabel, "ecwRemoteInputAreaLabelInvalid");
        } else {
          removeClass(ecwControl.ecwLabel, "ecwRemoteInputAreaLabelInvalid");
        }
        if (ecwControl.required) {
          addClass(ecwControl.ecwLabel, "ecwRemoteInputAreaLabelRequired");
        } else {
          removeClass(ecwControl.ecwLabel, "ecwRemoteInputAreaLabelRequired");
        }
      } else {
        removeClass(ecwControl.ecwLabel, "ecwRemoteInputAreaLabelInvalid");
        if (ecwControl.required) {
          removeClass(ecwControl.ecwLabel, "ecwRemoteInputAreaLabelRequired");
        }
      }
    }
  }
}

/**
 * Recalcul des tables en mode auto-height
 * @type boolean
 */
ECW.Layout.prototype.processEcwTableAutoHeight = function() {
  ecwTableProcessAutoHeight(this.listeDivEcwTable);
  ecwTableV2ProcessAutoHeight(this.listeDivEcwTableV2);
}

/**
 * Active le layout suivant ou precedent suivant l'action du clavier
 * @private
 */
ECW.Layout.prototype.onKey = function(action) {
  /* Activer le layout precedent, s'il en existe un */
  if (action == "ctrl-shift-left") {
    if (this.precedent) {
      this.precedent.computeFocus();
    }
  }
  /* Activer le layout suivant, s'il en existe un */
  if (action == "ctrl-shift-right") {
    if (this.suivant) {
      this.suivant.computeFocus();
    }
  }
}

/**
 * Positionnement du focus sur le layout.
 */
ECW.Layout.prototype.setFocus = function() {
  /* Gestion du tabindex */
  if (this.firstControlTabindex) {
    this.firstControlTabindex.setFocus();
  } else {
    this.firstControl.setFocus();
  }
}

