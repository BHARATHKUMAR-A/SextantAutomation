/**
 * Traitement de la position des champs du filtre
 * @param {Object} numCol Numero de la colonne pour la cellule
 * @param {Object} ligneBody Ligne du tableau concernee
 * @param {Object} cellFilter Cellule du filtre
 * @private
 */
ECW.Layout.prototype.processFilterPosition = function(numCol, ligneBody, cellFilter) {
  
  var newOlFilter = null;
  /* Premier champ */
  if (numCol == 0) {
    newOlFilter = ligneBody.cells[numCol+1].offsetLeft;
  }
  else if (numCol < ligneBody.cells.length - 1) {
    newOlFilter = ligneBody.cells[numCol+1].offsetLeft - ligneBody.cells[numCol].offsetLeft;
  }
  if (newOlFilter) {
    cellFilter.style.width = newOlFilter;  
  }
}

/**
 * Fixer le positionnement du filtre d'un tableau
 * @private
 */
ECW.Layout.prototype.setFilterDimensionOnTable = function() {

  /* Parcours des tables */
  for (var i = 0; i < this.listeDivEcwTable.length; i++) {

    var ecwTableCurrent = this.listeDivEcwTable[i].ecwTable;

    /* S'il existe un filtre rattache */
    if (ecwTableCurrent.ecwIdFilter) {

      var tableFilter = document.getElementById(ecwTableCurrent.ecwIdFilter);

      /* Parcours des filtres */
      var listeLigneBody = ecwTableCurrent.divTBody.firstChild.rows;
      for (var j = 0; j < 1; j++) {

        var ligneBody = listeLigneBody[j];
        for (var k = 0; k < ligneBody.cells.length; k++) {
            
          var cellFilter = tableFilter.rows[j].cells[k];
          /* Positionne les champs du filtre */
          this.processFilterPosition(k, ligneBody, cellFilter);
        }
      }
    }
  }

  /* Correction affichage du THead par rapport au TBody (decalage visuel) */
  document.body.style.display = "none";
  document.body.style.display = "";
}

