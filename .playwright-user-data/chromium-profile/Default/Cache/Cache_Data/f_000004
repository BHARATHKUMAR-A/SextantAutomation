/**
 * Constructeur de ECW.Layout
 * @private
 */
ECW.Layout.prototype.constructeur = function() {

  /* Detection des composants ECW de type DIV */
  this.detectAllEcwDivComponent();

  /* Creation des composants ECW de type DIV */
  this.createAllEcwDivComponent();

  /* Creation des composants ECW.Control */
  this.createAllEcwControl();

  /* Creation des composants ECW de type Grid */
  this.createAllEcwGrid();

  /* Relie les balises <label> */
  this.createLinkAllLabel();

  /* Creation des elements caches necessaires au bouclage */
  this.createInputHiddenForLoop();

  /* Associe a chaque ecwControl sa zone de saisie lorsqu'elle est definie. */
  this.linkRemoteInputAreaEcwControl();

  /* Recherche du premier et du dernier champ (chacun doit etre visible et accessible) */
  this.searchFirstAndLastInput();

  /* Active ou non le bouclage entre premier et dernier champ (qui peuvent recevoir un focus) */
  this.computeLoop();

  /* Initialisation des balises <select> de la table et positionnement des filtres sur une table */
  this.initSelectTableAndSetFilterTable();

  /* Initialisation des balises <select> de la tableV2 et positionnement des filtres sur une tableV2 */
  this.initSelectTableV2AndSetFilterTableV2();

 /* Dimensionnement des onglets */
  this.setSizeAllTabFolder();
  
  /* Traitement du mode auto-select des ComboBox */
  this.processComboBoxAutoSelect();
  
  /* Set la date de mise a jours de la page */
  this.setCurrentDate();
}

/**
 * Prise en compte d'un nouveau contenu HTML
 */
ECW.Layout.prototype.refresh = function(htmlLayout) {
  var newDivLayout = document.createElement("DIV");
  newDivLayout.innerHTML = htmlLayout;
  this.refreshDIV(newDivLayout);
}

/**
 * Prise en compte d'un nouveau contenu HTML pour un noeud
 */
ECW.Layout.prototype.refreshNode = function(nodeToRefresh, html) {

  if (this.ecwUI.ecwAccessKey) {
    this.ecwUI.ecwAccessKey.removeAccessKey(nodeToRefresh);
  }

  for (var i = nodeToRefresh.childNodes.length - 1; i >= 0; i--) {
    nodeToRefresh.removeChild(nodeToRefresh.childNodes[i]);
  }
  nodeToRefresh.innerHTML = html;
  this.update();
  ecwEvalScript(nodeToRefresh);
}

/**
 * Prise en compte d'un nouveau contenu HTML
 * @private
 */
ECW.Layout.prototype.refreshDIV = function(newDivLayout) {

  if (this.ecwUI.ecwAccessKey) {
    this.ecwUI.ecwAccessKey.removeAccessKey(this.noeudDOM);
  }

  /* Suppression de tous les noeuds enfants de <DIV class="ecwLayout"> */
  for (var i = this.noeudDOM.childNodes.length - 1; i >= 0; i--) {
    this.noeudDOM.removeChild(this.noeudDOM.childNodes[i]);
  }

  /* Contenu du Layout */
  this.noeudDOM.appendChild(newDivLayout);

  /* Construction du Layout */
  this.init();

  ecwEvalScript(newDivLayout);
}

/**
 * Prise en compte de nouveaux composants dans ECW.UI.
 */
ECW.Layout.prototype.update = function() {
  this.noeudDOM.removeChild(this.lastInputHidden);
  this.noeudDOM.removeChild(this.firstInputHidden);
  this.init();
}

ECW.Layout.prototype.init = function() {

  /* Init des listes d'objets */
  ecwSetAttribute(this, "listeDivEcwTable", new Array);
  ecwSetAttribute(this, "listeDivEcwTableV2", new Array);
  ecwSetAttribute(this, "listeDivEcwDoubleTableV2", new Array);
  ecwSetAttribute(this, "listeDivEcwComboBox", new Array);
  ecwSetAttribute(this, "listeDivEcwComboBoxAutoSelect", new Array);
  ecwSetAttribute(this, "listeDivEcwTabFolder", new Array);
  ecwSetAttribute(this, "listeDivEcwCalendar", new Array);
  ecwSetAttribute(this, "listeDivEcwTreeViewOld", new Array);  
  ecwSetAttribute(this, "listeDivEcwTreeView", new Array);
  ecwSetAttribute(this, "listeDivEcwMenu", new Array);
  ecwSetAttribute(this, "listeDivEcwTimeField", new Array);
  ecwSetAttribute(this, "listeDivEcwGrid", new Array);
  ecwSetAttribute(this, "listeDivEcwContainer", new Array);
  ecwSetAttribute(this, "listeDivRemoteInputArea", new Array);

  ecwSetAttribute(this, "control", new Array);
  ecwSetAttribute(this, "listeEcwControl", new Array);

  ecwSetAttribute(this, "firstInputHidden", null);
  ecwSetAttribute(this, "lastInputHidden", null);
  ecwSetAttribute(this, "firstControl", null);
  ecwSetAttribute(this, "lastControl", null);
  ecwSetAttribute(this, "firstControlTabindex", null);
  ecwSetAttribute(this, "lastControlTabindex", null);

  /* Construction du Layout */
  this.constructeur();
  
  if (this.ecwUI.ecwAccessKey) {
    this.ecwUI.ecwAccessKey.refresh();
  }
}

/**
 * Set la date sur la span de class ecwCurrentDate
 * @private
 */
ECW.Layout.prototype.setCurrentDate = function() {
  var noeuds = this.noeudDOM.getElementsByTagName("span");
  if(noeuds){
    var currentDate = ecwGetCurrentDate();
    for(var i = 0 ; i < noeuds.length ; ++i){
      if(isClass(noeuds[i], "ecwCurrentDate")){
        noeuds[i].innerHTML = currentDate;
      }
    }
  }
}

/**
 * Detecte les composants ECW de type DIV
 * @private
 */
ECW.Layout.prototype.detectAllEcwDivComponent = function() {

  var nbInterdits = 0;
  var allDiv = this.noeudDOM.getElementsByTagName("DIV");
  var div;
  var nbDiv = allDiv.length;
  for (var i = 0; i < nbDiv; ++i) {
    div = allDiv[i];
    divClass = div.className;
    /* Table */
    if ((divClass == "ecwTable") || (divClass == "ecwTableV2")) {
      /* Pour des pb de mise en page, */
      /* on autorise que les champs input, select et button dans les champs de saisies des tables */
      nbInterdits = 0;
      var allTable = div.getElementsByTagName("DIV");
      for (var k = 0; k < allTable.length; k++) {
        if ((allTable[k].className.indexOf("ecwComboBox") != -1) ||
            (allTable[k].className.indexOf("ecwCalendar") != -1)) {
          nbInterdits = 1;
        }
      }
      if (nbInterdits == 1) {
        alert("ecwCombo et ecwCalendar interdits dans les ecwTable ....");
      }
      var aDiv = div.getElementsByTagName("A");
      if (aDiv && aDiv.length > 0) {
        //alert("Balises <A interdites dans les ecwTable , prendre <Button....");
        //nbInterdits = 2; 
      }
      if (nbInterdits == 0) {
        if (divClass == "ecwTable") {
          this.listeDivEcwTable[this.listeDivEcwTable.length] = div;
        } else if (divClass == "ecwTableV2") {
          this.listeDivEcwTableV2[this.listeDivEcwTableV2.length] = div;
        }
      }
    }
    /* Double Table V2 */
    else if (divClass == "ecwDoubleTableV2") {
      this.listeDivEcwDoubleTableV2[this.listeDivEcwDoubleTableV2.length] = div;
    }
    /* Onglet */
    else if (divClass == "ecwTabFolder") {
      this.listeDivEcwTabFolder[this.listeDivEcwTabFolder.length] = div;
    }
    /* Calendrier */
    else if (divClass == "ecwCalendar") {
      this.listeDivEcwCalendar[this.listeDivEcwCalendar.length] = div;
    }
    /* Groupe de boutons */
    else if (divClass == "ecwButtonGroup") {
      if (!div.ecwButtonGroup) {
        div.ecwButtonGroup = new ECW.ButtonGroup(div, this.ecwUI);
      }
    }
    /* TreeView Old */
    else if (divClass == "ecwTreeViewOld") {
      this.listeDivEcwTreeViewOld[this.listeDivEcwTreeViewOld.length] = div;
    }
    /* TreeView */
    else if (divClass == "ecwTreeView") {
      this.listeDivEcwTreeView[this.listeDivEcwTreeView.length] = div;
    }
    /* Menu */
    else if (divClass == "ecwMenu") {
      this.listeDivEcwMenu[this.listeDivEcwMenu.length] = div;
    }
    /* Champ heure */
    else if (divClass == "ecwTimeField") {
      this.listeDivEcwTimeField[this.listeDivEcwTimeField.length] = div;
    /* Grid */
    }else if (divClass == "ecwGrid") {
      this.listeDivEcwGrid[this.listeDivEcwGrid.length] = div;
    /* Container */
    }else if (divClass == "ecwContainer") {
      this.listeDivEcwContainer[this.listeDivEcwContainer.length] = div;
    /* RemoteInputArea */
    }else if (divClass == "ecwRemoteInputArea") {
      this.listeDivRemoteInputArea[this.listeDivRemoteInputArea.length] = div;
    }
  }
}

/**
 * Construit les composants ECW de type DIV
 * @private
 */
ECW.Layout.prototype.createAllEcwDivComponent = function() {

  /* Parcours des tables */
  for (var k = 0; k < this.listeDivEcwTable.length; k++) {
    var noeudDOM = this.listeDivEcwTable[k];
    if (!noeudDOM.ecwTable) {
      ecwSetAttribute(noeudDOM, "ecwTable", new ECW.Table(noeudDOM, this.ecwUI, this));
    }
  }
  /* Parcours des tables V2 */
  for (var k = 0; k < this.listeDivEcwTableV2.length; k++) {
    var noeudDOM = this.listeDivEcwTableV2[k];
    if (!noeudDOM.ecwTable) {
      ecwSetAttribute(noeudDOM, "ecwTable", new ECW.TableV2(noeudDOM, this.ecwUI, this));      
    }
  }
  /* Parcours des doubles tables V2 */
  for (var k = 0; k < this.listeDivEcwDoubleTableV2.length; k++) {
    var noeudDOM = this.listeDivEcwDoubleTableV2[k];
    if (!noeudDOM.ecwDoubleTable) {
      ecwSetAttribute(noeudDOM, "ecwDoubleTable", new ECW.DoubleTableV2(noeudDOM, this.ecwUI, this));
    }
  }
  /* Parcours des onglets */
  for (var k = 0; k < this.listeDivEcwTabFolder.length; k++) {
    var noeudDOM = this.listeDivEcwTabFolder[k];
    if (!noeudDOM.ecwTabFolder) {
      ecwSetAttribute(noeudDOM, "ecwTabFolder", new ECW.TabFolder(noeudDOM, this.ecwUI));
    }
  }
  /* Parcours des calendriers */
  for (var k = 0; k < this.listeDivEcwCalendar.length; k++) {
    var noeudDOM = this.listeDivEcwCalendar[k];
    if (!noeudDOM.ecwCalendar) {
      ecwSetAttribute(noeudDOM, "ecwCalendar", new ECW.Calendar(noeudDOM, this.ecwUI, this));
    }
  }
  /* Parcours des treeViews Old */
  for (var k = 0; k < this.listeDivEcwTreeViewOld.length; k++) {
    var noeudDOM = this.listeDivEcwTreeViewOld[k];
    if (!noeudDOM.ecwTreeView) {
      ecwSetAttribute(noeudDOM, "ecwTreeView", new ECW.TreeViewOld(noeudDOM, this.ecwUI));
    }
  }
  /* Parcours des treeViews */
  for (var k = 0; k < this.listeDivEcwTreeView.length; k++) {
    var noeudDOM = this.listeDivEcwTreeView[k];
    if (!noeudDOM.ecwTreeView) {
      ecwSetAttribute(noeudDOM, "ecwTreeView", new ECW.TreeView(noeudDOM, this.ecwUI));
    }
  }
  /* Parcours des menus */
  for (var k = 0; k < this.listeDivEcwMenu.length; k++) {
    var noeudDOM = this.listeDivEcwMenu[k];
    if (!noeudDOM.ecwMenu) {
      ecwSetAttribute(noeudDOM, "ecwMenu", new ECW.Menu(noeudDOM, this.ecwUI, this));
    }
    var nomMenu = noeudDOM.ecwMenu.noeudDOM.id;
    /* pour chaque menu si je n'ai pas d'item il faut desactiver le bouton correspondant */      
    if (noeudDOM.ecwMenu.allMenuItem && noeudDOM.ecwMenu.allMenuItem.length == 0) {
      var btn = this.noeudDOM.getElementsByTagName("BUTTON");
      var btnFound = false;
      for (var indice = 0; indice< btn.length && !btnFound; indice++) {
        var idMenuBouton = btn[indice].getAttribute("ecwidmenu");
        if (idMenuBouton && nomMenu == idMenuBouton) {
          btn[indice].style.display = "none";
          btnFound = true;
        }
      }
    }
  }
  /* Parcours des champs heure */
  for (var k = 0; k < this.listeDivEcwTimeField.length; k++) {
    var noeudDOM = this.listeDivEcwTimeField[k];
    if (!noeudDOM.ecwTimeField) {
      ecwSetAttribute(noeudDOM, "ecwTimeField", new ECW.TimeField(noeudDOM));
    }
  }
  /* Parcours des container */
  for (var k = 0; k < this.listeDivEcwContainer.length; k++) {
    var noeudDOM = this.listeDivEcwContainer[k];
    if (!noeudDOM.ecwContainer) {
      ecwSetAttribute(noeudDOM, "ecwContainer", new ECW.Container(noeudDOM, this));
    }
  }
}

