/**
 * Creation des composants ECW.Control
 * @private
 */
ECW.Layout.prototype.createAllEcwControl = function() {

  /* Creation de champs input provisoires pour les controles autre que les INPUT */
  this.addProvisoiresInputHidden("A");
  this.addProvisoiresInputHidden("BUTTON");
  this.addProvisoiresInputHidden("TEXTAREA");
  this.addProvisoiresInputHidden("SELECT");

  /* Creation d'un tableau (listeNode) des noeuds a prendre en compte */
  /* avec application du style pour les champs Disabled */
  /* on utilise un tableau intermediaire pour pouvoir enrichir le DOM a l'aide */
  /* de insertBefore notamment */
  var listeNode = new Array;
  
  /* Ajout des champs INPUT du document (y compris les champs input provisoires) */
  var allNodes = this.noeudDOM.getElementsByTagName("INPUT");
  var node;

  /* Parcours de tous les noeuds */
  for (var i = 0; i < allNodes.length; ++i) {
    node = allNodes[i];
    /* On prend en compte TOUS les champs SAUF ceux qui sont CACHES */
    if (node.type != "hidden") {
 
     /* Ajout du noeud dans le tableau */
      listeNode[listeNode.length] = node;
      
      /* Pour les champs disabled */
      if (node.disabled) {
        addClass(node, node.nodeName + "_Disabled");
      }
      
    } else {
    
      /* Champ HIDDEN mais provisoire */
      if (node.className == "provisoires") {

        /* Ajout du noeud parent dans le tableau */
        listeNode[listeNode.length] = node.parentNode;

        /* ParentNode disabled */
        if (node.parentNode.disabled) {
          addClass(node.parentNode, node.parentNode.nodeName + "_Disabled");
        }
      }
    }
  }

  /* Suppression des champ input provisoires */
  this.removeProvisoiresInputHidden();

  /* Construction des champs a partir du tableau intermediaire */
  for (var i = 0; i < listeNode.length; ++i) {
    this.addEcwControl(listeNode[i]);
  }
}

/**
 * Associe a chaque ecwControl sa zone de saisie lorsqu'elle est definie.
 * @private
 */
ECW.Layout.prototype.linkRemoteInputAreaEcwControl = function() {

  for (var i = 0; i < this.listeDivRemoteInputArea.length; i++) {
    var div = this.listeDivRemoteInputArea[i];
    var inputs = div.getElementsByTagName("INPUT");
    for (var j = 0 ; j < inputs.length; j++) {
      if (inputs[j].ecwControl) {
        inputs[j].ecwControl.remoteInputArea = div;
      }
    }
  }
}

/**
 * Ajout d'un champ INPUT provisoire pour la balise specifie
 * @private
 */
ECW.Layout.prototype.addProvisoiresInputHidden = function(tagName) {
  var allNodes = this.noeudDOM.getElementsByTagName(tagName);
  for (var i = 0; i < allNodes.length; i++) {
    if(!allNodes[i].ecwGrid){
      var specialInputHidden = document.createElement("INPUT");
      specialInputHidden.type = "hidden";
      specialInputHidden.className = "provisoires";
      allNodes[i].appendChild(specialInputHidden);
    }
  }
}

/**
 * Suppression de tous les champs INPUT provisoires
 * @private
 */
ECW.Layout.prototype.removeProvisoiresInputHidden = function() {
  var allNodes = this.noeudDOM.getElementsByTagName("INPUT");
  var lenghtNodes = allNodes.length;
  var numNode = 0;
  for (var i = 0; i < lenghtNodes; i++) {
    if (allNodes[numNode].type == "hidden" && allNodes[numNode].className == "provisoires") {
      allNodes[numNode].parentNode.removeChild(allNodes[numNode]);
    } else {
      numNode++;
    }
  }
}

/**
 * Creation d'un objet ECW.Control a partir de son noeud DOM
 * @private
 */
ECW.Layout.prototype.addEcwControl = function(noeud) {

  var champ = noeud.ecwControl;
  if (!champ) {

    champ = new ECW.Control(noeud, this);

    /* Dans le cas d'une comboBox */
    /* Si le parent est une ComboBox et le champ est visible */
    if (champ.noeudDOM.parentNode.className.indexOf("ecwComboBox") >= 0 &&
        champ.noeudDOM.className.indexOf("ecwInvisible") < 0) {
      var listeCombo = champ.noeudDOM.parentNode.getElementsByTagName("DIV");
      if (listeCombo != null && listeCombo.length > 0) {
        comboBox = new ECW.ComboBox(champ.noeudDOM.parentNode, this.ecwUI, this, champ, listeCombo[0].ecwTable);
        ecwSetAttribute(champ.noeudDOM.parentNode, "ecwComboBox", comboBox);
        ecwSetAttribute(champ, "ecwComboBox", comboBox);
        this.listeDivEcwComboBox[this.listeDivEcwComboBox.length] = comboBox;
        if (comboBox.autoSelect) {
          this.listeDivEcwComboBoxAutoSelect[this.listeDivEcwComboBoxAutoSelect.length] = comboBox;
        } 
      }
    }
    /* Pour donner le focus au champ definis par le javascript de l'utilisateur */
    if (champ.noeudDOM.id) {
      var idControl = champ.noeudDOM.id;
      this.control[idControl] = function() {};
      this.control[idControl].setFocus = function() {
        champ.setFocus();
      }
    }
  }

  this.listeEcwControl[this.listeEcwControl.length] = champ;
  champ.index = this.listeEcwControl.length - 1;
}

/**
 * Relie les balises <label>
 * @private
 */
ECW.Layout.prototype.createLinkAllLabel = function() {

  /* Creation du lien entre les champs et d'eventuel LABEL */
  var labels = this.noeudDOM.getElementsByTagName("LABEL");
  for (var i = 0; i < labels.length; i++) {
    addClass(labels[i], "ecwLabel");
    var elt = null;
    if (labels[i].htmlFor) {
      elt = document.getElementById(labels[i].htmlFor);
      
      if (elt == null) {
        var msgError = "Erreur ECW : une balise <label> reference dans son attribut for";
        msgError += "\nun identifiant inconnu : id = [" + labels[i].htmlFor + "]";
        alert(msgError);
        return;
      }

      var suffixeTable = "";       
      /* Pose du lien entre le label et une table */
      if ((elt.className.toUpperCase() == "ECWTABLE")) {
        suffixeTable = "_EcwTable"
        elt.input.id = labels[i].htmlFor + suffixeTable;
        labels[i].htmlFor += suffixeTable;
      }
      if ((elt.className.toUpperCase() == "ECWTABLEV2")) {
        suffixeTable = "_EcwTableV2"
        elt.input.id = labels[i].htmlFor + suffixeTable;
        labels[i].htmlFor += suffixeTable;
      }
      /* Pose du lien entre le label et un champ de saisie */
      if (elt.ecwControl) {
        if (labels[i]) {
          /* si le label n'est pas un picto on l'ajoute au control */
          if (!labels[i].getAttribute("ecwPattern")) {
            elt.ecwControl.ecwLabel = labels[i];
          }
        }
      }

      /* Evenement onmouseover du LABEL */
      labels[i].onmouseover = function() {
        if (window.isClass) {
          /* On evite la mise en evidence d'un champ si c'est un picto */
          if (!window.isClass(this, "ecwLabelEmpty")) {
            if (window.addClass) {
              window.addClass(this, "ecwControlOver");
            }
          }
        }
      }

      /* Evenement onmouseout du LABEL */
      labels[i].onmouseout = function() {
        if (window.removeClass) {
          window.removeClass(this, "ecwControlOver");
        }
      }

      /* Gestion des required */
      if (isClass(labels[i], "ecwRequired") && elt) {
        this.ecwUI.addRequired(elt.id);
      }

      /* Gestion des patterns */
      if (labels[i].getAttribute("ecwPattern") && elt) {
        this.ecwUI.addValidator(elt.id, labels[i].getAttribute("ecwPattern"));
        elt.ecwControl.insertSpan(labels[i]);
      }
    }
  }
}

/**
 * Creation des elements caches necessaires au bouclage
 * @private
 */
ECW.Layout.prototype.createInputHiddenForLoop = function() {

  /* Creation dernier champ invisible pour retour au premier */
  ecwSetAttribute(this, "lastInputHidden", document.createElement("INPUT"));
  this.lastInputHidden.className = "ecwInvisible";
  this.lastInputHidden.setAttribute("autocomplete", "off");
  this.lastInputHidden.ecwLayout = this;

  /* Ajout du champ invisible en dernier */
  this.noeudDOM.appendChild(this.lastInputHidden);

  /* Creation premier champ invisible pour aller au dernier */
  ecwSetAttribute(this, "firstInputHidden", document.createElement("INPUT"));
  this.firstInputHidden.className = "ecwInvisible";
  this.firstInputHidden.setAttribute("autocomplete", "off");
  this.firstInputHidden.ecwLayout = this;

  /* Insertion du champ invisible avant le premier champ 'INPUT' */
  this.noeudDOM.insertBefore(this.firstInputHidden, this.noeudDOM.firstChild);
}

/**
 * Recherche du premier et du dernier champ (chacun doit etre visible et accessible)
 * @private
 */
ECW.Layout.prototype.searchFirstAndLastInput = function() {
  this.firstControl = this.getFirstVisibleAndEnable();
  this.lastControl = this.getLastVisibleAndEnable();
}

/**
 * Recherche le 1er champ visible et enable du formulaire
 * @private
 */
ECW.Layout.prototype.getFirstVisibleAndEnable = function() {

  /* Recherche le champ visible et enable suivant */
  var i = 0;
  if (i < this.listeEcwControl.length) {
    while ((!this.listeEcwControl[i].isVisible(true) 
        || !this.listeEcwControl[i].isEnable()) && i < this.listeEcwControl.length - 1) {
      i++;
    }
  }
  if (i < this.listeEcwControl.length) {
    if (this.listeEcwControl[i].isVisible(true) && this.listeEcwControl[i].isEnable()) {
      return this.listeEcwControl[i];
    }
  }
}

/**
 * Recherche le dernier champ visible et enable du formulaire
 * @private
 */
ECW.Layout.prototype.getLastVisibleAndEnable = function() {

  /* Recherche le champ visible et enable precedent */
  var i = this.listeEcwControl.length - 1;
  if (i >= 0) {
    while (i > 0 && (!this.listeEcwControl[i].isVisible(true) || !this.listeEcwControl[i].isEnable())) {
      i--;
    }
  }
  if (i >= 0) {
    if (this.listeEcwControl[i].isVisible(true) && this.listeEcwControl[i].isEnable()) {
      return this.listeEcwControl[i];
    }
  }
}

/**
 * Active ou non le bouclage entre premier et dernier champ (qui peuvent recevoir un focus)
 * @private
 */
ECW.Layout.prototype.computeLoop = function() {

  /* Bouclage s'il existe un premier et dernier champ visible accessible  */
  if (this.firstControl && this.lastControl) {

    var msgFirstLast = "first = " + this.firstControl.noeudDOM.id;
    msgFirstLast += " - " + this.firstControl.noeudDOM.nodeName;
    msgFirstLast += "\nlast = " + this.lastControl.noeudDOM.id;
    msgFirstLast += " - " + this.lastControl.noeudDOM.nodeName;

    /* Activation du bouclage */
    this.activateLoop();
  }
}

/**
 * Activation du bouclage
 * @private
 */
ECW.Layout.prototype.activateLoop = function() {

  /* Dernier champ cache -> focus sur le premier champ visible et accessible */
  this.lastInputHidden.onfocus = function() {
    /* S'il existe un premier champ visible et accessible */
    var firstExist = this.ecwLayout.getFirstVisibleAndEnable();
    if (firstExist) {
      firstExist.setFocus();
    }
  }

  /* Premier champ cache -> focus sur le dernier champ visible et accessible */
  this.firstInputHidden.onfocus = function() {
    /* S'il existe un dernier champ visible et accessible */
    var lastExist = this.ecwLayout.getLastVisibleAndEnable()
    if (lastExist) {
      lastExist.setFocus();
    }
  }

  /* Mode de defilement des zones de saisie avec tabIndex ou non */
  this.lastControlTabindex = this.listeEcwControl[0];
  for (var i = 0; i < this.listeEcwControl.length; i++) {
    if (this.listeEcwControl[i].noeudDOM.attributes && this.listeEcwControl[i].noeudDOM.attributes.tabindex) {
      if ((!this.firstControlTabindex) || (this.firstControlTabindex &&
        this.listeEcwControl[i].noeudDOM.attributes.tabindex.nodeValue <
        this.firstControlTabindex.noeudDOM.attributes.tabindex.nodeValue)) {
        this.firstControlTabindex = this.listeEcwControl[i];
      }
      if ((this.lastControlTabindex) && (this.listeEcwControl[i].noeudDOM.attributes.tabindex.nodeValue >
        this.lastControlTabindex.noeudDOM.attributes.tabindex.nodeValue)) {
        this.lastControlTabindex = this.listeEcwControl[i];
        this.lastInputHidden.tabIndex = "32767";
      }
      this.firstInputHidden.tabIndex = "1";
    } else {
      this.lastControlTabindex = null;
      this.lastInputHidden.tabIndex = null;
    }
  }
}

/**
 * Dimensionnement final des onglets
 * @private
 */
ECW.Layout.prototype.setSizeAllTabFolder = function() {

  for (var i = 0; i < this.listeDivEcwTabFolder.length; i++) {
  	var currentTab = this.listeDivEcwTabFolder[i];
  	//Il faut forcer un redimensionnement des onglets en priorite
  	currentTab.ecwTabFolder.refreshTabFolderSize();
 	
	currentTab.ecwTabFolder.fixerDimensions();
    var isActivate = false;
    
    /* V2 set active de la premiere page qui n'est pas disable */  
    var nbPages = currentTab.ecwTabFolder.pages.length
    for (var j = 0; j < nbPages; j++) {
      if (!isActivate) {
        if (!currentTab.ecwTabFolder.pages[j].disable) {
          currentTab.ecwTabFolder.pages[j].setActive();
          isActivate = true;
        }
      }

      /* Recherche des inputs de l'onglet */
      var listeInput = currentTab.ecwTabFolder.pages[j].noeudDOM.getElementsByTagName("INPUT");
      var nbInput = listeInput.length;
      for (var k = 0; k < nbInput; k++) {
        if (listeInput[k].ecwControl) {
          /* L'input a connaissance de son container : onglet */
          ecwSetAttribute(listeInput[k].ecwControl, "ecwTabItem", currentTab.ecwTabFolder.pages[j]);
        }
      }

    }
    if (isActivate) {
      currentTab.ecwTabFolder.desactiver();
    }
  }
}

/**
 * Initialisation des balises <select> de la table et positionnement des filtres sur une table
 * @private
 */
ECW.Layout.prototype.initSelectTableAndSetFilterTable = function() {
  // Parcours des tables
  // Cette initialisation n'est pas effectuee dans le constructeur d'une table,
  //car IE n'arrive pas a initialiser convenablement les <select>
  for (var i = 0; i < this.listeDivEcwTable.length; i++) {

    var ecwTableCurrent = this.listeDivEcwTable[i].ecwTable;
    
    // Si c'est une table reordonnable,
    //mise a jour des <select> caches 
    if (ecwTableCurrent.canReorder) {
      ecwTableCurrent.genererSelect(ecwTableCurrent.lignes);
    }

    // S'il existe un filtre rattache    
    if (ecwTableCurrent.ecwIdFilter) {	
      //Bug Fix : permet de realiser un calcul correct pour les deux navigateurs
      // IE et Firefox
      ecwTableCurrent.forceNoPositionForCompatibility();	
      
      var tableFilter = document.getElementById(ecwTableCurrent.ecwIdFilter);

      ecwTableCurrent.divTBody.style.width = "";
      ecwTableCurrent.noeudDOM.style.width = "";
	
      // Parcours des filtres
      var listeLigneBody = ecwTableCurrent.divTBody.firstChild.rows;
      
      for (var j = 0; j < 1; j++) {

        var ligneBody = listeLigneBody[j];
        for (var k = 0; k < ligneBody.cells.length; k++) {
            
          var cell = ligneBody.cells[k];
          var cellFilter = tableFilter.rows[j].cells[k];
          var owFilter = cellFilter.offsetWidth;
          var owCell = cell.offsetWidth;          
          //Si la cellule est plus petite que la cellule du filtre    
          if (owCell < owFilter) {
            cell.style.width = owFilter;
            ecwTableCurrent.divTHead.firstChild.rows[j].cells[k].style.width = owFilter;
            ecwTableCurrent.divTHead.firstChild.rows[j].cells[k].noWrap = true;
          }

          if (!ECW_isGecko_1_7_5) {
            //Positionne les champs du filtre
            this.processFilterPosition(k, ligneBody, cellFilter);
          }
        }
      }
      
      //Redimensionnement de la table (le fixer dimension permet de repasser en mode absolute     
      ecwTableCurrent.fixerDimensions();         
      ecwTableCurrent.divTBody.style.height = ecwTableCurrent.ecwHeightTable;         
    }    
  }

  this.processEcwTableAutoHeight();

  // Desynchronisation pour Mozilla 1.7.5
  // pour parer a des problemes de calculs de offsetLeft
  // apres modification du width
  if (ECW_isGecko_1_7_5) {
    setTimeout("ecwActiveUI.setFilterDimensionOnTableForLayout(" + this.idLayout + ")", 0);
  }
  
}

/**
 * Positionnement des filtres sur une table V2 de type AJAX
 * @private
 */
ECW.Layout.prototype.organizeFilterTableAjax = function(tableObject) {
	tableObject.forceNoPositionForCompatibility();       
 	var tableFilter = document.getElementById(tableObject.ecwIdFilter);	     
  	tableObject.divTBody.style.width = "";
  	tableObject.noeudDOM.style.width = "";  			      	
  	var divTBodyEle = tableObject.divTBody.firstChild;
  	while(divTBodyEle && divTBodyEle.nodeType == 3){
  		divTBodyEle = divTBodyEle.nextSibling;
  	}	    	         
	var divTHeadEle = tableObject.divTHead.firstChild;
	while(divTHeadEle && divTHeadEle.nodeType == 3){
  		divTHeadEle = divTHeadEle.nextSibling;
	}
	tableFilter.style.width = "";
	divTBodyEle.style.width = "";
	divTHeadEle.style.width = "";	
	//----------------------------------------------------------
	//ajouter le tableau d'encadrement comme pour la table ajax
	var orgFilter = tableFilter.getAttribute("ecwOrgFilter")
	if (!orgFilter) {
  		var tableObj = document.createElement("TABLE");

  		//[MA-E370022] - Mise en forme de la table du fitre
        tableObj.setAttribute('align', 'left');
        tableObj.setAttribute("border", "0");
        tableObj.cellSpacing = "2";
        tableObj.cellPadding = "4";
    	//End
    	
		var tbodyObj = document.createElement("TBODY");
		var trObj = document.createElement("TR");
		var tdObj = document.createElement("TD");
		//[MA-E370022] - Remplacement du "center" par left 
		tdObj.setAttribute('align', 'left');
		//End
		tableObj.appendChild(tbodyObj);
		tbodyObj.appendChild(trObj);
		trObj.appendChild(tdObj);	  		
  		var parentTable = tableFilter.parentNode;
  		parentTable.removeChild(tableFilter);
  		tdObj.appendChild(tableFilter);
  		parentTable.appendChild(tableObj);
  		tableFilter.setAttribute('ecwOrgFilter','true');
	}
	//-----------------------------------------------------	 	  	  		  		
	var nbCol = divTHeadEle.rows[0].cells.length;
	var sizeFilter = 0;
	var sizeTableCell = 0;
	var listFilter = tableFilter.rows[0]; 
	var currentCell = null;
	var listCellBody = divTBodyEle.rows[0];	 
	var newOlFilter = null;
	var currentSize=0;	
	for (var j=0;j<nbCol;j++) {
		currentTableCell = divTHeadEle.rows[0].cells[j];		
		listFilter.cells[j].style.width = "";
		listCellBody.cells[j].style.width = "";
		currentTableCell.style.width = "";			
		sizeFilter = listFilter.cells[j].offsetWidth;
		sizeTableCell = currentTableCell.offsetWidth;
		sizeCellBody = listCellBody.cells[j].offsetWidth;
		currentSize =  sizeTableCell;		
  		if (sizeTableCell < sizeFilter) {  			
  			sizeFilter = getComputedCSSWidth(listFilter.cells[j]);
  	 		listCellBody.cells[j].style.width = sizeFilter;
        	currentTableCell.style.width = sizeFilter;
        	//[LD] jira alignement entete et colonne avec scrollbar, filtre
        	//SIFAECW-697
        	//currentTableCell.noWrap = true;           
        	currentSize = listCellBody.cells[j].offsetWidth;
    	}    	
    	listFilter.cells[j].style.width = currentSize;
	}  	
	//Setter la largeur du tableau filtre
	var w = getComputedCSSWidth(divTBodyEle);		
	tableFilter.style.width = w;
	divTBodyEle.style.width = w;
	divTHeadEle.style.width = w;	
	//Redimensionnement de la table (le fixer dimension permet de repasser en mode absolute)	
	tableObject.fixerDimensions();   	
}

