/**
 * Detection du navigateur utilise
 * @private
 */
function ecwDetectBrowser() {
  /* User agent */
  var ua = navigator.userAgent.toLowerCase();

  ECW_isGecko = (navigator.product == "Gecko");
  ECW_isGecko_35 = ((navigator.product == "Gecko") && (ua.indexOf("/3.") != -1));
  ECW_isGecko_1_7_5 = ((navigator.product == "Gecko") && (ua.indexOf("1.7.5") != -1));
  ECW_isIE = !ECW_isGecko && ( ua.indexOf ( "msie" ) != -1 );
  ECW_isIE11 = !(window.ActiveXObject) && "ActiveXObject" in window;
  ECW_isSafari = !ECW_isGecko && !ECW_isIE && (ua.indexOf("safari") != -1);
  ECW_isOther = !ECW_isGecko && !ECW_isIE && !ECW_isSafari;
}

/* Detection du navigateur */
/* lors du chargement du script */
ecwDetectBrowser();

