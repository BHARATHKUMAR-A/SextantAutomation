/**
 * Formatage d'une date
 * @private
 */
function ecwGetCurrentDate() {

  var currentDate = new Date();

  /* Format : dd/mm/yyyy hh:nn:ss */
  var sepDate = "/";
  var formatDate = ecwPad(currentDate.getDate().toString(), 2, "0", 0) + sepDate;
  formatDate += ecwPad((currentDate.getMonth() + 1).toString(), 2, "0", 0) + sepDate;
  formatDate += currentDate.getFullYear() + " ";
  var sepHour = ":";
  formatDate += ecwPad(currentDate.getHours().toString(), 2, "0", 0) + sepHour;
  formatDate += ecwPad(currentDate.getMinutes().toString(), 2, "0", 0) + sepHour;
  formatDate += ecwPad(currentDate.getSeconds().toString(), 2, "0", 0);

  return (formatDate);
}

