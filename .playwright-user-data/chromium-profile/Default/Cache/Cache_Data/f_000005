/**
 * Actions des touches du clavier
 * @private
 */
function OnKey(event) {
  if (!event) {
    event = window.event;
  }
  // [Bug 0003285] enregistrement de la frappe (keydown) d'un raccourci clavier
  ECW_isAltKeyPressed = event.altKey;
  
  var kbActions = {
      8: "backSpace", 9: "tab", 13: "enter", 16: "shift", 17: "ctrl", 18: "alt", 27: "esc", 32:
      "space", 33: "pageUp", 34: "pageDown", 35: "end", 36: "home", 37: "left", 38: "up", 39:
      "right", 40: "down", 45: "inser", 46: "suppr",
      48: "0", 49: "1", 50: "2", 51: "3", 52: "4", 53: "5", 54: "6", 55: "7", 56: "8", 57: "9",
      112: "F1", 113: "F2", 114: "F3", 115: "F4", 116: "F5", 117: "F6",
      118: "F7", 119: "F8", 120: "F9", 121: "F10", 122: "F11", 123: "F12",
      65: "A", 66: "B", 67: "C", 68: "D", 69: "E", 70: "F", 71: "G", 72: "H", 73: "I", 74: "J",
      75: "K", 76: "L", 77: "M", 78: "N", 79: "O", 80: "P", 81: "Q", 82: "R", 83: "S", 84: "T",
      85: "U", 86: "V", 87: "W", 88: "X", 89: "Y", 90: "Z", 188: ","
  };
  var action = kbActions[event.keyCode];
  //alert("action = " + action);
  
  if (action && event.ctrlKey && event.shiftKey) {
    action = "ctrl-shift-" + action;
  } else if (action && event.ctrlKey) {
    action = "ctrl-" + action;
  }
  /* IE */
  event.cancelBubble = true;
  /* Mozilla */
  if (event.stopPropagation) {
    event.stopPropagation();
  }
  if (action == "F1" && event.altKey) {
    alert(ecwVersion);
  }
  if (action == "F12" && event.altKey) {
    ecwDisplayTimers();
  }
  if (action == "alt" && event.altKey) {
    if (ecwActiveUI.ecwAccessKey) {
      // ecwActiveUI.ecwAccessKey.show();
    }
  }

  /* Aide de la page */
  if (action == "," && event.altKey) {
    /* Declenchement */
    if (ecwActiveUI.onHelp) {
      return ecwActiveUI.onHelp();
    }
  }

  /* Touche Home */
  if (action == "esc" && event.shiftKey) {
    /* Declenchement */
    if (ecwActiveUI.onHome) {
      return ecwActiveUI.onHome();
    }
  }

  /* Touche Print */
  if (action == "P" && event.altKey) {
    /* Declenchement */
    if (ecwActiveUI.onPrint) {
      return ecwActiveUI.onPrint();
    }
  }

  /* Champ ayant le focus */
  var wChpActif = ecwActiveUI.champActif;

  /* Touche Entree */
  if (action == "enter") {
    /* Si ce n'est pas une table */
    /* Si ce n'est pas un calendrier ouvert */
    /* Si ce n'est pas une aide a la saisie ouverte */
    /* Si ce n'est pas un bouton */
    /* Si ce n'est pas un menu */
    /* Si ce n'est pas un arbre */
    /* Si ce n'est pas une textarea */
    if (wChpActif && (wChpActif.noeudDOM.ecwTable == null)
    && ((wChpActif.noeudDOM.ecwCalendar == null)
          || (wChpActif.noeudDOM.ecwCalendar && !wChpActif.noeudDOM.ecwCalendar.isDisplay))
    && ((wChpActif.noeudDOM.ecwComboBox == null)
          || (wChpActif.noeudDOM.ecwComboBox.ecwTable.noeudDOM.style.display == "none"))
    && ((wChpActif.noeudDOM.type != "button") && (wChpActif.noeudDOM.nodeName != "BUTTON"))
    && (wChpActif.noeudDOM.ecwMenu == null)
    && (wChpActif.noeudDOM.ecwTreeList == null)
    && ((wChpActif.noeudDOM.type != "textarea") && (wChpActif.noeudDOM.nodeName != "TEXTAREA"))) {

      /* RAZ Event pour IE sur ENTER */
      if (ECW_isIE) {
        if (!event) {
          event = window.event;
        }
        event.returnValue = false;
      }
      
      /* Declenchement */
      if (ecwActiveUI.onEnter && ecwActiveUI.uiEnterKeyActive ) {
        wChpActif.noeudDOM.blur();
        /* on force le passage en MAJ/min car sous IE certains evenements
         * onChange passent a la trappe. */
        if (wChpActif.noeudDOM.ecwControl) {
          wChpActif.noeudDOM.ecwControl.manageCase();
        }
        ecwActiveUI.desactiveUIEnterKey();
        return ecwActiveUI.onEnter();
      }
    }
  }

  /* Gestion de la touche ESC */
  if (action == "esc") {
    /* Si c'est une table */
    if (wChpActif && wChpActif.noeudDOM.ecwTable) {
      /* Champ associe a une combobox non deroulee */
      if (wChpActif.noeudDOM.ecwTable.ecwComboBox && wChpActif.noeudDOM.ecwTable.noeudDOM.style.display == "none") {
        /* Declenchement */
        if (ecwActiveUI.onEscape) {
          return ecwActiveUI.onEscape();
        }
      }
    }
    /* Si c'est un calendrier */
    else if (wChpActif && wChpActif.noeudDOM.ecwCalendar) {
      /* Calendrier non affichee */
      if (!wChpActif.noeudDOM.ecwCalendar.isDisplay) {
        /* Declenchement */
        if (ecwActiveUI.onEscape) {
        	if (ECW_isIE) {
        		ecwActiveUI.onEscape();
        		return false;
        	} else {        	        	
          		return ecwActiveUI.onEscape();
        	}        	
        }
      }
    }
    /* Si c'est un menu */
    else if (wChpActif && wChpActif.noeudDOM.ecwMenu) {
      wChpActif.noeudDOM.ecwMenu.onEscape();
    }
    /* Sinon */
    else if (ecwActiveUI.onEscape) {
      return ecwActiveUI.onEscape();
    }
  }
  
  /* Empeche le back du navigateur */
  if (action == "backSpace") {
    /* Si ce n'est pas un input type text */
    /* Si ce n'est pas une textarea */
    /* Si ce n'est pas une aide a la saisie ouverte */
    /* Si ce n'est pas une table */
    if (wChpActif  && (
            (wChpActif.noeudDOM.nodeName == "INPUT" && wChpActif.noeudDOM.type == "text" && !wChpActif.noeudDOM.readOnly)
         || (wChpActif.noeudDOM.nodeName == "INPUT" && wChpActif.noeudDOM.type == "password" && !wChpActif.noeudDOM.readOnly)
		 || (wChpActif.noeudDOM.nodeName == "TEXTAREA" && wChpActif.noeudDOM.type == "textarea" && !wChpActif.noeudDOM.readOnly) 
         || (wChpActif.noeudDOM.ecwComboBox  && wChpActif.noeudDOM.ecwComboBox.ecwTable.noeudDOM.style.display != "none") 
         || (wChpActif.noeudDOM.ecwTable) 
      )) {
      // Propagation
    } else {
      return false;
    }
  }

  /* Action sur le champ actif */
  if (action && ecwActiveUI.champActif) {

    /* Changement de layout */
    if (action == "ctrl-shift-left" || action == "ctrl-shift-right") {
      var layout = ecwGetLayout(ecwActiveUI.champActif.noeudDOM);
      return layout.onKey(action);
    }
 
    /* Touche Ctrl */
    if (event.ctrlKey) {
      /* Element dans un onglet */
      var noeudActuel = ecwActiveUI.champActif.noeudDOM;
      while (noeudActuel.parentNode) {
        if (noeudActuel.parentNode.ecwTabFolder) {
          return noeudActuel.parentNode.ecwTabFolder.onKey(action);
        } else {
          noeudActuel = noeudActuel.parentNode;
        }
      }
    }

    /* Aide a la saisie */
    if (ecwActiveUI.champActif.ecwComboBox) {
      return ecwActiveUI.champActif.ecwComboBox.onKey(action, event);
    }
    
    /* Noeud actif */
    var NodeActive = ecwActiveUI.champActif.noeudDOM;

    /* Table */
    if (NodeActive.ecwTable) {
      return NodeActive.ecwTable.onKey(action);
    }
    /* Table : Champ de saisie d'une page */
    if (NodeActive.ecwTableToPaginate) {
      return NodeActive.onKey(action);
    }
    /* Menu */
    if (NodeActive.ecwMenu) {
      return NodeActive.ecwMenu.onKey(action);
    }
    /* Calendrier */
    if (NodeActive.ecwCalendar) {
      return NodeActive.ecwCalendar.onKey(action, event);
    }
    /* Onglet */
    if (NodeActive.ecwTabFolder) {
      return NodeActive.ecwTabFolder.onKey(action);
    }
    /* Arbre */
    if (NodeActive.ecwTreeList) {
      return NodeActive.ecwTreeList.onKey(action);
    }
    /* Heure */
    if (NodeActive.ecwTime) {
      return NodeActive.ecwTime.onKey(action);
    }
    /* Boutons */
    if (NodeActive.tagName == "BUTTON" || (NodeActive.tagName == "INPUT" && NodeActive.type == "button")) {
      /* Test de la touche alt pour eviter les conflits avec accesskey */
      if (!event.altKey) {
        if (ecwActiveUI.ecwAccessKey && ecwActiveUI.ecwAccessKey.active.indexOf(action) >  - 1) {
          var wlabel = ecwActiveUI.ecwAccessKey.keys[ecwActiveUI.ecwAccessKey.active.indexOf(action)];
          /* Si accesskey est un bouton  */
          if (wlabel.ecwKeyNode.tagName == "BUTTON") {
            /* Positionner le focus sur le bouton */
            document.getElementById(wlabel.htmlFor).ecwControl.setFocus();
            /* et declencher l'evenement onclick si il existe */
            if (document.getElementById(wlabel.htmlFor).onclick) {
              document.getElementById(wlabel.htmlFor).onclick();
            }
            event.returnValue = false;
          }
        } else {
          /* Gestion des touches sur un champ */
          ecwActiveUI.champActif.onKey(action);
        }
      }
    }
  }
}

/**
 * Ajoute le style specifie a l'objet
 * @param obj Objet
 * @param theClass Nom du style CSS
 * @private
 */
function addClass(obj, theClass) {
  if (obj) {
    if (obj.className && obj.className != "") {
      if (obj.className.indexOf(theClass) ==  - 1) {
        obj.className = theClass + " " + obj.className;
      }
    } else {
      obj.className = theClass;
    }
  }
}

/**
 * Supprime le style specifie de l'objet
 * @param obj Objet
 * @param theClass Nom du style CSS
 * @private
 */
function removeClass(obj, theClass) {
  /* Test de l'existence de l'objet */
  if (obj && obj.className) {
    var oldClass = obj.className;
    var start = oldClass.indexOf(theClass);
    var len = theClass.length;
    if (0 == start) {
      if (len == oldClass.length) {
        obj.className = "";
      } else {
        obj.className = oldClass.substr(len + 1);
      }
    } else if (0 < start && ' ' == oldClass.charAt(start - 1)) {
      var before = oldClass.substr(0, start - 1);
      var after = oldClass.substr(start + len);
      obj.className = before + after;
    }
  }
}

/**
 * Verifie l'existence du style
 * @private
 */
function isClass(obj, theClass) {
  return (obj.className.indexOf(theClass) >= 0)
}

/**
 * Ajout du Timer pour le focus sous Mozilla
 * @private
 */
function ecwFocus(noeud) {

  /* Timer necessaire pour le focus au onload sous mozilla */
  if (ECW_isGecko) {
    window.nodeAfocuser = noeud;
    var timer = setTimeout("window.nodeAfocuser.focus();", 0);
  } else {
    noeud.focus();
  }
}

/**
 * Retourne la premiere div du style specifie pour un objet
 * @private
 */
function getFirstDivByClass(obj, className) {
  return getFirstChildByClass(obj, "DIV", className);
}

/**
 * Retourne la premiere div du style specifie pour un objet
 * @private
 */
function getFirstChildByClass(obj, tagName, className) {
  var i;
  var result;
  var child;
  var nbChildren = obj.childNodes.length;
  for (var i = 0; i < nbChildren; i++) {
    child = obj.childNodes[i];
    if (child.tagName == tagName && child.className == className) {
      result = child;
      break;
    }
  }
  return result;
}

/**
 * Retourne un tableau contenant les elements DIV de l'objet
 * qui ont le style specifie
 * @private
 */
function getChildsByClass(obj, className) {
  var i;
  var cClass = new Array;
  var child;
  var nbChildren = obj.childNodes.length;
  for (var i = 0; i < nbChildren; ++i) {
    child = obj.childNodes[i];
    if (child.tagName == "DIV" && child.className == className) {
      cClass[cClass.length] = child;
    }
  }
  return cClass;
}

/**
 * Retourne le premier descendant correspondant au type (tagName) specifie.
 * Equivalent &agrave; OBJ.getElementsByTagName(TAGNAME)[0].
 * @private
 */
function getFirstChildByTagName(obj, tagName) {
  var upcTagName = tagName.toUpperCase();
  var firstChildArray = [];
  firstChildArray[0] = obj;
  for (var i = 0; i < firstChildArray.length; ++i) {
    var node = firstChildArray[i];
    var child = node.firstChild;
    while (child) {
      if (child.tagName && child.tagName.toUpperCase() == upcTagName) {
        return child;
      } else {
        firstChildArray[firstChildArray.length] = child;
        child = child.nextSibling;
      }
    }
  }
  return null;
}

/**
 * Renvoie un tableau avec tous les fils direct de type 'tagName'.
 * @private
 */
function getChildrenByTagName(node, tagName) {
  var upcTagName = tagName.toUpperCase();
  var childArray = [];
  var child = node.firstChild;
  while (child) {
    if (child.tagName && child.tagName.toUpperCase() == upcTagName) {
      childArray[childArray.length] = child;
    }
    child = child.nextSibling;
  }
  return childArray;
}

/**
 * Retourne le noeud suivant correspondant au type (tagName) specifie.
 * @private
 */
function getNextNodeByTagName(obj, tagName) {
  var upcTagName = tagName.toUpperCase();
  var node = obj.nextSibling;
  while (node) {
    if (node.tagName && node.tagName.toUpperCase() == upcTagName) {
      return node;
    }
    node = node.nextSibling;
  }
  return null;
}

/**
 * Desactive la possibilite de selectionner un champ de texte
 * a l'aide de la souris
 * @private
 */
function desactiverSelectionTexte(element) {
  /* pour IE */
  element.onselectstart = ecwFalseFunction;
  /* pour Mozilla */
  // V2
  switch (element.tagName.toLowerCase()) {
    case "input" :
    case "textarea" :
    case "select" :
      break
    default :
      element.onmousedown = ecwFalseFunction;
  }
}

/**
 * Supprime les espaces avant et apres une chaine de caracteres
 * @private
 */
String.prototype.trim = function() {
  return this.replace(/(^\s*)|(\s*$)/g, "");
}

/**
 * Recupere le style de l'element specifie
 * @private
 */
function ecwGetComputedStyle(element) {
  var computedStyle = ("defaultView" in document) ? document.defaultView.getComputedStyle(element,
    ""): element.currentStyle;
  return computedStyle;
}

/**
 * Recupere le texte d'un noeud en crossBrowser
 * @private
 */
function ecwGetInnerText(noeud) {
  // Comment ne pas faire de test a chaque fois ? 
  // charger un script propre au browser ?
  var tc = noeud.textContent;
  if (tc) {
    return tc;
  } else {
    return noeud.innerText;
  }
}

/**
 * Positionne le texte d'un noeud en crossBrowser
 * @private
 */
function ecwSetInnerText(noeud, text) {
  
  if (noeud.textContent) {
    noeud.textContent = text;
  } else {
    noeud.innerText = text;
  }
}

/**
 * Ajoute la classe specifiee au texte specifie qui est contenu dans une balise
 * @private
 */
function ecwAddSpan(obj, cssclass, text) {
  var txt = obj;
  /* Cas d'un span dans l'objet */
  var elem = obj.getElementsByTagName("SPAN")[0];
  if (elem && elem.className != cssclass) {
    txt = elem;
  } else {
    /* Cas d'un div dans l'objet */
    elem = obj.getElementsByTagName("DIV")[0];
    if (elem) {
      txt = elem;
    }
  }
  var encodeText = ecwEncodeForRegExp(text);
  var monTexte = RegExp(encodeText, "i").exec(txt.innerHTML);
  txt.innerHTML = txt.innerHTML.replace(monTexte, "<span class='" + cssclass + "'>" + monTexte +
    "</span>");
}

/**
 * Encodage d'une valeur pour RegExp
 * @param value Valeur a encoder
 * @return Valeur encodee
 * @private
 */
function ecwEncodeForRegExp(value) {

  var encodeValue = "";
  for (var i = 0; i < value.length; i++) {
    /* Caracteres speciaux */
    if ((value.charAt(i) == "\\") || (value.charAt(i) == ".") || (value.charAt(i) == "$")
      || (value.charAt(i) == "[") || (value.charAt(i) == "]")
      || (value.charAt(i) == "(") || (value.charAt(i) == ")")
      || (value.charAt(i) == "{") || (value.charAt(i) == "}")
      || (value.charAt(i) == "^") || (value.charAt(i) == "?")
      || (value.charAt(i) == "*") || (value.charAt(i) == "+") || (value.charAt(i) == "-")) {

      encodeValue += "\\";
    }
    encodeValue += value.charAt(i);
  }
  return encodeValue;
}

/**
 * Supprime la classe specifie au texte de l'objet contenu dans une balise.
 * Inverse l'effet de la fonction ecwAddSpan()
 * @private
 */
function ecwRemoveSpan(obj, cssclass) {
  var mesSpan = obj.getElementsByTagName("SPAN");
  for (var i = 0; i < mesSpan.length; i++) {
    if (mesSpan[i].className == cssclass) {
      if (mesSpan[i].nextSibling) {
        mesSpan[i].nextSibling.nodeValue = mesSpan[i].firstChild.nodeValue +
          mesSpan[i].nextSibling.nodeValue;
        mesSpan[i].parentNode.removeChild(mesSpan[i]);
      } else {
        mesSpan[i].parentNode.innerHTML = mesSpan[i].innerHTML;
      }
      break;
    }
  }
}

