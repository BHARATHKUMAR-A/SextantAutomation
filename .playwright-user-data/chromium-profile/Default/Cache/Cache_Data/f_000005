  var form = document.forms;
  var len = form.length;
  for (var i = 0; i < len; ++i) {
    var ecwSubmit = new ECW.Submit(form[i]);
    ecwSubmit.prepareSubmit = ecwOnSubmit;
  }
}

/**
 * Cette classe est ajoutee a chaque formulaire (form) de la page lors de
 * la creation de l'ECW.UI.
 * <br>
 * Elle surcharge la methode 'submit' de chaque formulaire : lors du submit,
 * elle appellera d'abord une methode prepareSubmit (a definir).
 * <br>
 * Elle contient une reference au formulaire auquel elle est associee et
 * sauvegarde la methode 'submit' native du formulaire. Elle s'enregistre
 * egalement aupres du formulaire sous le nom 'ecwSubmit'.
 * @private
 */
ECW.Submit = function(form) {
  this.form = form;
  form.ecwSubmit = this;
  this.nativeSubmit = form.submit;
  form.submit = this.submit;
}

/**
 * Methode statique qui remplace la methode 'submit' de chaque formulaire.
 * @private
 */
ECW.Submit.prototype.submit = function() {
  /* ATTENTION : methode 'statique' qui remplace le submit du formulaire.
   * -> lorsqu'elle est appele , 'this' pointe sur le formulaire et non
   * pas sur l'objet ECW.Submit ! */
  var ok = true;
  if (this.ecwSubmit.prepareSubmit) {
    /* On recopie le callback sur le formulaire pour que 'this' pointe
     * sur le formulaire dans la methode appelee. */
    this.prepareSubmit = this.ecwSubmit.prepareSubmit;
    ok = this.prepareSubmit();
  }
  /* ATTENTION : test different de (true == ok)
   * -> teste si la methode renvoie true ou ne renvoie rien. */
  if (false != ok) {
    /* Si la methode 'prepareSubmit' ne renvoie pas false (i.e. renvoie 'true'
     * ou ne renvoie rien), on remet le submit original sur le formulaire et
     * on le (re-)declenche.
     */
    this.submit = this.ecwSubmit.nativeSubmit;
    this.submit();
  }
}

/**
 * M&eacute;thode a redefinir pour ajouter un traitement sur le 'submit' d'un formulaire.
 * Lorsque cette methode est appelee, 'this' pointe sur un objet de classe HTMLForm.
 * @private
 */
ECW.Submit.prototype.prepareSubmit = null;

