/**
 * Retourne la visibilite de l'objet
 * L'element peut ne pas etre visible du fait d'un container non visible lui-meme
 * @param noeudDOM Balise du DOM a tester
 * @param bodyVisible considere que le noeud BODY est visible meme s'il ne l'est pas.
 *        Parametre utile pour un calcul de visibilite lors de l'initialisation.
 * @private
 */
function ecwIsVisible(noeudDOM, bodyVisible) {
  var display;
  var visibility;
  var c;
  bodyVisible = true == bodyVisible;
  while (noeudDOM) {
    // Si le flag vaut true, on verifie qu'on arrive au noeud BODY AVANT de faire les tests de visibilite
    if (bodyVisible && noeudDOM.nodeName == "BODY") {
      // Si on a itere jusqu'au noeud BODY
      return true;
    }
    display = noeudDOM.style.display;
    c = display.charAt(0);
    if (('n' == c || 'N' == c) && "none" == display.toLowerCase()) {
      return false;
    }
    visibility = noeudDOM.style.visibility;
    c = visibility.charAt(0);
    if (('h' == c || 'H' == c) && "hidden" == visibility.toLowerCase()) {
      return false;
    }
    // Si le flag vaut false, on verifie qu'on arrive au noeud BODY APRES avoir fait les tests de visibilite
    if (!bodyVisible && noeudDOM.nodeName == "BODY") {
      // Si on a itere jusqu'au noeud BODY et que celui-ci est visible -> true
      return true;
    }
    // sinon, on itere sur le noeud parent
    noeudDOM = noeudDOM.parentNode;
  }
  // Impossible a atteindre : on passe forcement par le noeud BODY.
  return false;
}

/**
 * @private
 */
function getTargetElement(currentEvent) {
  var eventNav;
  var eventNavTarget;
  if (!currentEvent) {
    eventNav = window.event;
  } else {
    eventNav = currentEvent;
  }
  if (ECW_isGecko) {
    eventNavTarget = eventNav.target;
  } else if (ECW_isIE) {
    eventNavTarget = eventNav.srcElement;
  }
  return(eventNavTarget);
}

/**
 * @private
 */
function ecwIsFocusFormElement(event) {

  var formElementFocus = false;

  if (event == undefined) {
    formElementFocus = false;
  } else {
    var eventNavTarget = getTargetElement(event);
    if ((eventNavTarget.tagName.toLowerCase() == 'input') ||
        (eventNavTarget.tagName.toLowerCase() == 'select')) {
      formElementFocus = true;
    }
  }
  return(formElementFocus);
}

/**
 * Remplace tous les caracteres ' par '' pour une valeur de parametre.
 * @param value Valeur a encoder. 
 * @private
 */
function ecwEncodeJSParameterValue(value) {
  var result = value.replace(/'/g, "\\'"); 
  return result;
}

/**
 * Concatenates a substring until the determinated length is reached.
 * carPad : caractere de padding
 * sens=0 : padding avec caractere s a gauche
 * sens=1 : padding avec caractere s a droite
 * sens=2 : centre
 */
function pad(chaine, lgMax, carPad, sens){
  return carPad || (carPad = " "), (lgMax -= chaine.length) > 0 ? (carPad = new Array(Math.ceil(lgMax / carPad.length)
    + 1).join(carPad)).substr(0, sens = !sens ? lgMax : sens == 1 ? 0 : Math.ceil(lgMax / 2))
    + chaine + carPad.substr(0, lgMax - sens) : chaine;
}

