/**
 * Construit un appel de m&eacute;thode &agrave; partir d'un nom de m&eacute;thode
 * et du nombre d'arguments.
 * 
 * @private
 */
function ecwMethodCall(method, nArgs) {
  var mthdCall = method + "(";
  if (0 != nArgs) {
    mthdCall += "arguments[0]";
    for (var i = 1; i < nArgs; ++i) {
      mthdCall += ",arguments[" + i + "]";
    }
  }
  mthdCall += ")";
  return mthdCall;
}

/**
 * M&eacute;thode appel&eacute;e lors d'un rel&acirc;chement de touche juste AVANT
 * la m&eacute;thode <code>onKeyUp()</code> de l'&eacute;l&eacute;ment.
 * <br>
 * Cette m&eacute;thode est appel&eacute;e depuis le composant actif : le pointeur
 * <code>this</code> pointe donc sur ce composant.
 * 
 * @private
 */
function ecwOnKeyUp() {
  var ctrl = ecwActiveUI.champActif;
  if (ctrl) {
    // Traitement ECW dans le onkeyup (AVANT la methode originale).
    // SURTOUT NE PAS TOUCHER AU CHAMP VALUE DU NOEUD DOM : EFFETS DE BORD INDESIRABLES
    
    // On appelle la methode 'onkeyup' originale.
    if (ctrl.noeudDOM.onkeyupHTML) {
      eval(ecwMethodCall("ctrl.noeudDOM.onkeyupHTML", arguments.length));
    }
  }
}

function ecwOnChange() {
  var ctrl = ecwActiveUI.champActif;
  if (ctrl) {
    // Traitement ECW dans le onchange (AVANT la methode originale).
    ctrl.manageCase();
    // onchange pour la combo
    if (ctrl.noeudDOM.onchangeComboBox) {
      ctrl.noeudDOM.onchangeComboBox();
    }
    // On appelle la methode 'onchange' originale.
    if (ctrl.noeudDOM.onchangeHTML) {
      eval(ecwMethodCall("ctrl.noeudDOM.onchangeHTML", arguments.length));
    }
  }
}

function getAbsolutePos(el) {
  var SL = 0, ST = 0;
  var is_div = /^div$/i.test(el.tagName);
  if (is_div && el.scrollLeft)
    SL = el.scrollLeft;
  if (is_div && el.scrollTop)
    ST = el.scrollTop;
  var r = { x: el.offsetLeft - SL, y: el.offsetTop - ST };
  if (el.offsetParent) {
    var tmp = this.getAbsolutePos(el.offsetParent);
    r.x += tmp.x;
    r.y += tmp.y;
  }
  return r;
}

/**
 * Renvoie le charset d&eacute;fini dans la balise META. Si aucun charset n'est
 * d&eacute;fini, renvoie null.
 */
function ecwGetCharset() {
  var metaList = document.getElementsByTagName("META");
  var len = metaList.length;
  for (var i = 0; i < len; ++i) {
    var meta = metaList[i];
    if (meta.httpEquiv&& meta.content) {
      var a = meta.content.toLowerCase().indexOf("charset");
      var b = meta.content.indexOf("=", a);
      // normalement, le charset est la derniere info de la balise -> c = -1
      var c = meta.content.indexOf(";", b);
      if (-1 == c) {
        // cas normal
        return meta.content.substr(b + 1);
      } else {
        // normalement impossible a atteindre
        return meta.content.substring(b + 1, c - 1);
      }
    }
  }
  return null;
}

