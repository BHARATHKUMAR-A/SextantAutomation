/**
 * Validator pour les champs date.
 * @param value la valeur du champ a valider.
 * @param  ecwCalendar calendar associe au champ pour eventuellement utiliser la methode de validation du calendar.
 */
function ecwDateValidator(value,calendarPattern) {
  var datePattern;
  if (!calendarPattern) {
    datePattern = ecw.I18N.get("date");
  } else {
    return Date.checkDate(value,calendarPattern);
  }
  var jjPattern = ecw.I18N.get("calendar_%d");
  var mmPattern = ecw.I18N.get("calendar_%m");
  var aaPattern = ecw.I18N.get("calendar_%y");
  var aaaaPattern = ecw.I18N.get("calendar_%Y");
  
  var numPattern = datePattern;
  numPattern = numPattern.replace(new RegExp(aaaaPattern, "gi"), "[0-9]{4}");
  numPattern = numPattern.replace(new RegExp(aaPattern, "gi"), "[0-9]{2}");
  numPattern = numPattern.replace(new RegExp(mmPattern, "gi"), "[0-9]{1,2}");
  numPattern = numPattern.replace(new RegExp(jjPattern, "gi"), "[0-9]{1,2}");
  var numExp = new RegExp(numPattern);
  // On teste si la valeur saisie respecte le format du pattern
  // (sans verifier pour l'instant de la validite de la date)
  if (null == value.match(numExp))
    return false;
  
  // On decompose la valeur saisie pour voir si elle correspond
  // a une date correcte
  var order = datePattern.split(/\W+/);
  var array = value.split(/\D+/);
  var i = 0;
  var j = 0;
  var jj = null;
  var mm = null;
  var aa = null;
  while (i < array.length && j < order.length) {
    switch(order[j]) {
      case jjPattern :
        if (null == jj) jj = parseInt(array[i++], 10);
        break;
      case mmPattern :
        if (null == mm) mm = parseInt(array[i++], 10);
        break;
      case aaPattern :
      case aaaaPattern :
        if (null == aa) aa = parseInt(array[i++], 10);
        break;
      default :
        break;
    }
    ++j;
  }
  // Si une des valeurs (jour/mois/annee) n'est pas renseignee,
  // on lui affecte une valeur qui ne pose pas de probleme
  // (1er jour, mois de 31 jours, annee bissextile)
  if (null == jj)
    jj = 1;
  if (null == mm)
    mm = 0;
  if (null == aa)
    aa = 2000;
  // Si l'annee saisie est sur deux caracteres, on lui ajoute 1900 ou 2000
  // pour arriver entre 1970 et 2069 (valeurs arbitraires).
  if (null != aa && 100 > aa)
    aa += (aa < 70 ? 2000 : 1900);
  var date = new Date(aa, mm - 1, jj);
  return date.getDate() == jj && date.getMonth() == (mm - 1) && date.getFullYear() == aa;
}

