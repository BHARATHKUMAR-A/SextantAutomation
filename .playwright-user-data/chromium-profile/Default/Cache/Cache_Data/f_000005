 * Cette m&eacute;thode est destin&eacute;e &agrave; nettoyer un formulaire de
 * toutes les  aides &agrave; la saisie (ex : JJ/MM/AAAA dans les calendriers).
 * @param form le formulaire &acute; nettoyer (objet de type <code>HTMLForm</code>).
 */
function ecwDisableHelpContents(form) {
  for (var i in form.elements) {
    var noeudDOM = form.elements[i];
    if (noeudDOM) {
      if (noeudDOM.ecwControl && noeudDOM.ecwControl.helpContent) {
        noeudDOM.ecwControl.disableHelpContent();
      } else if (noeudDOM.ecwTimeField) {
        noeudDOM.ecwTimeField.disableHelpContent();
      }
    }
  }
}

