 * &agrave; la saisie.
 * @param form le formulaire (objet de type <code>HTMLForm</code>).
 */
function ecwEnableHelpContents(form) {
  for (var i in form.elements) {
    var noeudDOM = form.elements[i];
    if (noeudDOM) {
      if (noeudDOM.ecwControl && noeudDOM.ecwControl.helpContent) {
        noeudDOM.ecwControl.enableHelpContent();
      } else if (noeudDOM.ecwTimeField) {
