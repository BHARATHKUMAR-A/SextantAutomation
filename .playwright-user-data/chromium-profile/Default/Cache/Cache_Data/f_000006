/**
 * D&eacute;fini l'objet <b>ECW.Control</b>
 */
ECW.Control = function(noeud, layout) {
  ecwStartTimer("ECW.Control");
  ecwSetAttribute(this, "noeudDOM", noeud);
  if (layout) {
    ecwSetAttribute(this, "ecwLayout", layout);
    ecwSetAttribute(this, "ecwUI", layout.ecwUI);
  }
  ecwSetAttribute(noeud, "ecwControl", this);

  /* Constructeur */
  this.constructeur();
  ecwStopTimer("ECW.Control");
}

