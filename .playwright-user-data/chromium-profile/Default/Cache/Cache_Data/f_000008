/**
 * Constructeur de l'objet Table
 * @private
 */
ECW.Table.prototype.constructeur = function() {

  if (this.noeudDOM.getAttribute("ecwCanReorder")
      && this.noeudDOM.getAttribute("ecwCanReorder") == "true") {
    this.canReorder = true;
  }

  if (this.noeudDOM.getAttribute("ecwNumerotation")
      && this.noeudDOM.getAttribute("ecwNumerotation") == "true") {
    this.numerotation = true;
    this.numerotate();
  }

  if (this.noeudDOM.getAttribute("ecwShowSelection")
      && this.noeudDOM.getAttribute("ecwShowSelection") == "false") {
    this.showSelection = false;
  }
  
  if (this.noeudDOM.getAttribute("ecwAlternateColor")
      && this.noeudDOM.getAttribute("ecwAlternateColor") == "true") {
    this.alternateColor = true;
  }
  
  /* Ajustement automatiquement de la hauteur de la table en fonction de la taille de la page */
  if ((this.noeudDOM.getAttribute("ecwAutoHeight") != null)
      && (this.noeudDOM.getAttribute("ecwAutoHeight") == "true")) {
    this.autoHeight = true;
  } else {
    this.autoHeight = false;
  }

  /* Creation des DIV pour ECW.Table */
  this.createStructureDOM();

  /* Traitement a effectuer sur les lignes */
  this.creerComportementLignes();

  /* Supprimer la selection texte du navigateur */
  if (this.showSelection) {
    //desactiverSelectionTexte(this.noeudDOM);
  }
  
 
  
  this.fixerDimensions();

	

  if (!this.showSelection) {
      return;
  }

  /* Creation de la zone d'actions pour la double table */
  if (this.selectionDoubleTable) {
    this.createDivActionsDoubleSelect();
  }

  /* Creation des balises <select> cachee */
  this.createHiddenSelect();

  /* Modif V2.0 : Mise a jour du tri par defaut */
  if (!this.ajaxAction && this.noeudDOM.attributes.ecwDefaultSort) {
    this.initSort();
  }

  /* Dans le cas d'un comboBox, rendre invisible la DIV de la liste */
  if (this.noeudDOM.parentNode.className.indexOf("ecwComboBox") >= 0) {
    addClass(this.noeudDOM, "invisible");
  }
  
  /* Selection Double Table */
  if (this.selectionDoubleTable) {
    this.processSelectionDoubleTable();
  }
  /* Pas de Double Table */
  else {
    /* Reordonnancement */
    if (this.canReorder && (this.divReorder == null)) {

      /* Creation de la zone d'actions pour reordonner la table */
      this.createDivReorder();

      /* Tableau pour rendu visuel */
      this.createTableFormat();

      var tr = getFirstChildByTagName(this.tableFormat, "TR");
      var td = document.createElement("TD");
      tr.appendChild(td);
    
      /* Ajout de la div de reordonnancement */
      td.appendChild(this.divReorder);
    }
  }
  if (this.ecwComboBox) {
    this.ecwComboBox.listBuilded = true;
  }
  
}

/**
 * Traitement de la selection avec double table.
 * @private
 */
ECW.Table.prototype.processSelectionDoubleTable = function() {

  /* Tableau pour rendu visuel */
  this.createTableFormat();

  /* Boutons d'actions pour la double table */
  var tr = this.tableFormat.getElementsByTagName("TR")[1];
  var td = document.createElement("TD");
  tr.appendChild(td);

  td.appendChild(this.divActionsDoubleSelect);

  /* Creation de la table cible */
  this.createDivTableTargetSelect();

  /* Ajout de la nouvelle table */
  td = document.createElement("TD");
  tr.appendChild(td);
  td.appendChild(this.divTableTargetSelect);

  ecwSetAttribute(this, "ecwTableTargetSelect", new ECW.Table(this.divTableTargetSelect, this.ecwUI));
  ecwSetAttribute(this.ecwTableTargetSelect, "ecwTableSrcSelect", this);
  ecwSetAttribute(this.ecwTableTargetSelect, "tabNameKey", this.tabNameKey);

  /* Libelle de la nouvelle table */
  var labelTableSelect = document.getElementById(this.noeudDOM.getAttribute("ecwIdLabelSelection"));
  if (labelTableSelect) {
    var firstLine = getFirstChildByTagName(this.tableFormat, "TR");
    var cellLabelSelection = firstLine.cells[2];
    /* Lien entre label et table */
    labelTableSelect.htmlFor = this.ecwTableTargetSelect.noeudDOM.id;
    cellLabelSelection.appendChild(labelTableSelect);
  }

  /* Suppression des lignes non selectionnees dans la table cible */
  var tbodyTableSelect = getFirstChildByTagName(this.ecwTableTargetSelect.divTBody, "TBODY");
  var allTr = tbodyTableSelect.getElementsByTagName("TR");
  var countTr = allTr.length;
  for (var i = countTr - 1; i >= 0; i--) {
    /* tbody -> tr */
    /* si ecwSelection != "true", suppression */
    if (!this.isSelectedInDoubleTable(allTr[i])) {
      tbodyTableSelect.removeChild(allTr[i]);
    }
  }

  /* Suppression des lignes selectionnees dans la table source */
  var tbodyTable = getFirstChildByTagName(this.divTBody, "TBODY");
  allTr = tbodyTable.getElementsByTagName("TR");
  countTr = allTr.length;
  for (var i = countTr - 1; i >= 0; i--) {
    /* tbody -> tr */
    /* si ecwSelection == "true", suppression */
    if (this.isSelectedInDoubleTable(allTr[i])) {
      tbodyTable.removeChild(allTr[i]);
    }
  }

  /* Maj des comportements des lignes */
  this.majAllTableLinesBehaviour();

  /* Mise a jour des <select> caches */
  this.genererSelect(this.ecwTableTargetSelect.lignes);

  /* Reordonnancement de la table cible */
  if (this.canReorder) {

    /* Creation de la zone d'actions pour reordonner la table */
    this.ecwTableTargetSelect.createDivReorder();
    this.canReorder = false;
    this.ecwTableTargetSelect.canReorder = true;

    var tr = this.tableFormat.getElementsByTagName("TR")[1];
    var td = document.createElement("TD");
    tr.appendChild(td);

    /* Ajout de la div de reordonnancement */
    td.appendChild(this.ecwTableTargetSelect.divReorder);
  }

  /* Mise a jour des entetes */
  this.updateHeader(this);
  this.updateHeader(this.ecwTableTargetSelect);
}

/**
 * Retourne true si c'est une ligne selectionnee
 * pour la selection avec double table.
 * @param lineTr Ligne a verifier
 * @private
 */
ECW.Table.prototype.isSelectedInDoubleTable = function(lineTr) {
  var selected = false;
  if (lineTr
      && lineTr.getAttribute("ecwSelection")
      && lineTr.getAttribute("ecwSelection") == "true") {
    selected = true;
  }
  return selected;
}

/**
 * Cree un tableau pour formatter :
 *  - les boutons d'actions pour le reordonnancement,
 *  - le placement des doubles tables
 * @private
 */
ECW.Table.prototype.createTableFormat = function() {

  /* Creation d'un tableau de formattage */
  if (this.tableFormat == null) {
    ecwSetAttribute(this, "tableFormat", document.createElement("TABLE"));
    this.tableFormat.setAttribute("border", "0");
    this.tableFormat.cellSpacing = "2";
    this.tableFormat.cellPadding = "4";
    this.tableFormat.setAttribute("align", "center");

    var tbody = document.createElement("TBODY");
    this.tableFormat.appendChild(tbody);

    this.noeudDOM.parentNode.insertBefore(this.tableFormat, this.noeudDOM.nextSibling);

    /* Si selection avec double table */
    if (this.selectionDoubleTable) {
      /* Ligne des labels */
      var firstTr = document.createElement("TR");
      tbody.appendChild(firstTr);

      var cellTd = document.createElement("TD");
      firstTr.appendChild(cellTd);

      /* Recherche d'un label associe */
      /* -> Label de table ou label pour table de selection */
      var labels = this.ecwLayout.noeudDOM.getElementsByTagName("LABEL");     
      for (var i = 0; i < labels.length; i++) {
        if (labels[i].htmlFor && (labels[i].htmlFor == this.noeudDOM.id)) {
          /* Deplacement de la balise <label> */
          cellTd.appendChild(labels[i]);
          break;
        }
      }

      /* Espace */
      cellTd = document.createElement("TD");
      firstTr.appendChild(cellTd);

      /* Cellule pour Libelle double table */
      cellTd = document.createElement("TD");
      firstTr.appendChild(cellTd);
    }

    /* Ligne pour les tables */
    var tr = document.createElement("TR");
    tbody.appendChild(tr);
    
    var td = document.createElement("TD");
    td.setAttribute("align", "center");
    tr.appendChild(td);

    if (this.noeudDOM) {
      td.appendChild(this.noeudDOM);
    }
  }
}

