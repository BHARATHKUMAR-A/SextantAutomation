  this.ecwTable.lastPage();
}

function ecwTableAjaxInputGotoOnKey(action) {
  if (action == "enter") {        
    var inputGoToPage = this.ecwTableToPaginate.inputGoToPage;
    if (inputGoToPage.value != null && inputGoToPage.value.trim() != "") {
      this.ecwTableToPaginate.goToPage(inputGoToPage.value);
      /* Focus */
      this.ecwControl.setFocus();
      this.ecwControl.select();
    }
  }
}

function ecwTableAjaxInputGotoOnClick() {
  var inputGoToPage = this.ecwTable.inputGoToPage;
  if (inputGoToPage.value != null && inputGoToPage.value.trim() != "") {
    this.ecwTable.goToPage(inputGoToPage.value);
    /* Focus */
    inputGoToPage.ecwControl.setFocus();
    inputGoToPage.ecwControl.select();
  }
}

/**
 * Creation d'une span dans une td d'un tr
 * @param tr Ligne
 * @param innerDiv InnerHTML de la div dans la cellule
 * @param balise td creee
 * @private
 */
ECW.Table.prototype.createDivInTd = function(tr, innerDiv) {
  var td = document.createElement("TD");
  var div = document.createElement("DIV");
  div.setAttribute("align", "center");
  div.innerHTML = innerDiv;
  tr.appendChild(td);
  td.appendChild(div);
  return td;
}

/**
 * Navigation dans la table -> page precedente
 * @param selectLastLine Boolean indiquant si la selection sera faite sur la premiere ou derniere ligne.
 * @private
 */
ECW.Table.prototype.previousPage = function(selectLastLine) {
  /* Si la table est ajaxisee */
  if (this.ajaxAction && (this.currentPage != 0) && (parseInt(this.currentPage, 10) > 1)) {
    this.currentPage--;
    this.refreshInternalAjax();
    if (selectLastLine) {
      this.selectionnerLigne(this.lignes[this.lignes.length - 1]);
    } else {
      this.selectionnerLigne(this.lignes[0]);
    }
  }
}

/**
 * Navigation dans la table -> page suivante
 * @private
 */
ECW.Table.prototype.nextPage = function() {
  /* Si la table est ajaxisee */
  if (this.ajaxAction && (this.currentPage != 0) && (parseInt(this.currentPage, 10) < parseInt(this.numberOfPage, 10))) {
    this.currentPage++;
       this.refreshInternalAjax();
    this.selectionnerLigne(this.lignes[0]);
  }
}

/**
 * Navigation dans la table -> premiere page
 * @private
 */
ECW.Table.prototype.firstPage = function() {
  /* Si la table est ajaxisee */
  if (this.ajaxAction && (this.currentPage != 0) && (parseInt(this.currentPage, 10) != 1)) { 
    this.currentPage = 1;
    this.refreshInternalAjax();
    this.selectionnerLigne(this.lignes[0]);
  }
}

/**
 * Navigation dans la table -> derniere page
 * @private
 */
ECW.Table.prototype.lastPage = function() {
  /* Si la table est ajaxisee */
  if (this.ajaxAction && (this.currentPage != 0) && (parseInt(this.currentPage, 10) < parseInt(this.numberOfPage, 10))) {
    this.currentPage = this.numberOfPage;
    this.refreshInternalAjax();
    this.selectionnerLigne(this.lignes[0]);
  }
}

/**
 * Navigation dans la table -> aller a la page demandee
 * @param page Numero de page
 * @private
 */
ECW.Table.prototype.goToPage = function(page) {
  /* Si la table est ajaxisee */
  if (this.ajaxAction) {
    /* C'est un nombre */
    if (ecwIsValidNumber(page)) {
      var pageNo = parseInt(page, 10);
      if (pageNo <= 0 || pageNo > parseInt(this.numberOfPage, 10)) {
        // Par defaut, ECW n'affiche aucun message
        this.inputGoToPage.ecwControl.setUIMessage("W", "IncorrectPageNumber", null, null);
      } else {
        this.currentPage = pageNo;
        this.refreshInternalAjax();
      }
    }
  }
}

/**
 * R&eacute;cup&egrave;re la page courante. Renvoie le num&eacute;ro de la page
 * courante (cas d'une table AJAX) ou 0 s'il s'agit d'une table classique. 
 */
ECW.Table.prototype.getCurrentPage = function() {
  /* Si la table est ajaxisee */
  if (this.ajaxAction) {
    return this.currentPage;
  } else {
    return 0;
  }
}

/**
 * Renvoie le nombre d'&eacute;l&eacute;ment total
 * pour une table gros volume. 
 */
ECW.Table.prototype.getNbOfElement = function() {
  if (this.ajaxAction) {
    return this.numberOfElement;
  } else {
    return this.getNbLines();
  }
}

/**
 * Gestion du onclick d'une action de type Icone.
 * @param {Object} span Icone action concerne.
 */
function ecwTableCallClickAction(span) {
  window.ecwTableAction = null;
  window.ecwTableAction = span.getAttribute("ecwonclick");
}

/**
 * Indique si une action de type Icone est d&eacute;clench&eacute;e
 * (&agrave; utiliser dans l'&eacute;v&egrave;nement onSelect)
 */
ECW.Table.prototype.hasActionIconSelected = function() {
  if (window.ecwTableAction) {
    return true;
  } else {
    return false;
  }
}

/**
 * Methode de recalcul de la hauteur de la derniere table si elle est en mode autoHeight
 */
function ecwTableProcessAutoHeight(mesListeDivEcwTable) {
  /* On parcours la liste des tables depuis la fin jusqu'a trouver la premiere table en mode autoHeight */
  /* On ajuste sa taille en fonction de la place restante */
  if (mesListeDivEcwTable) {
    var nbTables = mesListeDivEcwTable.length - 1;
    var tableTrouve = false;
    /* Parcours des tables */
    for (var k = nbTables; k >= 0 && !tableTrouve; k--) {
      var maTable = mesListeDivEcwTable[k].ecwTable;
      if (maTable.autoHeight && maTable.lignes && maTable.lignes.length != 0) {
        var hauteurLigne = maTable.lignes[0].offsetHeight;
        var lastInputHiddenLayout = maTable.ecwLayout.lastInputHidden;
        var hauteurDispo = maTable.ecwLayout.noeudDOM.clientHeight 
          - lastInputHiddenLayout.offsetTop - lastInputHiddenLayout.offsetHeight - 2;
        var nbLigneSupp = parseInt(hauteurDispo / hauteurLigne, 10) - 1;
        var newNbLigne = Math.max(maTable.nbligne + nbLigneSupp, 1);
        maTable.noeudDOM.setAttribute("ecwNbLines", newNbLigne);
        maTable.fixerDimensions();
        tableTrouve = true;
      }
    }
  }
}

/**
 * @param evtType le type d'&eacute;v&egrave;nement qui d&eacute;clenche le message &agrave; afficher.
 * Sert &eacute;galement de cl&eacute; i18n si le message n'est pas personnalis&eacute;.
 * @param message le message (internationalis&eacute;) qui sera affich&eacute;. La valeur null
 * @private
 */
ECW.Table.prototype.setUIMessage = function(gravity, evtType, message, i18n, show) {
  var msg = this.getMessage(evtType);
  if (null == msg && null != message) {
    msg = message;
  }
  if (null == msg && null != i18n) {
    msg = ecw.I18N.get(evtType);
  }
  this.messageErrorKey = evtType;
  this.messageErrorGravity = gravity;
  this.messageError = msg;
  if (this.ecwTableTargetSelect) {
    this.ecwTableTargetSelect.messageErrorKey = evtType;
    this.ecwTableTargetSelect.messageErrorGravity = gravity;
    this.ecwTableTargetSelect.messageError = msg;
  }
  if (false != show) {
    // si show vaut true ou n'est pas positionne, on affiche le message.
    this.showUIMessage();
  }
}


/**
 * Efface le message d'erreur courrant de ce control.
 * @private
 */
ECW.Table.prototype.clearUIMessage = function() {
  if (this.messageError) {
    this.hideUIMessage();
    // la remise a zero doit etre faite APRES la desactivation du message.
    this.messageError = null;
    this.messageErrorKey = null;
    if (this.ecwTableTargetSelect) {
      this.ecwTableTargetSelect.messageErrorKey = null;
      this.ecwTableTargetSelect.messageError = null;
    }
  }
}

/**
 * Affiche le message d'erreur 'courant' de ce control.
 * @private
 */
ECW.Table.prototype.showUIMessage = function() {
  if (this.messageError) {
    this.ecwUI.setMessage(this.messageErrorGravity, this.messageError);
  }
}

/**
 * Masque le message d'erreur affiche pour ce control.
 * @private
 */
ECW.Table.prototype.hideUIMessage = function() {
  if (null != this.messageError && this.messageError == this.ecwUI.getMessage()) {
    this.ecwUI.clearMessage();
  }
}

/**
 * Sp&eacute;cifie le message &agrave; afficher lorsqu'une erreur ou un warning est lev&eacute;.
 * <br>
 * Les messages que l'on peut modifier dans ce composant sont :
 * <ul>
 *   <li><code>"NoRowSelected"</code> : le message affich&eacute; dans une double table
 *       lorsque l'utilisateur clique sur une fl&egrave;che sans s&eacute;lectionner de ligne.</li>
 *   <li><code>"IncorrectPageNumber"</code> : le message affich&eacute; lorsqu'on essaye d'aller
 *       sur une page inexistante (num&eacute;ro inf&egrave;rieur &agrave; 0 ou sup&eacute;rieur
 *       au nombre de pages).</li>
 * </ul>
 * 
 * @param evtType le type d'&eacute;v&egrave;nement qui d&eacute;clenche le message &agrave; afficher.
 * @param message le message (internationalis&eacute;) qui sera affich&eacute;. La valeur null
 * r&eacute;tablit le message d'origine d'ECW.
 */
ECW.Table.prototype.setMessage = function(evtType, message) {
  switch (evtType) {
    // mettre ici tous les 'case' concernant uniquement le controle inputGoToPage
    case "IncorrectPageNumber" :
      this.setMessageGoToPage(evtType, message);
      break;
    // mettre ici tous les 'case' concernant uniquement la table
    case "NoRowSelected" :
      this.setMessageTable(evtType, message);
      break;
    // mettre ici tous les 'case' concernant la table et le controle inputGoToPage
    default :
      this.setMessageGoToPage(evtType, message);
      this.setMessageTable(evtType, message);
  }
}

/**
 * Sp&eacute;cifie le message &agrave; afficher lorsqu'une erreur ou un warning
 * est lev&eacute; sur la table.
 * @private
 */
ECW.Table.prototype.setMessageTable = function(evtType, message) {
  this.messages[evtType] = message;
  if (this.messageErrorKey == evtType) {
    var show = this.messageError == this.ecwUI.getMessage();
    this.setUIMessage(this.messageErrorGravity, evtType, message, null, show);
  }
}

/**
 * Sp&eacute;cifie le message &agrave; afficher lorsqu'une erreur ou un warning
 * est lev&eacute; sur le champ <code>inputGoToPage</code>.
 * @private
 */
ECW.Table.prototype.setMessageGoToPage = function(evtType, message) {
  if (this.inputGoToPage && this.inputGoToPage.ecwControl) {
    this.inputGoToPage.ecwControl.setMessage(evtType, message);
  }
}

/**
 * Renvoie le message affich&eacute; lorsqu'une erreur ou un warning est lev&eacute;.
 * La valeur null signifie que la valeur par d&eacute;faut d'ECW sera utilis&eacute;e.
 */
ECW.Table.prototype.getMessage = function(evtType) {
  return this.messages[evtType];
}

/**
 * Efface le message d'erreur s'il est affich&eacute;.
 */
ECW.Table.prototype.clearMessage = function() {
  this.clearUIMessage();
}

/**
 * Retourne l'identifiant de la colonne de tri.
 * Vaut -1 si aucune colonne n'est triee.
 * @return Identifiant de la colonne de tri.
 */
ECW.Table.prototype.getSortColId = function() {
  if (null == this.triActif || 0 == this.triActif) {
    if (null == this.sortColId) {
      return -1;
    } else {
      return this.sortColId;
    }
  } else {
    return Math.abs(this.triActif) - 1;
  }
}

/**
 * Indique si le tri est croissant sur la colonne de tri.
 * @return Tri croissant ou decroissant de la colonne de tri.
 */
ECW.Table.prototype.isSortIncrease = function() {
  if (null == this.triActif || 0 == this.triActif) {
    return this.sortIncrease;
  } else {
    return this.triActif > 0;
  }
}

/**
 * Permet de savoir si la table est vide ou non.
 * @private
 */
ECW.Table.prototype.isEmptyTable = function() {
  return (this.lignes == null);
}

/**
 * Permet de savoir si la table contient une seule ligne.
 * @private
 */
ECW.Table.prototype.hasOnlyOneLine = function() {
  var result = false;
  if (this.lignes && this.lignes.length) {
    result = (this.lignes.length == 1); 
  }
  return result;
}

