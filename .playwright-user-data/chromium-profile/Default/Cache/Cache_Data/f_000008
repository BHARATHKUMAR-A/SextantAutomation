/**
 * Creation de la div de la table cible.
 * @private 
 */
ECW.Table.prototype.createDivTableTargetSelect = function() {

  var divNewTable = document.createElement("DIV");
  divNewTable.className = "ecwTable";
  divNewTable.id = this.noeudDOM.id + "_select";

  if (this.noeudDOM.getAttribute("ecwNbLines")) {
    divNewTable.setAttribute("ecwNbLines", this.noeudDOM.getAttribute("ecwNbLines"));
  }
  if (this.noeudDOM.getAttribute("ecwNumerotation")) {
    divNewTable.setAttribute("ecwNumerotation", this.noeudDOM.getAttribute("ecwNumerotation"));
  }
  if (this.noeudDOM.getAttribute("ecwAlternateColor")) {
    divNewTable.setAttribute("ecwAlternateColor", this.noeudDOM.getAttribute("ecwAlternateColor"));
  }
  if (this.noeudDOM.getAttribute("ecwSelection") && (this.noeudDOM.getAttribute("ecwSelection") == "doubleTable")) {
    divNewTable.setAttribute("ecwSelection", "multiple");
  }

  var newTable = document.createElement("TABLE");
  newTable.cellSpacing = "0";
  newTable.cellPadding = "0";

  var currentTHead = getFirstChildByTagName(this.divTBody, "THEAD");
  if (currentTHead) {
    var cloneTHead = currentTHead.cloneNode(true);
    /* Suppression de la 1ere colonne de numerotation */
    if (this.numerotation) {

      var firstTr = getFirstChildByTagName(cloneTHead, "TR");
      var firstTd = getFirstChildByTagName(cloneTHead, "TD");
      /* thead -> tr -> td */
      firstTr.removeChild(firstTd);
    }
    newTable.appendChild(cloneTHead);
  }

  var currentTBody = getFirstChildByTagName(this.divTBody, "TBODY");
  newTBody = currentTBody.cloneNode(true);
  
  /* Suppression de la 1ere colonne de numerotation */
  if (this.numerotation) {

    var allTr = newTBody.getElementsByTagName("TR");
    for (var i = 0; i < allTr.length; i++) {
      var firstTd = getFirstChildByTagName(allTr[i], "TD");
      /* tbody -> tr -> td */
      allTr[i].removeChild(firstTd);
    }
  }

  newTable.appendChild(newTBody);
  
  divNewTable.appendChild(newTable);
  this.divTableTargetSelect = divNewTable;
}

/**
 * Mise a jour des comportements des lignes des deux tables.
 * @private 
 */
ECW.Table.prototype.majAllTableLinesBehaviour = function() {

  this.creerComportementLignes();
  this.ligneActive = null;
  /* Mise a jour de la numerotation */
  this.processNumerotation();
  
  this.ecwTableTargetSelect.creerComportementLignes();
  this.ecwTableTargetSelect.ligneActive = null;
  /* Mise a jour de la numerotation */
  this.ecwTableTargetSelect.processNumerotation();
}

/**
 * Suppression des styles utilises pour une ligne.
 * @private 
 */
ECW.Table.prototype.removeStyleLines = function(line) {

  /* Style Multi-selection */
  removeClass(line, "ecwTableLineMultiple");

  /* Style Mono-selection */
  removeClass(line, "ecwTableLineActive");
  removeClass(line, "ecwTableLineSelect");

  /* Style alternee */    
  removeClass(line, "ecwTableAlternateLine1");
  removeClass(line, "ecwTableAlternateLine2");
  
  removeClass(line, "ecwTableLineOver");
}

/**
 * Selection de la ligne la plus proche de celle deplacee
 * pour la table concernee.
 * @param rIndexActiveLine rIndex de la ligne deplacee.
 * @param ecwTable Objet ECW.Table concerne.
 * @private 
 */
ECW.Table.prototype.selectNextLineAfterMove = function(rIndexActiveLine, ecwTable) {

  var newIndexSelect = -1;
  if ((rIndexActiveLine > 0) && (rIndexActiveLine < ecwTable.lignes.length)) {
    newIndexSelect = rIndexActiveLine - 1;
  }
  else if (rIndexActiveLine >= ecwTable.lignes.length) {
    newIndexSelect = ecwTable.lignes.length - 1;
  }
  if (newIndexSelect != -1) {
    ecwTable.selectionnerLigne(ecwTable.lignes[newIndexSelect]);
  }
}

/**
 * Deplacement de toutes les lignes d'une table a une autre.
 * @param ecwTableSource Table source.
 * @param ecwTableTarget Table cible.
 * @private 
 */
ECW.Table.prototype.moveAllLineFromTo = function(ecwTableSource, ecwTableTarget) {

  if (ecwTableSource.lignes && ecwTableSource.lignes.length != 0) {

    var tbodySelect = getFirstChildByTagName(ecwTableTarget.divTBody, "TBODY");
    /* Utilisation de nbNodes : */
    /* car appendChild() deplace le noeud et modifie la valeur de ecwTableSource.lignes.length */
    var nbNodes = ecwTableSource.lignes.length;
    var currentLine = null;
    for (var i = 0; i < nbNodes; i++) {
      currentLine = ecwTableSource.lignes[0];
      tbodySelect.appendChild(currentLine);
    }

    /* Maj des comportements des lignes */
    this.majAllTableLinesBehaviour();

    /* Selection sur derniere ligne ajoutee */
    ecwTableTarget.selectionnerLigne(currentLine);
    
    /* Mise a jour des <select> caches */
    this.genererSelect(this.ecwTableTargetSelect.lignes);
    
    /* Reinitialisation de la multi-selection */
    ecwTableSource.tabLigneMulti = [];
    
    /* Mise a jour des entetes */
    this.updateHeader(ecwTableSource);
    this.updateHeader(ecwTableTarget);
  }
}

/**
 * Ajout de toutes les lignes dans la table de selection.
 * @private 
 */
ECW.Table.prototype.addAllLine = function() {
  /* Deplacement de toutes les lignes dans la table de selection */
  this.moveAllLineFromTo(this, this.ecwTableTargetSelect);
  this.clearUIMessage();
  this.ecwTableTargetSelect.clearUIMessage();

  if (this.onSelectionChanged) {
    this.onSelectionChanged();
  }
}

/**
 * Suppression de toutes les lignes dans la table de selection.
 * @private 
 */
ECW.Table.prototype.removeAllLine = function() {
  /* Deplacement de toutes les lignes dans la table initiale */
  this.moveAllLineFromTo(this.ecwTableTargetSelect, this);
  this.clearUIMessage();
  this.ecwTableTargetSelect.clearUIMessage();

  if (this.onSelectionChanged) {
    this.onSelectionChanged();
  }
}

/**
 * Deplacement de(s) ligne(s) selectionnee(s) d'une table a une autre.
 * @param ecwTableSource Table source.
 * @param ecwTableTarget Table cible.
 * @private 
 */
ECW.Table.prototype.moveLineFromTo = function(ecwTableSource, ecwTableTarget) {

  /* Si selection */
  if (ecwTableSource.ligneActive) {
       this.clearUIMessage();
      this.ecwTableTargetSelect.clearUIMessage();
    var tbodySelect = getFirstChildByTagName(ecwTableTarget.divTBody, "TBODY");
    var currentLine;
    var rIndexActiveLine;

    /* Mono-selection */
    if (ecwTableSource.tabLigneMulti.length == 0) {
      currentLine = ecwTableSource.ligneActive;
      rIndexActiveLine = ecwTableSource.ligneActive.rIndex;
      tbodySelect.appendChild(ecwTableSource.ligneActive);      
    }
    /* Multi-selection */
    else {
      var listeMultiSelect = ecwTableSource.tabLigneMulti;
      currentLine = listeMultiSelect[0];
      rIndexActiveLine = listeMultiSelect[0].rIndex;

      for (var i = 0; i < listeMultiSelect.length; i++) {
        tbodySelect.appendChild(listeMultiSelect[i]);      
      }
      
      /* Reinitialisation de la multi-selection */
      ecwTableSource.tabLigneMulti = [];
    }
   
    /* Maj des comportements des lignes */
    this.majAllTableLinesBehaviour();
    
    /* Selection sur ligne ajoutee */
    ecwTableTarget.selectionnerLigneWithOutFocus(currentLine);
    ecwTableTarget.desactiver();

    /* Selection de la ligne la plus proche dans la table */
    this.selectNextLineAfterMove(rIndexActiveLine, ecwTableSource);
    
    /* Mise a jour des <select> caches */
    this.genererSelect(this.ecwTableTargetSelect.lignes);
    
    /* Mise a jour des entetes */
    this.updateHeader(ecwTableSource);
    this.updateHeader(ecwTableTarget);
  } else {
      // Par defaut, ECW n'affiche aucun message
      this.setUIMessage("W", "NoRowSelected", null, null);
  }
}

/**
 * Mise a jour de la table d'entete.
 * @private
 */
ECW.Table.prototype.updateHeader = function(ecwTable) {
    if (ecwTable.divTHead) {
        var oldBody = getFirstChildByTagName(ecwTable.divTHead, "TBODY");
        var newBody = getFirstChildByTagName(ecwTable.divTBody, "TBODY").cloneNode(true);
        ecwTable.divTHead.firstChild.replaceChild(newBody, oldBody);
    }
}

/**
 * Ajout d'une ligne dans la table de selection.
 * @private
 */
ECW.Table.prototype.addLine = function() {
  /* Deplacement de(s) ligne(s) selectionnee(s) dans la table de selection */
  this.moveLineFromTo(this, this.ecwTableTargetSelect);
  
  if (this.onSelectionChanged) {
    this.onSelectionChanged();
  }
}

/**
 * Suppression d'une ligne dans la table de selection.
 * @private
 */
ECW.Table.prototype.removeLine = function() {
  /* Deplacement de(s) ligne(s) selectionnee(s) dans la table de selection */
  this.moveLineFromTo(this.ecwTableTargetSelect, this);
  
  if (this.onSelectionChanged) {
    this.onSelectionChanged();
  }
}

/**
 * Appel Ajax.
 * @param Valeur saisie par l'utilisateur (cas de la ComboBox)
 * @return divBody de la Table
 * @private
 */
ECW.Table.prototype.callAjax = function(userValue) {

  /* Generation de l'url de la requete Ajax */
  var url = this.ajaxAction;

  var data = new Array();
  /* Si le champ est renseigne */
  if (userValue) {
    data["value"] = userValue;
  }
  data["page"] = this.currentPage;
  data["max"] = this.pageSize;

  /* Tri ??? (Attention : sortColId == 0 ne veut pas dire pas de tri !) */
  if (this.sortColId || 0 == this.sortColId) {
    data["sortColId"] = this.sortColId;
    data["sortIncrease"] = this.sortIncrease;
  }
  
  /* Charset */
  var charset = ecwGetCharset();
  if (charset) {
    data["charset"] = charset;
  }
  
  /* S'il existe des parametres supplementaires */
  if (this.ajaxParameters) {
    /* Ajout des parametres supplementaires */
    for (i = 0; i < this.ajaxParameters.length; i++) {
      var node = document.getElementById(this.ajaxParameters[i]);
      if (node && node.name && node.value) {
        if (data[node.name]) {
          if (data[node.name] instanceof Array) {
            data[node.name].push(node.value);
          } else {
            var array = new Array();
            array.push(data[node.name]);
            array.push(node.value);
            data[node.name] = array;
          }
        } else {
          data[node.name] = node.value;
        }
      } else if (node == null) {
        alert("Erreur ECW\nL'identifiant id=[" + this.ajaxParameters[i] + "] reference dans ecwIdParameters\n de la table [" 
          + this.noeudDOM.id +"] n'existe pas");
        return;
      }
    }
  }

  /* Affichage de l'url */
  if (this.modeDebug) {
    var msgSend = "Envoi Ajax : " + url + "?" + data;
    this.ecwUI.setMessage("W", msgSend);
  }

  /* Interrogation du serveur par une requete Ajax --> Retour par XML */
  var xmlDoc = new ECW.Ajax().ajaxXML(url, data, this.modeDebug);

  if (this.modeDebug) {
    alert("length(xmldoc) = " + xmlDoc.childNodes.length);
    if (xmlDoc.documentElement.textContent && xmlDoc.documentElement.textContent.trim() != "") {
      alert("textContent = " + xmlDoc.documentElement.textContent);
    }
  }

  /* Verification de la valide de la reponse */
  if (xmlDoc && xmlDoc.documentElement && xmlDoc.documentElement.childNodes) {

    var headerNode = null;
    var bodyNode = null;

    for (i = 0; i < xmlDoc.documentElement.childNodes.length; i++) {

      var currentNode = xmlDoc.documentElement.childNodes[i];

      /* Bug sous Mozilla - parfois les Element Xml de nodeType de 1 */
      /* Sont intercalees entre des node de type text (nodeType 3) */
      if (currentNode.nodeType == 1) {

        /* <header> */
        if (currentNode.nodeName == "header") {
          headerNode = currentNode;
        }
        /* <body> */
        else if (currentNode.nodeName == "body") {
          bodyNode = currentNode;
        }
      }
    }

    if (bodyNode == null) {
      alert("Erreur bodyNode = " + xmlDoc.documentElement.textContent);
    }
    this.currentPageSize = bodyNode.getAttribute("pageSize");
    this.numberOfPage = bodyNode.getAttribute("numberOfPage");
    this.numberOfElement = bodyNode.getAttribute("numberOfElement");

    if (this.numberOfPage == 0) {
      this.currentPage = 0;
    }

    /* Creation de la table contenant les elements */
    var table = document.createElement("TABLE");

    /* Entete de colonne */
    if (headerNode && headerNode.childNodes) {

      /* <thead> */
      var thead = document.createElement("THEAD");
      /* <tr> */
      var trThead = document.createElement("TR");
      var enteteDefined = false;

      /* Parcours des noeuds <col> */
      for (i = 0; i < headerNode.childNodes.length; i++) {

        var colHeaderNode = headerNode.childNodes[i];

        /* Bug sous Mozilla - parfois les Element Xml de nodeType de 1 */
        /* Sont intercalees entre des node de type text (nodeType 3) */
        if ((colHeaderNode.nodeType == 1) && (colHeaderNode.nodeName == "groupcell")) {
          /* Ajout d'un group cell */
          var trGroupCell = document.createElement("TR");
          var cellList = colHeaderNode.childNodes;
          for (j = 0; j < cellList.length; ++j) {
            /* Parcours des cellules du groupcell */
            var cell = cellList[j];
            if ((cell.nodeType == 1) && (cell.nodeName == "cell")) {
              var th = document.createElement("TH");
              var nb = cell.getAttribute("nb");
              if (nb) {
                th.colSpan= nb;
              }
              var titleCell = cell.getAttribute("title");
              if (!titleCell) {
                titleCell = "&nbsp;";
              }
              th.innerHTML = titleCell;
              trGroupCell.appendChild(th);
            }
          }
          thead.appendChild(trGroupCell);

        } else if ((colHeaderNode.nodeType == 1) && (colHeaderNode.nodeName == "col")) {

          /* Nom de la cle */
          var keyHeaderCol = colHeaderNode.getAttribute("key");
          var keyorderHeaderCol = colHeaderNode.getAttribute("keyOrder");
          var hiddenHeaderCol = colHeaderNode.getAttribute("hidden");
          var sortableHeaderCol = colHeaderNode.getAttribute("sortable");

          /* Valeur de cle specifiee */
          if (keyHeaderCol && keyorderHeaderCol) {
            table.setAttribute("ecwKeyName" + keyorderHeaderCol, keyHeaderCol);
          }
          /* Si la colonne n'est pas cachee */
          if (!hiddenHeaderCol || (hiddenHeaderCol != "true")) {
            /* Cellule */
            var th = document.createElement("TH");
            var titleColHeader = colHeaderNode.getAttribute("title");
            if (!titleColHeader) {
              titleColHeader = "&nbsp;";
            } else if (titleColHeader != "&nbsp;") {
              enteteDefined = true;
            }

            th.innerHTML = titleColHeader;

            /* Colonne triable */
            if (sortableHeaderCol && (sortableHeaderCol == "true")) {
              addClass(th, "ecwTableSortable");
              removeClass(th, "ecwTableSortEncours");

              var sortIncreaseHeaderCol = colHeaderNode.getAttribute("sortIncrease");
              if (sortIncreaseHeaderCol) {
                /* Croissant */
                if (sortIncreaseHeaderCol && (sortIncreaseHeaderCol == "true")) {
                  addClass(th, "ecwTableSortIncrease");
                  removeClass(th, "ecwTableSortDecrease");
                }
                /* Decroissant */
                else {
                  removeClass(th, "ecwTableSortIncrease");
                  addClass(th, "ecwTableSortDecrease");
                }
              }
            }

            trThead.appendChild(th);
          }
        }
      }
      thead.appendChild(trThead);
      if (enteteDefined) {
        table.appendChild(thead);
      }
    }

    /* <tbody> */
    var tbody = document.createElement("TBODY");
    table.appendChild(tbody);

    /* Parcours des elements */
    var lineNumber = 0;
    for (i = 0; i < bodyNode.childNodes.length && lineNumber < this.pageSize; i++) {
      /* Bug sous Mozilla - parfois les Element Xml de nodeType de 1 */
      /* Sont intercalees entre des node de type text (nodeType 3) */
      if (bodyNode.childNodes[i].nodeType == 1) {

        var lineNode = bodyNode.childNodes[i];

        /* Creation de la ligne */
        var trTbody = document.createElement("TR");
        tbody.appendChild(trTbody);
        
        /* Parsing XML du noeud <line> */
        if (lineNode.childNodes.length != 0) {

          for (j = 0; j < lineNode.childNodes.length; j++) {
          
            var colNode = lineNode.childNodes[j];
          
            /* Bug sous Mozilla - parfois les Element Xml de nodeType de 1 */
            /* Sont intercalees entre des node de type text (nodeType 3) */
            if (colNode.nodeType == 1) {

              /* Pas d'enfants pour <col>, colonne classique */
              if (colNode.childNodes.length == 0) {

                var cssclassCol = colNode.getAttribute("cssclass");
                var keyvalueCol = colNode.getAttribute("keyValue");
                var keyorderCol = colNode.getAttribute("keyOrder");
                var hiddenCol = colNode.getAttribute("hidden");
                var displayCol = colNode.getAttribute("display");
                var styleCol = colNode.getAttribute("style");

                /* Valeur de cle specifiee */
                if (keyorderCol) {
                  trTbody.setAttribute("ecwKeyVal" + keyorderCol, keyvalueCol);
                }
                /* Si la colonne n'est pas cachee */
                if (!hiddenCol || (hiddenCol != "true")) {
              
                  var tdTbody = document.createElement("TD");
                  trTbody.appendChild(tdTbody);

                  /* Style cssclass specifie */
                  if (cssclassCol || styleCol) {
                    var divTdTbody = document.createElement("DIV");
                    
                    if (cssclassCol) {
                      divTdTbody.className = cssclassCol;
                    }
                    if (styleCol) {
                      if (ECW_isIE) {
                        divTdTbody.style.setAttribute("cssText", styleCol);
                      } else {
                        divTdTbody.setAttribute("style", styleCol);
                      }
                    }
                    tdTbody.appendChild(divTdTbody);
                    /* Balise <pre> */
                    if (displayCol == 1) {
                      //ancien code : ne fonctionne pas avec IE
                      //var preDiv = document.createElement("PRE");
                      //preDiv.innerHTML = this.traductionTexte(colNode.getAttribute("value"));
                      //divTdTbody.appendChild(preDiv);
					  var str = "<PRE>" + this.traductionTexte(colNode.getAttribute("value")) + "</PRE>"; 
					  divTdTbody.innerHTML = str;
                    } else {
                      divTdTbody.innerHTML = this.traductionTexte(colNode.getAttribute("value"));
                    }
                  }
                  /* Pas de style specifie */
                  else {
                    /* Balise <pre> */
                    if (displayCol == 1) {
                      //var preTd = document.createElement("PRE");
                      //preTd.innerHTML = colNode.getAttribute("value");
                      //tdTbody.appendChild(preTd);                      
                      var str = "<PRE>" + this.traductionTexte(colNode.getAttribute("value")) + "</PRE>"; 
                      tdTbody.innerHTML = str;
                    } else {    
                      tdTbody.innerHTML = this.traductionTexte(colNode.getAttribute("value"));
                    }
                  }
                }
              }
              /* Enfant pour <col>, balise <action> */
              else {

                var tdTbody = document.createElement("TD");
                trTbody.appendChild(tdTbody);
                var actionTable = document.createElement("TABLE");
                tdTbody.appendChild(actionTable);
                addClass(actionTable, "ecwTableListeAction");
                actionTable.setAttribute("border", "0");
                actionTable.cellSpacing = "0";
                actionTable.cellPadding = "0";

                var actionTbody = document.createElement("TBODY");
                var trActionTbody = document.createElement("TR");

                for (k = 0; k < colNode.childNodes.length; k++) {

                  var actionNode = colNode.childNodes[k];

                  /* Bug sous Mozilla - parfois les Element Xml de nodeType de 1 */
                  /* Sont intercalees entre des node de type text (nodeType 3) */
                  if (actionNode.nodeType == 1) {

                    var titleAction = actionNode.getAttribute("title");
                    var urlAction = actionNode.getAttribute("url");
                    var cssclassAction = actionNode.getAttribute("cssclass");

                    var tdActionTbody = document.createElement("TD");
                    var spanAction = document.createElement("SPAN");
                    if (titleAction) {
                      spanAction.title = titleAction;
                    }
                    if (urlAction) {
                      spanAction.url = urlAction;
                      spanAction.setAttribute("onclick", "window.ecwTableCallClickAction(this);");
                      spanAction.onclick = ecwTableSpanOnClick;
                      spanAction.setAttribute("ecwonclick", urlAction);
                    }
                    if (cssclassAction) {
                      addClass(spanAction, cssclassAction);
                    }

                    tdActionTbody.appendChild(spanAction);
                    trActionTbody.appendChild(tdActionTbody);
                  }
                }

                actionTbody.appendChild(trActionTbody);
                actionTable.appendChild(actionTbody);
              }
            }
          }
        }
        
        /* Ligne suivante */
        lineNumber += 1;
      }
    }
  }
  if (this.modeDebug) {
    alert("table :\n" + table.innerHTML);
  }

  /* Rafraichissement du contenu de la table ECW */
  var divBody = document.createElement("DIV");
  divBody.appendChild(table);
  // alert("divBody :\n" + divBody.innerHTML);


  return(divBody);
}

function ecwTableSpanOnClick() {
  window.ecwTableCallClickAction(this);
}

/**
 * Methode de traduction des caracteres < > & " d'un texte 
 * @private
 */
ECW.Table.prototype.traductionTexte = function(texte){
    var texteResult = texte;
    if(texte.match("&") && !texte.match("&nbsp;")){
        texteResult = texte.replace("&","&amp;");
    }
    if(texte.match("<")){
        texteResult = texte.replace("<","&lt;");
    }
    if(texte.match(">")){
        texteResult = texte.replace(">","&gt;");
    }
    
    if(texte.match("\"")){
        texteResult = texte.replace("\"","&quot;");
    }
    return texteResult; 
    
}

/**
 * Rafra&icirc;chissement de la Table Ajax.
 * @param page Numero de la page souhaitee.
 */
ECW.Table.prototype.refreshAjax = function(page) {

  if (this.ajaxAction) {

    /* Page courante */
    this.currentPage = 1;

    /* C'est un nombre */
    if (page && ecwIsValidNumber(page)
        && (parseInt(page, 10) <= parseInt(this.numberOfPage, 10))
        && (parseInt(page, 10) > 0)) {
      this.currentPage = page;
    }
    /* Mise a jour de la Table en Ajax */
    this.refreshInternalAjax();
  }
}

/**
 * La Table est mise a jour grace a une requete Ajax.
 * @private
 */
ECW.Table.prototype.refreshInternalAjax = function() {

  /* Appel Ajax pour le contenu de la table */
  var divBody = this.callAjax();

  /* N'affiche le bandeau de pagination que s'il y a plus d'une page */  
  //if (this.numberOfPage>1) {  //BUG FIX prise en compte du parametre hiddenpage  
  if (!this.hiddenPage || this.numberOfPage>1) {

	/* Pagination */
    var table = document.createElement("TABLE");
    table.setAttribute("border", "0");
    table.setAttribute("align", "center");
    
    /* Raffraichissement de la pagination */
    if (this.tdPagination == null) {
      var tbodyPagination = getFirstChildByTagName(this.tableFormat, "TBODY");
      var trPagination = document.createElement("TR");
      addClass(trPagination, "ecwTablePagination");
      tbodyPagination.appendChild(trPagination);
      ecwSetAttribute(this, "tdPagination", document.createElement("TD"));
      trPagination.appendChild(this.tdPagination);
    }
    else {
      for (var i = this.tdPagination.childNodes.length - 1; i >= 0; i--) {
        this.tdPagination.removeChild(this.tdPagination.childNodes[i]);
      }
    }
  
    /* Ajout de la pagination */
    this.tdPagination.appendChild(table);
  
    var tbody  = document.createElement("TBODY");
    table.appendChild(tbody);
    var tr = document.createElement("TR");
    tbody.appendChild(tr);
  
    /* Page */
    var args = new Array;
    var indiceMin = ((this.currentPage - 1) * this.pageSize) + 1;
    var indiceMax = parseInt(indiceMin, 10) + parseInt(this.currentPageSize, 10) - 1;
    
    var infoEltTd;
    if (0 == this.numberOfElement) {
      infoEltTd = this.createDivInTd(tr, ecw.I18N.get("noElement", args));
    } else {
      args[0] = indiceMin;
      args[1] = indiceMax;
      args[2] = this.numberOfElement;
      infoEltTd = this.createDivInTd(tr, ecw.I18N.get("infoElement", args));
    }
  
    /* Premiere page */
    var td = document.createElement("TD");
    var imageTableFirstPage = document.createElement("SPAN");
    addClass(imageTableFirstPage, "ecwTableFirstPage");
    imageTableFirstPage.title = ecw.I18N.get("firstPage");
    ecwSetAttribute(imageTableFirstPage, "ecwTable", this);
    imageTableFirstPage.onclick = ecwTableAjaxImgFirst;
    td.appendChild(imageTableFirstPage);
    tr.appendChild(td);
  
    /* Page precedente */
    td = document.createElement("TD");
    var imageTablePreviousPage = document.createElement("SPAN");
    addClass(imageTablePreviousPage, "ecwTablePreviousPage");
    imageTablePreviousPage.title = ecw.I18N.get("previousPage");
    ecwSetAttribute(imageTablePreviousPage, "ecwTable", this);
    imageTablePreviousPage.onclick = ecwTableAjaxImgPrevious;
    td.appendChild(imageTablePreviousPage);
    tr.appendChild(td);
    
    /* Numero de pages*/
    /* Premiere */
    var separator = "...";
    var firstPageTd;
    var firstSepTd;
    if (((this.currentPage != 0)) && (this.currentPage != 1)) {
      firstPageTd = this.createDivInTd(tr, "1");
      firstSepTd = this.createDivInTd(tr, separator);
    } else {
      firstPageTd = this.createDivInTd(tr, "&nbsp;");
      firstSepTd = this.createDivInTd(tr, "&nbsp;");
    }
    /* Courante */
    var currentPageTd;
      if (0 == this.numberOfElement) {
          currentPageTd = this.createDivInTd(tr, "<b>0</b>");
      } else {
          currentPageTd = this.createDivInTd(tr, "<b>" + this.currentPage + "</b>");
      }
  
    /* Derniere */
    var secondSepTd;
    var lastPageTd;
    if (this.currentPage != this.numberOfPage) {
      secondSepTd = this.createDivInTd(tr, separator);
      lastPageTd = this.createDivInTd(tr, this.numberOfPage);
    } else {
      secondSepTd = this.createDivInTd(tr, "&nbsp;");
      lastPageTd = this.createDivInTd(tr, "&nbsp;");
    }
  
    /* Page suivante */
    td = document.createElement("TD");
    var imageTableNextPage = document.createElement("SPAN");
    addClass(imageTableNextPage, "ecwTableNextPage");
    imageTableNextPage.title = ecw.I18N.get("nextPage");
    ecwSetAttribute(imageTableNextPage, "ecwTable", this);
    imageTableNextPage.onclick = ecwTableAjaxImgNext;
    td.appendChild(imageTableNextPage);
    tr.appendChild(td);
  
    /* Derniere page */
    td = document.createElement("TD");
    var imageTableLastPage = document.createElement("SPAN");
    addClass(imageTableLastPage, "ecwTableLastPage");
    imageTableLastPage.title = ecw.I18N.get("lastPage");
    ecwSetAttribute(imageTableLastPage, "ecwTable", this);
    imageTableLastPage.onclick = ecwTableAjaxImgLast;
    td.appendChild(imageTableLastPage);
    tr.appendChild(td);
  
    /* Acces a une page */
    this.createDivInTd(tr, ecw.I18N.get("goToPage", args));
  
    td = document.createElement("TD");
    if (this.inputGoToPage == null) {
      this.inputGoToPage = document.createElement("INPUT");
      this.inputGoToPage.id = "inputGoToPage_" + this.noeudDOM.id;
      this.inputGoToPage.size = 4;
      /* Nom different ecwTablePaginate */
      ecwSetAttribute(this.inputGoToPage, "ecwTableToPaginate", this);
      this.inputGoToPage.ecwTableToPaginate = this;
      this.inputGoToPage.onKey = ecwTableAjaxInputGotoOnKey;
    }
    td.appendChild(this.inputGoToPage);
    tr.appendChild(td);
  
    td = document.createElement("TD");
    var imageTableGoToPage = document.createElement("SPAN");
    addClass(imageTableGoToPage, "ecwTableGoToPage");
    imageTableGoToPage.ecwTable = this;
    imageTableGoToPage.onclick = ecwTableAjaxInputGotoOnClick;
    td.appendChild(imageTableGoToPage);
    tr.appendChild(td);

  } else if (this.tdPagination != null) {
      for (var i = this.tdPagination.childNodes.length - 1; i >= 0; i--) {
        this.tdPagination.removeChild(this.tdPagination.childNodes[i]);
      }
  }
  
  /* Rafraichissement de la table */
  this.refreshDIV(divBody);

  /* N'affiche le bandeau de pagination que s'il y a plus d'une page */
  //if (this.numberOfPage>1) {//BUG FIX prise en compte du parametre hiddenpage  
  if (!this.hiddenPage || this.numberOfPage>1) {
	  
    /* Calcul des tailles de cellules : pour avoir un bandeau de pagination de taille unique */
    var tdNumberWidth = document.createElement("TD");
    tdNumberWidth.innerHTML = this.numberOfPage;
    tr.appendChild(tdNumberWidth);
  
    var tdFirstWidth = document.createElement("TD");
    tdFirstWidth.innerHTML = "1";
    tr.appendChild(tdFirstWidth);
  
    var tdSepWidth = document.createElement("TD");
    tdSepWidth.innerHTML = separator;
    tr.appendChild(tdSepWidth);
  
    var tdInfoEltWidth = document.createElement("TD");
    args[0] = this.numberOfElement;
    args[1] = this.numberOfElement;
    args[2] = this.numberOfElement;
    tdInfoEltWidth.innerHTML = ecw.I18N.get("infoElement", args);
    tr.appendChild(tdInfoEltWidth);
  
    /* Initialisation des tailles de cellules */
    infoEltTd.style.width = tdInfoEltWidth.offsetWidth;
    currentPageTd.style.width = tdNumberWidth.offsetWidth;
    firstSepTd.style.width = tdSepWidth.offsetWidth;
    secondSepTd.style.width = tdSepWidth.offsetWidth;
    firstPageTd.style.width = tdFirstWidth.offsetWidth;
    lastPageTd.style.width = tdNumberWidth.offsetWidth;
  
    /* Suppression des cellules de reference */
    tr.removeChild(tdNumberWidth);
    tr.removeChild(tdSepWidth);
    tr.removeChild(tdInfoEltWidth);
    tr.removeChild(tdFirstWidth);
  }
  
  /* Evenement onRefresh */
  if (this.onRefresh) {
    this.onRefresh();
  }
}

