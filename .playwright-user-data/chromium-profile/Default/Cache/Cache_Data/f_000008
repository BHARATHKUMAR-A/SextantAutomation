/**
 * D&eacute;fini l'objet <b>ECW.Table</b>
 * @private
 */
ECW.Table = function(noeud, ui, layout) {

  ecwStartTimer("ECW.Table");
  
  ecwSetAttribute(this, "noeudDOM", noeud);
  ecwSetAttribute(this, "ecwUI", ui);
  ecwSetAttribute(this, "ecwLayout", layout);
  ecwSetAttribute(this, "input", null);
  this.nbligne = 8;
  this.nbligneInitial = 8;
  ecwSetAttribute(this, "ligneActive", null);
  ecwSetAttribute(this, "tabLigneMulti", new Array());
  ecwSetAttribute(this, "lignes", null);
  ecwSetAttribute(this, "divTHead", null);
  ecwSetAttribute(this, "divTBody", null);
  ecwSetAttribute(this, "divTStatus", null);
  ecwSetAttribute(this, "ligneMultiSelect", false);
  ecwSetAttribute(this, "tabNameKey", new Array());
  ecwSetAttribute(this, "comparators", new Array());
  ecwSetAttribute(this, "ecwTable", this);
  this.texteFiltre = "";
  this.searchColumn = 0;
  ecwSetAttribute(this, "lastSelectedLine", null);
  this.numerotation = false;
  this.showSelection = true;
  this.alternateColor = false;
  ecwSetAttribute(this, "tableFormat", null);
  this.canReorder = false;
  this.hiddenPage = false;
  this.selectionDoubleTable = false;
  ecwSetAttribute(this, "divActionsDoubleSelect", null);
  ecwSetAttribute(this, "divTableTargetSelect", null);
  ecwSetAttribute(this, "ecwTableTargetSelect", null);
  ecwSetAttribute(this, "ecwTableSrcSelect", null);

  this.sortColId = null;
  this.sortIncrease = false;
  
    /* Ensemble des messages d'erreur affiche par ce composant. */
    ecwSetAttribute(this, "messages", new Array());

  /* Mode debug */
  this.modeDebug = false;

  /* Constructeur */
  
  if (this.noeudDOM.getAttribute("ecwHiddenPage")
  		&& this.noeudDOM.getAttribute("ecwHiddenPage") == "true") {
  	this.hiddenPage = true;  	
  }
  
   /* Recuperation du mode de selection des lignes (single ou multiple) */
  var attrEcwNbLines = this.noeudDOM.attributes.ecwNbLines;
  if (attrEcwNbLines) {
    this.nbligne = attrEcwNbLines.nodeValue;
    this.nbligneInitial = attrEcwNbLines.nodeValue;
  }
  
  var attrEcwIdFilter = this.noeudDOM.attributes.ecwIdFilter;
  if (attrEcwIdFilter) {
    this.ecwIdFilter = attrEcwIdFilter.nodeValue;
  }
  
  /* Recuperation du mode de selection des lignes (single ou multiple) */
  var attrEcwSelection = this.noeudDOM.attributes.ecwSelection;
  if (attrEcwSelection && attrEcwSelection.nodeValue == "multiple") {
    this.ligneMultiSelect = true;
  }
  else if (attrEcwSelection && attrEcwSelection.nodeValue == "doubleTable") {
    this.selectionDoubleTable = true;
    this.ligneMultiSelect = true;
  }

  /* Dans le cas d'une comboBox, rendre invisible la DIV de la liste */
  if (this.noeudDOM.parentNode.className.indexOf("ecwComboBox") >= 0) {
    addClass(this.noeudDOM, "ecwInvisible");
  }
  /* Table classique */
  else {

    /* Table Ajax */
    if (this.noeudDOM.getAttribute("ecwAction") != null) {

      /* Page courante */
      this.currentPage = 1;
      var initPage = this.noeudDOM.getAttribute("ecwInitPage");
      if (initPage) {
        this.currentPage = initPage;
      }

      this.ajaxAction = this.noeudDOM.getAttribute("ecwAction");
      if (this.noeudDOM.getAttribute("ecwPageSize") != null) {
        this.pageSize = this.noeudDOM.getAttribute("ecwPageSize");
      }
      if (this.noeudDOM.getAttribute("ecwIdParameters") != null) {
        this.ajaxParameters = this.noeudDOM.getAttribute("ecwIdParameters").split(",");
      }

      var colId = this.noeudDOM.getAttribute("ecwDefaultSort");
      if (colId && ecwIsValidNumber(colId)) {
        this.sortColId = colId;
        this.sortIncrease = true;
        var defaultSort = this.noeudDOM.getAttribute("ecwDefaultTypeSort");
        if (defaultSort && defaultSort == "Decrease") {
          this.sortIncrease = false;
        }          
      }

      /* Tableau pour rendu visuel */
      this.createTableFormat();

      /* Mise a jour de la Table en Ajax */
      this.refreshInternalAjax();
    }
    /* Table sans Ajax */
    else {
      /* Appel du constructeur de l'objet Table */
      this.constructeur();
    }
  }

  /* Ajout du champ invisible de selection de la liste */
  var inputTable = document.createElement("INPUT");
  this.noeudDOM.insertBefore(inputTable, this.noeudDOM.firstChild);
  inputTable.className = "ecwInvisible";
  inputTable.setAttribute("autocomplete", "off");
  inputTable.id = "inputEcwTable_" + this.noeudDOM.id;
  if (this.noeudDOM.getAttribute("accesskey")) {
    inputTable.accessKey = this.noeudDOM.accessKey  // pour IE
    inputTable.setAttribute("accesskey", this.noeudDOM.getAttribute("accesskey")); // pour Mozilla
    this.noeudDOM.accessKey = ""; // Effacer le lien (pour IE)
  }
  ecwSetAttribute(inputTable, "ecwTable", this);
  ecwSetAttribute(this, "input", inputTable);
  ecwSetAttribute(this.noeudDOM, "input", inputTable);
  /* Copie le title sur l'input de la liste */
  inputTable.title = this.noeudDOM.title; 
  /* Supprime le title du div */
  this.noeudDOM.title = "";
  ecwSetAttribute(this.noeudDOM, "ecwTable", this);
  
  /* Evenement onkeyup (utilisation du clavier) */
  ecwSetAttribute(inputTable, "onkeyup", ecwTableOnKeyUp);

  ecwStopTimer("ECW.Table");
}

function ecwTableOnKeyUp(event) {
  var touches = " abcdefghijklmnopqrstuvwxyz0123456789_-@#éèùàç$.:";
  if (touches.indexOf(this.value.toLowerCase()) >= 0 && this.value != "") {
    this.ecwTable.findChar(this.value);
  }
  this.value = "";
}

