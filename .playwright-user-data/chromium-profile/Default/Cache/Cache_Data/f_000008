/**
 * Creation de la DIV class="ecwTableHead"
 * utilisee pour afficher les entetes de colonnes
 * @private
 */
ECW.Table.prototype.createTableHead = function() {

  /* Recherche de la balise <TABLE> et de la balise <THEAD> */
  var currentTable = getFirstChildByTagName(this.noeudDOM, "TABLE");
  if (!(currentTable && currentTable.tHead)){
      return;
  }

  var wdivTHead = document.createElement("DIV");
  wdivTHead.className = "ecwTableHead";
 
  /* Ajout de la DIV class="ecwTableHead" */
  // On l'ajoute plutot a la fin de la methode pour eviter les maj intempestives
  // -> possibilite de fuite memoire : on l'ajoute tout de suite !
  this.noeudDOM.appendChild(wdivTHead);

  ecwSetAttribute(this, "divTHead", wdivTHead);
 
  /* Creation d'un clone de <TABLE> : Modif V2.0*/
  var cloneTable = currentTable.cloneNode(true);
  cloneTable.cellSpacing = "0";
  cloneTable.cellPadding = "0";
  wdivTHead.appendChild(cloneTable);
 
  if (!this.showSelection){
    /* Ajout de la DIV class="ecwTableHead" */
    //this.noeudDOM.appendChild(wdivTHead);
    return;
  }

  /* Activer les zones sensibles de l'entete pour le tri des colonnes si la table doit etre triee */
  /* Recherche des colonnes triables sur toutes les lignes d'entete */
  var listeLigneEntete = this.divTHead.getElementsByTagName("TR");
  var nbLignesEntete = listeLigneEntete.length;
  for (var i = 0; i < nbLignesEntete; ++i) {

    var colonnes = listeLigneEntete[i];
    var nbColCells = colonnes.cells.length;
    for (var j = 0; j < nbColCells; ++j) {
      var cell = colonnes.cells[j];
      /* Tri seulement pour les colonnes ayant l'attribut ecwTableSortable */
      if (isClass(cell, "ecwTableSortable")) {
        cell.ecwTable = this;
        cell.ecwTable.triActif = 0;
    
        /* Evenement onmouseover */
        cell.onmouseover = function() {
          if (window.addClass) {
            window.addClass(this, "ecwTableEnteteOver");
          }
        }
        /* Evenement onmouseout */
        cell.onmouseout = function() {
          if (window.removeClass) {
            window.removeClass(this, "ecwTableEnteteOver");
          }
        }
        /* Evenement onclick */
        cell.onclick = function() {
 
          /* Test si le tableau n'est pas vide */
          if (this.ecwTable.lignes && this.ecwTable.lignes.length != 0) {
    
            /* Faire patienter l'utilisateur pendant le tri */
            if (window.addClass) {
                window.addClass(this, "ecwTableSortEncours");
            }
            if (this.ecwTable.lignes.length > 100) {
              ecwActiveUI.setMessage("W", ecw.I18N.get("sortInProgress"));
            }
            celluleATrier = this;

            /* Tri javascript */
            if (!this.ecwTable.ajaxAction) {
              var cmdTri = "celluleATrier.ecwTable.sortByColumn(celluleATrier);";
              cmdTri += " removeClass(celluleATrier, 'ecwTableSortEncours');";
              cmdTri += " ecwActiveUI.clearMessage();";
              var timer = setTimeout(cmdTri, 0);
            }
            /* Tri serveur avec appel Ajax */
            else {
              /* Indice de la colonne de tri */
              var sortId = this.cellIndex;
              if (this.ecwTable.numerotation) {
                sortId = sortId - 1;
              }

              /* Ordre de la colonne de tri */
              if(this.ecwTable.sortColId != sortId){
                /* Si changement de colonne, tri increase (compatibilite avec table non ajax) */
                this.ecwTable.sortIncrease = true;
              }else{
                /* Sinon tri inverse */
                this.ecwTable.sortIncrease = !this.ecwTable.sortIncrease;
              }

              this.ecwTable.sortColId = sortId;

              if (this.ecwTable.ecwComboBox) {
                  /* Mise a jour de la combo en ajax */
                  this.ecwTable.currentPage = 1;
                  this.ecwTable.ecwComboBox.refreshInternalAjax();
                  this.ecwTable.ecwComboBox.showAfterAjax();          
              } else {
                   /* Mise a jour de la Table en Ajax */
                  this.ecwTable.refreshInternalAjax();        
              }
            }
          }
        }
      }
    }
  }
  /* Ajout de la DIV class="ecwTableHead" */
  //this.noeudDOM.appendChild(wdivTHead);
}

/**
 * Creation de la DIV class="ecwTableBody"
 * utilisee pour afficher les donnees
 * @private
 */
ECW.Table.prototype.createTableBody = function() {

  var wdivTBody = document.createElement("DIV");
  wdivTBody.className = "ecwTableBody";
  wdivTBody.ecwTable = this;

  /* Positionnement du Tabindex, */
  /* car sous Firefox 1.5, une div de style overflow:auto devient focusable */
  if (ECW_isGecko) {
    wdivTBody.tabIndex = -1;
  }

  /* Ajout de la DIV class="ecwTableBody" */
  this.noeudDOM.appendChild(wdivTBody);
  ecwSetAttribute(this.noeudDOM, "ecwTable", this);

  /* Si la balise <TABLE> existe */
  var baliseTable = getFirstChildByTagName(this.noeudDOM, "TABLE");
  if (baliseTable) {
    baliseTable.cellSpacing = "0";
    baliseTable.cellPadding = "0";

    /* appendChild() : effectue un deplacement du noeud <TABLE> */
    /* sous la <DIV class="ecwTableBody"> */
    wdivTBody.appendChild(baliseTable);

    ecwSetAttribute(this, "divTBody", wdivTBody);
  }
}

/**
 * Creation de la DIV class="ecwTableStatus"
 * utilisee pour afficher une barre d'etat
 * @private
 */
ECW.Table.prototype.createTableStatus = function() {

  var wdivTStatus = document.createElement("DIV");
  wdivTStatus.className = "ecwTableStatus";
  wdivTStatus.innerHTML = "BEN - Status";

  /* Ajout de la DIV class="ecwTableStatus" */
  this.noeudDOM.appendChild(wdivTStatus);
  
  ecwSetAttribute(this, "divTStatus", wdivTStatus);
}

/**
 * Creation des balises <select> cachee
 * @private
 */
ECW.Table.prototype.createHiddenSelect = function() {

  /* Recuperation des cles de la liste pour le generation des SELECT */
  var tabAttKey = getFirstChildByTagName(this.noeudDOM, "TABLE");
  if (tabAttKey) {
  
    var i = 0;
    var keyNameCurrent = tabAttKey.getAttribute("ecwKeyName" + i);
    /* Parcours des cles */
    while (keyNameCurrent) {
      this.tabNameKey[i] = keyNameCurrent;
      /* Balise <SELECT> */
      var wSelect = document.createElement("SELECT");
      /*    .....    ou canReorder pour placer toute keyVal dans le select */
      if (this.ligneMultiSelect || this.canReorder) {
        wSelect.multiple = true;
        var tmpSuffix = (ecwTabNameSuffix)?"[]":""; 
        wSelect.name = this.tabNameKey[i] + tmpSuffix; //+ "[]";  //[] pour PHP        
      } else {
        wSelect.name = this.tabNameKey[i];
      }
      wSelect.size = "3";
      wSelect.id = "listeSelect" + this.tabNameKey[i];
      this.noeudDOM.appendChild(wSelect);
      /* Donne provisoirement le focus pour que IE prenne en compte le SELECT [SIFAECW-528] */
      /* Uniquement pour le mode reorder : [SIFAECW-542] */
      if (!this.ecwComboBox && this.canReorder) {
        wSelect.focus();
      }

      /* Le style display:'none' sous IE dans un SELECT multiple empeche la generation dynamique des OPTION */
      wSelect.style.visibility = "hidden";
      wSelect.style.position = "absolute";
      //wSelect.style.width = "200px";
      //wSelect.style.height = "200px";

      /* Suivant */
      ++i;
      keyNameCurrent = tabAttKey.getAttribute("ecwKeyName" + i);
    }
  }
}

/**
 * Detection d'un table vide.
 * @private
 */
ECW.Table.prototype.detectEmptyTable = function() {

  /* Detection d'une table vide */
  if (this.lignes && this.lignes.length == 1) {
    if (isClass(this.lignes[0], "ecwTableLineEmpty")) {
      this.lignes = null;
    }
  }
}

/**
 * Cree le comportement des lignes sur les actions
 * @private
 */
ECW.Table.prototype.creerComportementLignes = function() {

  if (this.noeudDOM.getElementsByTagName("TBODY").length > 0) {

    this.lignes = getFirstChildByTagName(this.divTBody, "TBODY").rows;

    /* Detection d'une table vide */
    this.detectEmptyTable();

    if (this.lignes) {

      var indiceColonne = 0;
      if (this.numerotation) {
        indiceColonne = 1;
      }
      if (this.ecwComboBox && this.ecwComboBox.noeudDOM.getAttribute("ecwColumnIndex")) {
        var rang = parseInt(this.ecwComboBox.noeudDOM.getAttribute("ecwColumnIndex"));
        indiceColonne += rang;
        this.searchColumn = indiceColonne;
      }

      var ligne;
      var nbLignes = this.lignes.length;
      for (var j = 0; j < nbLignes; ++j) {
        ligne = this.lignes[j];
        /* Suppression des styles pour la ligne */
        this.removeStyleLines(ligne);

        /* Coloration des lignes par alternance */
        if (this.alternateColor) {
          if (j % 2 == 0) {
            /* j est pair */
            addClass(ligne, "ecwTableAlternateLine1");
          } else {
            /* j est impair */
            addClass(ligne, "ecwTableAlternateLine2");
          }
        }
        ecwSetAttribute(ligne, "ecwTable", this);
        ligne.ecwTable.triActif = 0;
        /* Precalcul du rowIndex pour gagner du temps sous Mozilla */
        ligne.rIndex = j + 1;

        ligne.chaineCar = ecwGetInnerText(ligne.getElementsByTagName("TD")[indiceColonne]);

        /* Evenement onclick sur une ligne */
        ligne.onclick = ecwTableLigneOnClick;

        /* Evenement onmouseover sur une ligne */
        ligne.onmouseover = ecwTableLigneOnMouseOver;

        /* Evenement onmouseout sur une ligne */
        ligne.onmouseout = ecwTableLigneOnMouseOut;
      }
    }
  }
}

function ecwTableLigneOnMouseOver(event) {
  if (this.ecwTable.showSelection) {
    addClass(this, "ecwTableLineOver");
  }
  var listeTD = this.getElementsByTagName("TD");
  for (var k = 0; k < listeTD.length; ++k) {
    var div = listeTD[k].getElementsByTagName("DIV");
    if (div && div.length > 0) {
      var obj = div[0];
      if (ecwGetComputedStyle(obj).overflow == "hidden") {
        /* Si balise <pre> */
        var balisePre = obj.getElementsByTagName("PRE");
        if (balisePre && balisePre.length > 0) {
          obj.title = balisePre[0].innerHTML.trim();
        } else {
          /* Si balise <span> */
          var baliseSpan = obj.getElementsByTagName("SPAN");
          if (baliseSpan && baliseSpan.length > 0) {
            obj.title = baliseSpan[0].innerHTML.trim();
          } else {
            obj.title = obj.innerHTML.trim();
          }
        }
      }
    }
  }
}

function ecwTableLigneOnMouseOut(event) {
  if (this.ecwTable.showSelection) {
    removeClass(this, "ecwTableLineOver");
  }
}

function ecwTableLigneOnClick(event) {
  removeClass(this, "ecwTableLineOver");
  if (!event) {
    event = window.event;
  }             
  if (this.ecwTable.ligneMultiSelect) {
    if (event.ctrlKey) {
      this.ecwTable.cocherLigne(this);
    } else if (event.shiftKey) {
      this.ecwTable.shiftCocherLigne(this);
    }
    /* Annulation de la selection des lignes */
    /* uniquement pour le mode classique (pas de selection avec double table) */
    else {
      this.ecwTable.unselectLines();
    }
  }

  this.ecwTable.selectionnerLigne(this, false, event);
  this.ecwTable.lastSelectedLine = this;
  if (this.ecwTable.ecwComboBox) {
    this.ecwTable.ecwComboBox.executerActionLigne(this);
  }
  
  if (this.ecwTable.noeudDOM.getAttribute("ecwAutoExecuteOnClick") == "true") {
    removeClass(this, "ecwTableLineOver");
    this.ecwTable.executerActionLigne(this);
  }

  /* Si une action de type Icone a ete declenchee */
  if (window.ecwTableAction) {
    eval(window.ecwTableAction);
  }
  window.ecwTableAction = null;
  
  /* Generation du select en mode mutli-select */
  /* car si onEnter, le desactiver n'est pas appele */
  if (!this.ecwTable.canReorder && (this.ecwTable.ecwTableSrcSelect == null) && (this.ecwTable.ecwTableTargetSelect == null)) {
    if (this.ecwTable.ligneMultiSelect && this.ecwTable.tabLigneMulti.length > 0) {
      this.ecwTable.genererSelect(this.ecwTable.tabLigneMulti);
    }
  }

}

/**
 * Calcul la hauteur et la largeur de la liste
 * @private
 */
ECW.Table.prototype.fixerDimensions = function() {
  /* Precise la hauteur du DIV principal en fonction du nb lignes maxi a afficher */
  if (this.noeudDOM.attributes.ecwNbLines) {
    this.nbligne = parseInt(this.noeudDOM.attributes.ecwNbLines.nodeValue, 10);
  }
  var hauteurEntete = 0;
  var hauteurTab = 0;
  
  /* Si l'entete existe */
  if (this.divTHead) {
    /* Recuperation de la valeur de offsetHeight */
    /* offsetHeight est uniquement valable si le noeud est visible */
    var offHeight = getFirstChildByTagName(this.noeudDOM, "THEAD").offsetHeight;
    this.divTHead.style.height = offHeight;
    hauteurEntete = offHeight;
  }
  
  this.ecwHeightHeadTable = hauteurEntete;
  /* Si la table contient au moins une ligne */
  if (this.lignes && this.lignes.length > 0) {
    /* Si c'est une combo, calcul de la hauteur au plus juste */  
    if (this.ecwTable.ecwComboBox) {
      var nbLineToShow = this.lignes.length;
      if (this.lignes.length > this.nbligne) {
        nbLineToShow = this.nbligne;
      }
      hauteurTab = (this.lignes[0].offsetHeight) * nbLineToShow;
    }
    /* C'est une table */
    else {
      hauteurTab = (this.lignes[0].offsetHeight) * this.nbligne;
    }
  }
  /* Aucune ligne dans le tableau */
  else {
    if (this.divTBody) {    
      /* Ajout d'une ligne pour le calcul de la hauteur d'une ligne */
      var tbodyVide = getFirstChildByTagName(this.divTBody, "TBODY");
      if (!tbodyVide) {
        tbodyVide = document.createElement("TBODY");
        getFirstChildByTagName(this.divTBody, "TABLE").appendChild(tbodyVide);
      }

      var trVide = document.createElement("TR");
      tbodyVide.appendChild(trVide);
      var tdVide = document.createElement("TD");
      trVide.appendChild(tdVide);
      tdVide.innerHTML = "LIGNE DE TEST";

      /* Calcul de la hauteur totale */
      var firstLine = getFirstChildByTagName(getFirstChildByTagName(this.divTBody, "TBODY"), "TR");
      hauteurTab = firstLine.offsetHeight * this.nbligne;

      /* Suppression de la ligne */
      tbodyVide.removeChild(trVide);
    }
    /* Combo Ajax */
    else {
      hauteurTab = 20;
    }
  }
  if (this.divTBody) {
  	if(!(ECW_isGecko_35 && this.ecwIdFilter)) {
    	this.divTBody.style.height = hauteurEntete + hauteurTab;
    }
  }
  this.ecwHeightTable = hauteurEntete + hauteurTab;

  /* Fixe la largeur de la liste */
  var wlargeur = 0;

  /* Pour eviter l'ascenseur horizontal en cas de manque de place */  
  if (ECW_isGecko && this.divTBody) {
    /* Position de la balise <table> */
    this.divTBody.firstChild.style.position = "absolute";
  }

  /* Si l'entete existe */
  if (this.divTHead) {
    this.divTHead.style.width = this.divTBody.firstChild.offsetWidth;

    /* Si la table contient au moins une ligne */
    if (this.lignes != null && this.lignes.length > 0) {
      if (this.lignes[0].parentNode.parentNode.offsetWidth > this.divTHead.offsetWidth) {
        wlargeur = this.lignes[0].parentNode.parentNode.offsetWidth;
      } else {
        wlargeur = this.divTHead.offsetWidth;
      }
    } else {
      wlargeur = this.divTHead.offsetWidth;
    }

  }
  /* Si l'entete n'existe pas */
  else {
    /* Si la table contient au moins une ligne */
    if (this.lignes != null && this.lignes.length > 0) {
      wlargeur = this.lignes[0].parentNode.parentNode.offsetWidth;
    } else {
      wlargeur = 20;
    }
  }

  /* Pour Mozilla */
  if (ECW_isGecko && this.divTBody) {
    /* Position de la balise <table> */
    this.divTBody.firstChild.style.position = "";
  }

  /* Si l'ascenseur vertical s'affiche il faut ajouter la largeur de l'ascenseur */
  if (this.lignes && this.lignes.length > this.nbligne) {
    wlargeur += ecwScrollBarWidth;
  }

  /* Si barre de status */
  if (this.divTStatus) {
    var owStatus = this.ecwTable.divTStatus.offsetWidth;
    if (wlargeur < owStatus) {
      wlargeur = owStatus;
    }
  }

  this.ecwWidthTable  = wlargeur;

  if (this.divTBody) {
    this.divTBody.style.width = wlargeur;
    /* Pour une table, calcul de la longueur, car position: static */
    if (!this.ecwTable.ecwComboBox) {
      this.noeudDOM.style.width = this.divTBody.offsetWidth + 3;
    }
    /* Pour une Combo, PAS de calcul de la longueur, car position: absolute */
  }
  
  /* Modif V2.0 : disabled des champs input et select du TBODY du divTHead */
  /* pour ne pas polluer l'entete avec le focus */
  if ((this.divTHead) && (this.divTBody)) {
    var divTHeadTBody = getFirstChildByTagName(this.divTHead, "TBODY");
    if (divTHeadTBody) {
      var lines = divTHeadTBody.getElementsByTagName("INPUT");
      for (var indiceLines = 0; indiceLines < lines.length; indiceLines++) {
        lines[indiceLines].disabled = true;
      }

      lines = divTHeadTBody.getElementsByTagName("SELECT");
      for (var indiceLines = 0; indiceLines < lines.length; indiceLines++) {
        lines[indiceLines].disabled = true;
      }

      lines = divTHeadTBody.getElementsByTagName("BUTTON");
      for (var indiceLines = 0; indiceLines < lines.length; indiceLines++) {
        lines[indiceLines].disabled = true;
      }
    }
  }
  //Forcer le mode absolute pour IE apres les calculs de dimension
  if (ECW_isIE && this.divTBody) { 
  	this.divTBody.firstChild.style.position = "absolute";
  }
}

/**
 * Permet de forcer le style POSITION pour le tableau
 * Valeur force : chaine vide => permet un recalcul correct dans le cas d'un tableau
 * avec filtre
 * @private
 */
ECW.Table.prototype.forceNoPositionForCompatibility = function() {
	if (this.divTBody) this.divTBody.firstChild.style.position = "";		
}

/**
 * Positionne la ligne selectionnee en ligne active sans faire le focus
 * @param ligne Ligne selectionnee
 * @param cursorTop = true permet de positionner le curseur au plus haut dans la liste
 * @param event Evenement
 * @private
 */
ECW.Table.prototype.selectionnerLigneWithOutFocus = function(ligne, cursorTop, event) {

  /* Deselectionner la ligne active */
  if (this.ligneActive) {
    removeClass(this.ligneActive, "ecwTableLineActive");
    removeClass(this.ligneActive, "ecwTableLineSelect");
    if (this.ligneActive != ligne) {
      ecwRemoveSpan(this.ligneActive.getElementsByTagName("TD")[this.searchColumn],
        "ecwTableTextSelectFiltre");
    }
  }

  /* Selectionne la nouvelle ligne active */
  this.ligneActive = ligne;
  if (this.ligneActive && this.showSelection) {
    addClass(ligne, "ecwTableLineActive");
  }

  /* Mise a jour du select cache, sauf si canReorder ou le select */
  /* porte sur l'ensemble des lignes si l'ordre a ete modifie */
  if ((!this.canReorder && !this.selectionDoubleTable && (this.ecwTableSrcSelect == null) && (this.ecwTableTargetSelect == null))
      || (!this.canReorder && (this.ecwTableSrcSelect != null) && (this.ecwTableTargetSelect != null)) ) {
       this.genererSelect(new Array(this.ligneActive));
  }

  /* Scrolling */
  hauteurEntete = 0;
  if (this.divTHead) {
    hauteurEntete = this.divTHead.offsetHeight;
  }
  /* Scrolling de la ligne superieure */
  if (ligne && ligne.offsetTop - hauteurEntete < this.ligneActive.parentNode.parentNode.parentNode.scrollTop) {
    this.ligneActive.parentNode.parentNode.parentNode.scrollTop = ligne.offsetTop - hauteurEntete;
  }
  /* Scrolling de la ligne inferieure */
  if (ligne && ligne.offsetTop + ligne.offsetHeight >
    this.ligneActive.parentNode.parentNode.parentNode.scrollTop +
    this.ligneActive.parentNode.parentNode.parentNode.offsetHeight) {
    this.ligneActive.parentNode.parentNode.parentNode.scrollTop = ligne.offsetTop +
      ligne.offsetHeight - this.ligneActive.parentNode.parentNode.parentNode.offsetHeight;
  }

  /* Positionnement de la ligne selectionnee /*
  /* pour qu'elle soit en premiere position */
  if (ligne && cursorTop) {
    this.ligneActive.parentNode.parentNode.parentNode.scrollTop = ligne.offsetTop - hauteurEntete;
  }

  /* Derniere ligne selectionnee */
  this.lastSelectedLine = ligne;
}

/**
 * Positionne la ligne selectionnee en ligne active
 * @param ligne Ligne selectionnee
 * @param cursorTop = true permet de positionner le curseur au plus haut dans la liste
 * @param event Evenement
 * @private
 */
ECW.Table.prototype.selectionnerLigne = function(ligne, cursorTop, event) {

  this.selectionnerLigneWithOutFocus(ligne, cursorTop, event);

  /* Pour un tableau, */
  /* Si l'input invisible n'est pas disable, focus */
  //Modif V2.0
  if ((!this.input.disabled) && (!ecwIsFocusFormElement(event))) {
    this.setFocus();
  }

  /* Evenement onSelect */
  if (this.onSelect) {
    this.onSelect();
  }
}

/**
 * S&eacute;lectionne la ligne correspondante &agrave; l'index.
 * @param index l'index de la ligne &agrave; s&eacute;lectionner
 * (0 -> premi&egrave;re ligne).
 */
ECW.Table.prototype.selectLine = function(index) {
  if (this.lignes) {
    if (index) {
      if (index >= this.lignes.length)
        index = this.lignes.length - 1;
    } else {
      index = 0;
    }
    this.selectionnerLigne(this.lignes[index]);
  }
}

/**
 * S&eacute;lectionne la ligne correspondante &agrave; l'index sans donner
 * le focus &agrave; la table.
 * @param index l'index de la ligne &agrave; s&eacute;lectionner
 * (0 -> premi&egrave;re ligne).
 */
ECW.Table.prototype.selectLineWithOutFocus = function(index) {
  if (this.lignes) {
    if (index) {
      if (index >= this.lignes.length)
        index = this.lignes.length - 1;
    } else {
      index = 0;
    }
    this.selectionnerLigneWithOutFocus(this.lignes[index]);
    this.desactiver();
  }
}

/**
 * Desactive la table : passe la ligne de l'etat selectionne actif a l'etat selectionne non-actif
 * @private
 */
ECW.Table.prototype.desactiver = function() {
  this.hideUIMessage();
  removeClass(this.noeudDOM, "ecwTableActive");
  /* Si selection d'une ligne */
  if (this.ligneActive) {
    removeClass(this.ligneActive, "ecwTableLineActive");

    /* Si le tableau n'est pas reordonnable */
    /* et si ce n'est pas le tableau de selection (double table) */    
    if (!this.canReorder && (this.ecwTableSrcSelect == null) && (this.ecwTableTargetSelect == null)) {
    
      /* Mono-selection */
      if ((!this.ligneMultiSelect) || this.tabLigneMulti.length == 0) {
        if (this.showSelection) {
          addClass(this.ligneActive, "ecwTableLineSelect");
        }
        /* Selection de la ligne active */
        if (!this.canReorder && (this.ecwTableSrcSelect == null)) {
            this.genererSelect(new Array(this.ligneActive));
        }    
      }
      /* Multi-selection */
      else {
        if (this.tabLigneMulti.length > 0) {
          this.genererSelect(this.tabLigneMulti);
        }
      }
    }
    /* Si ordonnable ou selection avec double table */
    else {
      addClass(this.ligneActive, "ecwTableLineSelect");
    }
  }
}

/**
 * Active la table : passe la ligne de l'etat selectionne non-actif a l'etat selectionne actif
 * @private
 */
ECW.Table.prototype.activer = function() {
  this.showUIMessage();
  if (!this.showSelection) {
    return;
  }
  addClass(this.noeudDOM, "ecwTableActive");
  if (this.ligneActive) {
    removeClass(this.ligneActive, "ecwTableLineSelect");
    addClass(this.ligneActive, "ecwTableLineActive");
    this.setFocus();
  } else {
    /* Lignes presentes */
    if (this.lignes && this.lignes.length > 0) {
      this.selectionnerLigne(this.lignes[0]);
    }
    /* Tableau vide */
    else {
      this.setFocus();
    }
  }
}

/**
 * Actions des touches du clavier
 * @private
 */
ECW.Table.prototype.onKey = function(action) {

  /* Si le table est integre dans une ComboBox */
  if (this.ecwComboBox) {
    this.ecwComboBox.onKey(action);
  }
  /* Sinon : liste classique */
  else {

    if (action == "esc" && this.ecwUI.onEscape) {
      this.ecwUI.onEscape();
    }

    if (action == "inser" && this.onInsert) {
      this.onInsert();
    }

    /* Evenements uniquement valables pour un tableau NON vide */
    if (this.lignes && this.lignes.length > 0) {
      if (action == "space") {
        if (this.ligneActive.ecwTable.ligneMultiSelect) {
          this.cocherLigne(this.ligneActive);
        }
        /* Evenement onSelect */
        if (this.onSelect) {
          this.onSelect();
        }
      }
      if (action == "suppr" && this.onDelete) {
        this.onDelete();
      }
      if (action == "enter" && this.onExecute) {
        /* RAZ Event pour IE sur ENTER */
        if (ECW_isIE) {
          if (!event) {
            event = window.event;
          }
          event.returnValue = false;
        }
        this.onExecute();
      }
      
      /* Actions des touches de navigation du clavier (up, down, pageUp, pageDown, home, end) */
      if (action == "home" || action == "end" || action == "pageDown" || action == "pageUp" || action == "down" || action == "up"){
        this.onKeyNavigation(action);
        return false;
      }
      
      if (action == "backSpace") {
        this.ecwTable.texteFiltre = this.ecwTable.texteFiltre.substr(0, this.ecwTable.texteFiltre.length - 1);
        this.ecwTable.findChar("");
      }
      if (action == "ctrl-C") {
        this.copyTable();
      }
      
      /* Multi-selection */
      if (this.ligneMultiSelect) {
        if (action == "ctrl-A") {
          this.selectAll();
        }
      }

      /* Table non Ajax */
      if (this.ajaxAction) {
        if (action == "ctrl-home") {
          this.firstPage();
        }else if (action == "ctrl-end") {
          this.lastPage();          
        }
      }else 
      /* Reordonnancement */
      if (this.canReorder) {
        if (action == "ctrl-home") {
          this.lineTop();
        }
        if (action == "ctrl-end") {
          this.lineBottom();          
        }
        if (action == "ctrl-up") {
          this.lineUp();
        }
        if (action == "ctrl-down") {
          this.lineDown();
        }
      }


    }
    /* Deplacement de ligne */
    if (this.selectionDoubleTable) {
      if (action == "right") {
        this.addLine();
      }
      if (action == "ctrl-right") {
        this.addAllLine();
      }
    }
    if (this.ecwTableSrcSelect) {
      if (action == "left") {
        this.ecwTableSrcSelect.removeLine();
      }
      if (action == "ctrl-left") {
        this.ecwTableSrcSelect.removeAllLine();
      }
    }
  }
}

/**
 * Actions des touches de navigation du clavier.
 * (up, down, pageUp, pageDown, home, end) 
 * @private
 */
ECW.Table.prototype.onKeyNavigation = function(action) {
  var position = 0;
  if(this.ligneActive){
    position = this.ligneActive.rIndex;
  }
  var existAscenseur = (this.lignes && this.lignes.length > this.nbligne);
  var hauteurEntete = 0;
  if (this.divTHead) {
    hauteurEntete = this.divTHead.offsetHeight;
  }
  
  /* Table non AJAX */
  if(!this.ajaxAction){

    if (action == "home") {
    
      this.initFindChar();
      this.selectionnerLigne(this.lignes[0]);
    }else if (action == "end") {
    
      this.initFindChar();
      this.selectionnerLigne(this.lignes[this.lignes.length - 1]);
    }else if (action == "pageDown") {
    
      if(position+this.nbligne>this.lignes.length){
        this.initFindChar();
        this.selectionnerLigne(this.lignes[this.lignes.length - 1]);
      }else{
        this.changerSelectionLigne(this.nbligne);
      }
      if(existAscenseur){
        this.ligneActive.parentNode.parentNode.parentNode.scrollTop = this.ligneActive.offsetTop - hauteurEntete;
      }
    }else if (action == "pageUp") {
    
      if(position-this.nbligne<=0){
        this.initFindChar();
        this.selectionnerLigne(this.lignes[0]);
      }else{
        this.changerSelectionLigne( -this.nbligne);
      }
      if(existAscenseur){
        this.ligneActive.parentNode.parentNode.parentNode.scrollTop = this.ligneActive.offsetTop - hauteurEntete;
      }
    }else if(action == "down"){
    
      this.changerSelectionLigne(1);
    }else if(action == "up"){
    
      this.changerSelectionLigne(-1);
    }

   /* Table AJAX */
  }else{

    var actionChangePage = null;
    var selectLastLine = false;
    /* sans ascenseur */
    if(!existAscenseur){
  
      if (action == "home") {
        actionChangePage = "firstPage";
      }else if (action == "end") {
        actionChangePage = "lastPage";
      }else if (action == "pageDown") {
        actionChangePage = "nextPage";
      }else if (action == "pageUp") {
        actionChangePage = "previousPage";
      }else if(action == "down"){

        /* Si on est sur la 1iere ligne on retourne a la 1iere page, sinon on remonte d'une ligne */
        if(position==this.lignes.length){
          actionChangePage = "nextPage";
        }else{
          this.changerSelectionLigne(1);
        }
      }else if(action == "up"){
        
        /* Si on est sur la 1iere ligne on retourne a la 1iere page, sinon on descend d'une ligne */
        if(position==1){
          actionChangePage = "previousPage";
          selectLastLine = true;
        }else{
          this.changerSelectionLigne(-1);
        }
      }
      
    /* avec ascenseur */
    }else {
  
      if (action == "home") {
        
        /* Si on est sur la 1iere ligne on retourne a la 1iere page, sinon on retourne deja au debut de la page courante */
        if(position==1){
          actionChangePage = "firstPage";
        }else{
          this.initFindChar();
          this.selectionnerLigne(this.lignes[0]);
        }
      }else if (action == "end") {
        
        /* Si on est sur la derniere ligne on va sur la derniere page, sinon on retourne deja a la fin de la page courante */
        if(position==this.lignes.length){
          actionChangePage = "lastPage";
        }else{
          this.initFindChar();
          this.selectionnerLigne(this.lignes[this.lignes.length - 1]);
        }
      }else if (action == "pageDown") {
        
        /* Si on est sur la derniere ligne on va a la page suivante */
        /* sinon on avance de nbLigne ou moins, suivant ce qu'il reste */
        if(position==this.lignes.length){
          actionChangePage = "nextPage";
        }else{
          if(position+this.nbligne>this.lignes.length){
            this.initFindChar();
            this.selectionnerLigne(this.lignes[this.lignes.length - 1]);
          }else{
            this.changerSelectionLigne(this.nbligne);
          }
          this.ligneActive.parentNode.parentNode.parentNode.scrollTop = this.ligneActive.offsetTop - hauteurEntete;
        }
      }else if (action == "pageUp") {
        
        /* Si on est sur la premiere ligne on retourne a la page precedente */
        /* sinon on recule de nbLigne ou moins, suivant ce qu'il reste */
        if(position==1){
          actionChangePage = "previousPage";
        }else{
  
          if(position-this.nbligne<=0){
            this.initFindChar();
            this.selectionnerLigne(this.lignes[0]);
          }else{
            this.changerSelectionLigne( -this.nbligne);
          }
          this.ligneActive.parentNode.parentNode.parentNode.scrollTop = this.ligneActive.offsetTop - hauteurEntete;
        }
      }else if(action == "down"){
        if(position==this.lignes.length){
          actionChangePage = "nextPage";
        }else{
          this.changerSelectionLigne(1);
        }
      }else if(action == "up"){
        if(position==1){
          actionChangePage = "previousPage";
          selectLastLine = true;
        }else{
          this.changerSelectionLigne(-1);
        }
      }
    }
    
    if(actionChangePage){
    	var obj = this;
    	if(this.ecwComboBox){
    	  obj = this.ecwComboBox;
    	}
      if(actionChangePage=="firstPage"){
        obj.firstPage();
      }else if(actionChangePage=="previousPage"){
        obj.previousPage(selectLastLine);
      }else if(actionChangePage=="nextPage"){
        obj.nextPage();
      }else if(actionChangePage=="lastPage"){
        obj.lastPage();
      }
    }
  
  }
}

/**
 * Deplace le curseur de selection d'une ligne
 * @private
 */
ECW.Table.prototype.changerSelectionLigne = function(position) {
  if (this.lignes) {
    if (this.ligneActive) {
      var rIndexLigne = this.ligneActive.rIndex;
      this.initFindChar();
//alert('rIndexLigne:'+rIndexLigne+'\nposition:'+position+'\nlength:'+this.lignes.length)
      if (rIndexLigne + position > 0 && rIndexLigne + position <= this.lignes.length) {
        this.selectionnerLigne(this.lignes[rIndexLigne + position - 1]);
      } else {
        if (position > 0) {
          this.onKey("end");
        } else {
          this.onKey("home");
        }
      }
    } else {
      this.onKey("home");
    }
  }
}

/**
 * Mise a jour des couleurs alternees
 * @private
 */
ECW.Table.prototype.processAlternateColor = function() {

  if (this.lignes) {
    /* Pour les tableaux ayant des couleurs de lignes alternees */
    if (this.alternateColor && this.showSelection) {
      var ligne;
      var nbLignes = this.lignes.length;
      for (var i = 0; i < nbLignes; ++i) {
        ligne = this.lignes[i];
        if (i % 2 == 0) {
          /* i est pair */
          removeClass(ligne, "ecwTableAlternateLine2");
          addClass(ligne, "ecwTableAlternateLine1");
        } else {
          /* i est impair */
          removeClass(ligne, "ecwTableAlternateLine1");
          addClass(ligne, "ecwTableAlternateLine2");
        }
      }
    }
  }
}
  
/**
 * Lance le tri sur une colonne de la liste
 * @private
 */
ECW.Table.prototype.sortByColumn = function(col) {
  this.initFindChar();
  this.searchColumn = col.cellIndex;

  /* Recuperation de la table contenant les donnees a trier en passant par le DIV principal */
  var table = getFirstChildByTagName(this.divTBody, "TABLE");
  if (col.ecwTable.triActif != 0) {
    if (Math.abs(col.ecwTable.triActif) - 1 == col.cellIndex) {
      if (col.ecwTable.triActif > 0) {
        removeClass(col, "ecwTableSortIncrease");
        addClass(col, "ecwTableSortDecrease");
        col.ecwTable.triActif =  - (col.cellIndex + 1);
        ecw_sort(col.ecwTable.triActif, table, this.comparators);
      } else {
        removeClass(col, "ecwTableSortDecrease");
        addClass(col, "ecwTableSortIncrease");
        col.ecwTable.triActif = col.cellIndex + 1;
        ecw_sort(col.ecwTable.triActif, table, this.comparators);
      }
    } else {
      var tr = col.parentNode;
      var listeTd = tr.cells;
      var tdOld = listeTd[Math.abs(col.ecwTable.triActif) - 1];
      removeClass(tdOld, "ecwTableSortDecrease");
      removeClass(tdOld, "ecwTableSortIncrease");
      addClass(col, "ecwTableSortIncrease");
      col.ecwTable.triActif = col.cellIndex + 1;
      ecw_sort(col.ecwTable.triActif, table, this.comparators);
    }
  } else {
    addClass(col, "ecwTableSortIncrease");
    col.ecwTable.triActif = col.cellIndex + 1;
    ecw_sort(col.ecwTable.triActif, table, this.comparators);
  }
  
  /* Mise a jour des lignes alternees */
  this.processAlternateColor();

  /* Mise a jour de la numerotation */
  this.processNumerotation();

  /* Mise a jour de la numerotation */
  this.processIndex();

  /* Selection de la 1ere ligne */
  this.selectionnerLigne(this.lignes[0]);
}

/**
 * Selectionne ou deselectionne une ligne en mode MultiSelection
 * @private
 */
ECW.Table.prototype.cocherLigne = function(ligne,modeShift) {
  var obj = ligne;
   /* modeShift : flag permettant de contourner un bug lors 
   * de la multiselection de ligne avec shift et lorsque l'on va 
   * de bas en haut
   * Correctif pas tres elegant mais limite les effets de bord
   * car cette methode est utilisee dans de nombreux cas.
   * */
  if (modeShift==null) modeShift=false;
  if (isClass(obj, "ecwTableLineMultiple")) {
    var j = 0;
    var tabMulti = new Array;
    for (var i = 0; i < this.tabLigneMulti.length; i++) {
      if (this.tabLigneMulti[i] != ligne) {
        tabMulti[j] = this.tabLigneMulti[i];
        j++;
      }
    }
    this.tabLigneMulti = tabMulti;
    removeClass(obj, "ecwTableLineMultiple");
  } else {
    /* Retient la premiere ligne selectionnee si elle ne l'est pas encore */
    if(!modeShift && this.lastSelectedLine && this.lastSelectedLine.rIndex!=ligne.rIndex 
        && !isClass(this.lastSelectedLine, "ecwTableLineMultiple")){
      addClass(this.lastSelectedLine, "ecwTableLineMultiple");
      this.tabLigneMulti[this.tabLigneMulti.length] = this.lastSelectedLine;
    }
    this.tabLigneMulti[this.tabLigneMulti.length] = ligne;
    addClass(obj, "ecwTableLineMultiple");
  }

  if (this.onMultiSelect) {
    this.onMultiSelect();
  }
}

/**
 * Selectionne un ensemble de lignes situees entre la derniere ligne selectionnee
 * et la ligne sur laquelle on vient de cliquer
 * @private
 */
ECW.Table.prototype.shiftCocherLigne = function(ligne) {

  /* Sauvegarde la derniere lignes selectionnee */
  var currentLine;
    if (this.lastSelectedLine) {
        currentLine = this.lastSelectedLine;
    } else {
        /* Si aucune ligne n'est selectionnee, on prend la premiere */
        currentLine = getFirstChildByTagName(getFirstChildByTagName(this.divTBody, "TBODY"), "TR");
    }

  /* Deselection */
  this.unselectLines();

  /* Retablit la ligne selectionnee */
  this.lastSelectedLine = currentLine;

  if (ligne.rIndex > this.lastSelectedLine.rIndex) {
    for (var i = this.lastSelectedLine.rIndex; i <= ligne.rIndex; i++) {
      var ligneACocher = this.lignes[i - 1];
      /* Au cas ou la ligne serait deja selectionnee */
      removeClass(ligneACocher, "ecwTableLineMultiple");
      this.cocherLigne(ligneACocher,true);
    }
  } else {
    for (var i = ligne.rIndex; i <= this.lastSelectedLine.rIndex; i++) {
      var ligneACocher = this.lignes[i - 1];
      /* Au cas ou la ligne serait deja selectionnee */
      removeClass(ligneACocher, "ecwTableLineMultiple");
      this.cocherLigne(ligneACocher,true);
    }
  }
}

/**
 * Genere une balise SELECT avec ses options correspondant a la cle
 * de la/les ligne(s) selectionnee(s)
 * @private
 */
ECW.Table.prototype.genererSelect = function(listeLignes) {

  /* Generation des balises SELECT */
  for (var i = 0; i < this.tabNameKey.length; i++) {
    var wSelect = document.getElementById("listeSelect" + this.tabNameKey[i]);
    
    /* Suppression des anciennes balises OPTION */
    for (var k = wSelect.childNodes.length - 1; k >= 0; k--) {
      wSelect.removeChild(wSelect.childNodes[k]);
    }

    /* Generation des balises OPTION en mode multiSelection */
    if (listeLignes && listeLignes.length > 1) {
      for (var j = 0; j < listeLignes.length; j++) {
        var wOption = document.createElement("OPTION");
        if (listeLignes[j].getAttribute("ecwKeyVal" + i) != null) {
          var wtext = listeLignes[j].getAttribute("ecwKeyVal" + i);
        } else {
          var wtext = ecwGetInnerText(listeLignes[j].getElementsByTagName("TD")[i]).trim();
        }
        wOption.text = wtext;
        wOption.value = wtext;
        wOption.selected = true;
        wSelect.appendChild(wOption);
      }
    }
    /* Generation des balises OPTION en mode monoSelection */
    else if (listeLignes && listeLignes.length == 1) {
      var wOption = document.createElement("OPTION");
      if (listeLignes[0].getAttribute("ecwKeyVal" + i) != null) {
        var wtext = listeLignes[0].getAttribute("ecwKeyVal" + i);
      } else {
        var wtext = ecwGetInnerText(listeLignes[0].getElementsByTagName("TD")[i]).trim();
      }
      wOption.text = wtext;
      wOption.value = wtext;
      wOption.selected = true;
      wSelect.appendChild(wOption);
    }
  }
}

/**
 * Execute une action
 * @private
 */
ECW.Table.prototype.executerActionLigne = function(ligne) {
  if (this.onExecute) {
    this.onExecute();
  }
}

/**
 * Initialise la recherche du caractere saisie dans la liste
 * @private
 */
ECW.Table.prototype.initFindChar = function() {
  if (this.ligneActive) {
    ecwRemoveSpan(this.ligneActive.getElementsByTagName("TD")[this.searchColumn],
      "ecwTableTextSelectFiltre");
  }
  this.texteFiltre = "";
}

/**
 * Recherche le caractere saisie dans la liste
 * @private
 */
ECW.Table.prototype.findChar = function(touche) {
  var texte = this.texteFiltre + touche;
  if (texte.length != 0) {
    var nbLines = 0;
    if (this.lignes) {
      nbLines = this.lignes.length;
    }
    texte = texte.toUpperCase();
    for (var i = 0; i < nbLines; ++i) {
      var cell = this.lignes[i].getElementsByTagName("TD")[this.searchColumn];
      var cellText = (ecwGetInnerText(cell).toUpperCase()).trim();
      if (cellText.indexOf(texte) == 0) {
        this.selectionnerLigne(this.lignes[i], true);
        ecwRemoveSpan(cell, "ecwTableTextSelectFiltre");
        ecwAddSpan(cell, "ecwTableTextSelectFiltre", texte);
        this.texteFiltre = texte;
        break;
      }
    }
  } else {
    this.initFindChar();
  }
}

/**
 * Place le focus sur la table
 */
ECW.Table.prototype.setFocus = function() {
  if (this.input.ecwControl && this.input.ecwControl.isVisible()) {
    return this.input.ecwControl.setFocus();
  }
}

/**
 * Retourne le nombre de ligne de la table
 */
ECW.Table.prototype.getNbLines = function() {

  /* La liste est construite */
  if (this.lignes) {
    return this.lignes.length;
  }
  /* Si la liste n'est pas encore construite */
  /* Cas de la ComboBox */
  else if (this.ecwComboBox && !this.ecwComboBox.listBuilded) {
    this.constructeur();
    this.ecwComboBox.listBuilded = true;
    if (this.lignes) {
      return this.lignes.length;
    } else {
      return 0;
    }
  }
  /* Autre cas */
  else {
    return 0;
  }
}

/**
 * Retourne le nombre de lignes s&eacute;lectionn&eacute;es dans la table
 */
ECW.Table.prototype.getSelectedLines = function() {
  if (this.tabLigneMulti.length == 0 && this.ligneActive) {
    return 1;
  } else {
    return this.tabLigneMulti.length;
  }
}

/**
 * Retourne vrai si une ligne est s&eacute;lectionn&eacute;e dans la table
 */
ECW.Table.prototype.hasSelectedLine = function() {
  if (this.ligneActive) {
    return true;
  } else {
    return false;
  }
}

/**
 * Retourne le contenu de la cellule de la ligne active.
 * @param idColonne Index de la colonne.
 */
ECW.Table.prototype.getColumn = function(idColonne) {
  var result = null;
  if(this.numerotation){
    idColonne++;
  }
  var listeColumn = getChildrenByTagName(this.ligneActive, "TD");
  if (listeColumn && (idColonne < listeColumn.length)) {
    var objColumn = listeColumn[idColonne]; 
    if (objColumn) {
      var valueColumn = ecwGetInnerText(objColumn);
      if (valueColumn) {
        result = valueColumn.trim();
      }
    }
  }
  return result;
}

/**
 * Retourne la valeur de la cl&eacute; de la ligne active
 */
ECW.Table.prototype.getKeyVal = function(keyName) {
  for (var i = 0; i < this.tabNameKey.length; i++) {
    if (this.tabNameKey[i] == keyName) {
      /* Si une ligne est selectionnee */
      if (this.ligneActive) {
        return this.ligneActive.getAttribute("ecwKeyVal" + i);
      }
      else {
        return "";
      }
    }
  }
}

/**
 * Specifie un comparateur pour une colonne donnee. Par defaut, le comparateur
 * choisi lors d'un tri est choisi en fonction du contenu de la premiere case
 * non vide de la colonne.
 * @param colonne l'index de la colonne,
 * @param comparator la fonction qui va permettre de comparer les elements :
 * cette fonction doit accepter deux parametres (a et b) en entree et renvoyer
 * un entier negatif, nul ou positif selon le resultat de la comparaison
 * entre a et b.
 */
ECW.Table.prototype.setColumnComparator = function(colonne, comparator) {
  this.comparators[colonne] = comparator;
}

/**
 * Specifie un comparateur pour une colonne donnee, designee par sa cle.
 * @param colonne la cle de la colonne,
 * @param comparator la fonction de comparaison.
 */
ECW.Table.prototype.setKeyValComparator = function(keyName, comparator) {
  for (var i = 0; i < this.tabNameKey.length; i++) {
    if (this.tabNameKey[i] == keyName) {
      this.comparators[i] = comparator;
    }
  }
}

/**
 * Retourne l'index de la ligne active.
 * Ajout David Meunier 18/06/2007.
 * @return index de la ligne active.
 */
ECW.Table.prototype.getSelectedLineIndex = function() {
  return this.ligneActive.rIndex - 1;
}

/**
 * Retourne la (les) valeur(s) de la cl&eacute; de la (des) ligne(s) active(s)
 * @return Tableau des valeurs pour la cl&eacute;
 */
ECW.Table.prototype.getAllKeyVal = function(keyName) {

  var result = new Array();

  /* Recherche de la cle */
  for (var i = 0; i < this.tabNameKey.length; i++) {
    /* Cle trouve */
    if (this.tabNameKey[i] == keyName) {
      /* Mono-selection */
      if (this.tabLigneMulti.length == 0 && this.ligneActive) {
        result[0] = this.ligneActive.getAttribute("ecwKeyVal" + i); 
        return result;
      }
      /* Multi-selection */
      else if (this.tabLigneMulti.length > 0) {
        for (var j = 0; j < this.tabLigneMulti.length; j++) {
          result[j] = this.tabLigneMulti[j].getAttribute("ecwKeyVal" + i);
        }
        return result;
      }
      /* Sinon */
      else {
        result[0] = "";
        return result;
      }
    }
  }
}

/**
 * Rafra&icirc;chi les donn&eacute;es de la liste
 */
ECW.Table.prototype.refresh = function(htmlTable) {
  var newDivTable = document.createElement("DIV");
  newDivTable.innerHTML = htmlTable;
  this.refreshDIV(newDivTable);
}

/**
 * Rafra&icirc;chi les div d'une table
 * @private
 */
ECW.Table.prototype.refreshDIV = function(table, status) {

  /* Suppression de tous les noeuds enfants de <DIV class="ecwTable> */
  for (var i = this.noeudDOM.childNodes.length - 1; i >= 0; i--) {
    if (this.noeudDOM.childNodes[i].nodeName != "INPUT") {
      this.noeudDOM.removeChild(this.noeudDOM.childNodes[i]);
    }
  }
  this.ligneActive = null;
  this.tabLigneMulti = new Array;
  this.lignes = null;
  this.divTHead = null;
  this.divTBody = null;
  this.divTStatus = null;
  this.tabNameKey = new Array;
  this.texteFiltre = "";
  this.searchColumn = 0;

  /* Contenu de la table */
  this.noeudDOM.appendChild(table);

  /* Construction de la Table */
  this.constructeur();
  
  if (status) {
    this.noeudDOM.appendChild(status);
    this.divTStatus = status;
  }
}

/**
 * Copie dans le presse papier le contenu de la liste
 * @private
 */
ECW.Table.prototype.copyTable = function() {
  var monText = document.createElement("TEXTAREA");
  monText.innerText = this.divTBody.innerHTML;
  if (monText.createTextRange) {
    var Copied = monText.createTextRange();
    Copied.execCommand("Copy");
    this.input.ecwControl.ecwUI.setMessage("I",
      "Tableau copie au format HTML dans le presse papier Window. \nVous pouvez le coller dans une feuille Excel.");
  }
}

/**
 * S&eacute;lectionne toutes les lignes du tableau
 */
ECW.Table.prototype.selectAll = function() {

  if (this.lignes && this.ligneMultiSelect) {

    /* Deselection */
    this.unselectLines();

    /* Parcours des lignes */
    for (var iLigne = 0; iLigne < this.lignes.length; iLigne++) {
      this.cocherLigne(this.lignes[iLigne]);
    }
    /* Mise a jour de la balise <select> */
    this.genererSelect(this.lignes);
  }
}

/**
 * S&eacute;lectionne la/les ligne(s) dont les cl&eacute;s et les valeurs de cl&eacute; sont pass&eacute;s
 * en param&egrave;tre
 * Structure du param&eacute;tre recu :
 *  tabKey = [["cle0", "cle1", ...], ["val01", "val11", ...], ["val02", "val12", ...], [...], ... ]
 */
ECW.Table.prototype.selectKey = function(tabKey) {

  /* Deselection */
  this.unselectLines();

  if (tabKey.length > 0) {
    /* Recuperation de l'ordre des cles par rapport a celui defini dans la balise table */
    var indexKeyName = new Array;
    for (var i = 0; i < tabKey[0].length; i++) {
      for (var j = 0; j < this.tabNameKey.length; j++) {
        if (this.tabNameKey[j] == tabKey[0][i]) {
          indexKeyName[i] = j;
        }
      }
    }
    /* Comparaison des valeurs de cle pour chaque ligne */
    var tabLignesSelect = new Array;
    if (this.lignes) {
      /* Pour chaque ligne de la table */
      for (var iLigne = 0; iLigne < this.lignes.length; iLigne++) {
        var currentLigne = this.lignes[iLigne];
        /* Pour chaque groupe de valeurs du parametre recu */
        for (var iGrpVal = 1; iGrpVal < tabKey.length; iGrpVal++) {
          var valTrue = true;
          /* Compare avec chaque valeur du groupe */
          for (var iVal = 0; iVal < tabKey[iGrpVal].length && valTrue; iVal++) {
            if (currentLigne.getAttribute("ecwKeyVal" + indexKeyName[iVal]) != tabKey[iGrpVal][iVal]) {
              valTrue = false;
            }
          }
          /* Si valeurs de cles correspondent, on sauvegarde la ligne et on passe a la ligne suivante. */
          if (valTrue) {
            tabLignesSelect[tabLignesSelect.length] = currentLigne;
            break;
          }
        }
      }
    }

    /* Selection des lignes dans la table */
    if (tabLignesSelect.length > 0) {
    
      /* Multi-selection avec plusieurs lignes selectionnees */
      if ((this.ligneMultiSelect) && (tabLignesSelect.length > 1)) {
        for (var i = 0; i < tabLignesSelect.length; i++) {
          this.cocherLigne(tabLignesSelect[i]);
        }
        this.genererSelect(tabLignesSelect);
      }
      /* Selection d'un ligne */
      else {
        /* Si c'est une Combo */
        /* recopie de la valeur dans le champ texte rattache */
        if (this.ecwComboBox) {
          this.ecwComboBox.ecwControl.noeudDOM.value = tabLignesSelect[0].chaineCar.trim();
        }
        this.selectionnerLigne(tabLignesSelect[0]);
      }
    }
  }
}

/**
 * Supprime la selection de toutes les lignes
 */
ECW.Table.prototype.unselectLines = function() {

  if (this.lignes) {
    /* Parcours des lignes */
    for (var iLigne = 0; iLigne < this.lignes.length; iLigne++) {
      /* Style Multi-selection */
      removeClass(this.lignes[iLigne], "ecwTableLineMultiple");

      /* Style Mono-selection */
      removeClass(this.lignes[iLigne], "ecwTableLineActive");
      removeClass(this.lignes[iLigne], "ecwTableLineSelect");

      /* Mise en evidence de la saisie */
      ecwRemoveSpan(this.lignes[iLigne].getElementsByTagName("TD")[this.searchColumn], "ecwTableTextSelectFiltre");
    }
    this.tabLigneMulti = [];
    this.lastSelectedLine = null;
    this.ligneActive = null;

    /* Pas de maj de la balise <select> cache, en mode Double Table */
    if ((this.ecwTable.ecwTableSrcSelect == null)
        && (this.ecwTable.ecwTableTargetSelect == null)) {
      /* Initialisation des balises <select> cachees */
      for (var i = 0; i < this.tabNameKey.length; i++) {
        var wSelect = document.getElementById("listeSelect" + this.tabNameKey[i]);

        /* Suppression des anciennes balises OPTION */
        for (var k = wSelect.childNodes.length - 1; k >= 0; k--) {
          wSelect.removeChild(wSelect.childNodes[k]);
        }
      }
    }
  }
}

/**
 * Tri par defaut des lignes
 * @private
 */
ECW.Table.prototype.initSort = function() {

  // Recuperation du mode de tri des lignes (single ou multiple)
  var tableValeur = getFirstChildByTagName(this.divTBody, "TABLE");
  var tableEntete = getFirstChildByTagName(this.divTHead, "TABLE");
  var numColDefaultSort = this.noeudDOM.attributes.ecwDefaultSort.nodeValue;
  var typeSort = "Decrease";

  if (this.noeudDOM.attributes.ecwDefaultTypeSort &&
      this.noeudDOM.attributes.ecwDefaultTypeSort.nodeValue == "Increase") {
    typeSort = "Increase";
  }

  //Il faut tjs se baser sur la derniere ligne du thead dans le cas ou il y aurait des groupcell)
  var nbRow = tableEntete.tHead.rows.length;
  var lastRows = tableEntete.tHead.rows[nbRow-1];

  // Controle sur le numero de colonne
  if (numColDefaultSort >= lastRows.cells.length) {
    //Pas de tri
    return ;
  }

  // Controle que la colonne est triable
  if (!isClass(lastRows.cells[numColDefaultSort], "ecwTableSortable")) {
    //Pas de tri
    return ;
  }

  //Modification de l'apparence
  var defaulColSort = lastRows.cells[numColDefaultSort];
  if (typeSort == "Increase") {
    addClass(defaulColSort, "ecwTableSortIncrease");
    defaulColSort.ecwTable.triActif = defaulColSort.cellIndex + 1;

  } else if (typeSort == "Decrease") {
    addClass(defaulColSort, "ecwTableSortDecrease");
    defaulColSort.ecwTable.triActif =  - (defaulColSort.cellIndex + 1);
  }

  //Tri
  ecw_sort(defaulColSort.ecwTable.triActif, tableValeur, this.comparators);

  //Mise a jour des lignes alternees
  this.processAlternateColor();

  //Mise a jour de la numerotation
  this.processIndex();
}


/**
 * Ajoute une colonne dans la table pour la numerotation,
 * puis place les numeros de ligne.
 * @private
 */
ECW.Table.prototype.numerotate = function() {
      
  var theadTable = getFirstChildByTagName(this.ecwTable.noeudDOM, "THEAD");
  /* Si l'entete existe */
  if (theadTable) {
    /* Entete de colonne pour numerotation */
    // il faut recuperer tous les fils (TR) de l'entete pour ajouter une colonne a chaque fils
    var upcTagName = "TR";
      var firstChildArray = theadTable.childNodes;
      for (var i = 0; i < firstChildArray.length; ++i) {
        var node = firstChildArray[i];
        if (node.tagName && node.tagName.toUpperCase() == upcTagName) {
          var td = document.createElement("TD");
          td.innerHTML = "&nbsp;";
          node.insertBefore(td, node.firstChild);
        } 
      }
  }

  var tbodyTable = getFirstChildByTagName(this.noeudDOM, "TBODY");
  /* Si le body existe */
  if (tbodyTable) {

    this.lignes = tbodyTable.rows;

    /* Pour chaque ligne */
    if (this.lignes && this.lignes.length != 0) {
      for (var i = 0; i < this.lignes.length; i++) {
        var ligne = this.lignes[i];
        var td = document.createElement("TD");
        td.className = "ecwTableNumerotation";
        ligne.insertBefore(td, ligne.firstChild);
      }
    }
    
    /* Detection d'une table vide */
    this.detectEmptyTable();
  }

  /* Colonne de recherche par defaut est la colonne d'indice 1*/
  /* La colonne d'indice 0 est la colonne de numerotation */
  this.searchColumn = 1;

  /* Mise a jour de la numerotation */
  this.processNumerotation();
}

/**
 * Mise a jour de la numerotation des lignes.
 * @private
 */
ECW.Table.prototype.processNumerotation = function() {

  /* Si la numerotation est activee */
  if (this.numerotation) {
    var lignes = this.lignes;
    if (lignes && lignes.length != 0) {
      for (var i = 0; i < lignes.length; i++) {
        var ligne = lignes[i];
        ligne.firstChild.innerHTML = "<span>" + (i + 1) + "</span>";
      }
    }
  }
}

/**
 * Mise a jour de l'index des lignes.
 * @private
 */
ECW.Table.prototype.processIndex = function() {
  if (this.lignes) {
    var n = this.lignes.length;
    for (var i = 0; i < n; ++i) {
      var ligne = this.lignes[i];
      ligne.rIndex = i + 1;
    }
  }
}

/**
 * Decale la ligne courante vers le haut.
 * @private
 */
ECW.Table.prototype.lineUp = function() {
  if (this.ligneActive) {
    this.moveActiveLigne(-1);
    this.genererSelect(this.lignes);
  }
}

/**
 * Decale la ligne courante vers le bas.
 * @private
 */
ECW.Table.prototype.lineDown = function() {
  if (this.ligneActive) {
    this.moveActiveLigne(1);
    this.genererSelect(this.lignes);
  }
}

/**
 * Place la ligne courante a la premiere position.
 * @private
 */
ECW.Table.prototype.lineTop = function() {
  if (this.ligneActive && this.ligneActive.rIndex > 1) {
    this.moveActiveLigne((this.ligneActive.rIndex - 1) *  -1);
    this.genererSelect(this.lignes);
  }
}

/**
 * Place la ligne courante a la derniere position.
 * @private
 */
ECW.Table.prototype.lineBottom = function() {
  if (this.ligneActive && this.ligneActive.rIndex < this.lignes.length) {
    this.moveActiveLigne((this.ligneActive.rIndex - this.lignes.length) *  -1);
    this.genererSelect(this.lignes);
  }
}

/**
 * Decale la ligne active. Le mouvement indique le nombre de decalage. Si le
 * mouvement est positif, alors le decalage se fait vers le bas.
 * @private
 */
ECW.Table.prototype.moveActiveLigne = function(movement) {
  if (this.ligneActive) {
    if (movement != -1 && movement != 1) {
      this.decaleLigne(this.ligneActive.rIndex - 1, this.ligneActive.rIndex - 1 + movement);
    } else {
      this.swapLigne(this.ligneActive.rIndex - 1, this.ligneActive.rIndex - 1 + movement);
    }
    this.selectionnerLigne(this.ligneActive);
  }
}

/**
 * Echange deux lignes du tableau.
 * @private
 */
ECW.Table.prototype.swapLigne = function(numLigne1, numLigne2) {

  if (numLigne1 >= 0 && numLigne2 < this.lignes.length && numLigne2 >= 0) {
    var tbody = getFirstChildByTagName(this.divTBody, "TBODY");
    var lines = getChildrenByTagName(tbody, "TR");

    var temp = lines[numLigne2].rIndex;
    lines[numLigne2].rIndex = lines[numLigne1].rIndex;
    lines[numLigne1].rIndex = temp;

    if (numLigne1 < numLigne2) {
      tbody.insertBefore(lines[numLigne2], lines[numLigne1]);
    } else {
      tbody.insertBefore(lines[numLigne1], lines[numLigne2]);
    }
  }

  /* Mise a jour des lignes alternees */
  this.processAlternateColor();

  /* Mise a jour de la numerotation */
  this.processNumerotation();
}

/**
 * Decale toutes les lignes entre deux indices de ligne.
 * @private
 */
ECW.Table.prototype.decaleLigne = function(numLigne1, numLigne2) {

  if (numLigne1 >= 0 && numLigne2 < this.lignes.length && numLigne2 >= 0 && numLigne1 != numLigne2) {
    var tbody = getFirstChildByTagName(this.divTBody, "TBODY");
    var lines = getChildrenByTagName(tbody, "TR");

    if (numLigne1 > numLigne2) {
      for (var i = numLigne2; i < numLigne1; i++) {
        lines[i].rIndex++;
      }
      lines[numLigne1].rIndex = numLigne2 + 1;
      tbody.insertBefore(lines[numLigne1], lines[numLigne2]);

    } else {
      for (var i = numLigne1 + 1; i <= numLigne2; i++) {
        lines[i].rIndex--;
      }

      lines[numLigne1].rIndex = numLigne2 + 1;
      if (numLigne2 == lines.length - 1) {
        tbody.appendChild(lines[numLigne1]);
      } else {
        tbody.insertBefore(lines[numLigne1], lines[numLigne2 + 1]);
      }
    }
  }

  /* Mise a jour des lignes alternees */
  this.processAlternateColor();

  /* Mise a jour de la numerotation */
  this.processNumerotation();
}

