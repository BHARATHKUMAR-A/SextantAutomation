/**
 * D&eacute;fini l'objet <b>ECW.ComboBox</b>
 * @private
 */
ECW.ComboBox = function(noeud, ui, layout, champ, table) {
  ecwStartTimer("ECW.ComboBox");
  ecwSetAttribute(this, "noeudDOM", noeud);
  ecwSetAttribute(this, "ecwUI", ui);
  ecwSetAttribute(this, "ecwLayout", layout);
  ecwSetAttribute(this, "ecwControl", champ);
  ecwSetAttribute(this.ecwControl, "ecwComboBox", this);
  ecwSetAttribute(this, "ecwTable", table);
  ecwSetAttribute(this.ecwTable, "ecwComboBox", this);
  this.ecwTable.noeudDOM.style.display = "none";

  /* Mode debug */
  this.modeDebug = false;
  this.listBuilded = false;
  this.checkValue = false;
  this.comboActivated = false;

  /* Constructeur */
  this.hiddenPage=false;
  this.constructeur();
  ecwStopTimer("ECW.ComboBox");
}

