/**
 * D&eacute;fini l'objet <b>ECW.Calendar</b>
 * @private
 */
ECW.Calendar = function(noeud, ui, layout) {
  ecwStartTimer("ECW.Calendar");
  ecwSetAttribute(this, "noeudDOM", noeud);
  ecwSetAttribute(this, "ecwUI", ui);
  ecwSetAttribute(this, "ecwLayout", layout); 
  /* Chargement de la langue */
  if (!window.Calendar._DN) {
  if (window.ecwLocale) {
      this.loadLanguage(window.ecwLocale);
    } else {
      this.loadLanguage(new ECW.I18N().getNavigatorLanguage());
    }
  }
  this.constructeur();
  ecwStopTimer("ECW.Calendar");
}

