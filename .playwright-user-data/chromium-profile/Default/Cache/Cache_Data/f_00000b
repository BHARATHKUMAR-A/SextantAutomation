/**
 * Constructeur de ECW.Calendar
 * @private
 */
ECW.Calendar.prototype.constructeur = function() {

  /* On recherche l'input attache au calendrier */
  if (this.noeudDOM.getElementsByTagName("input") != null) {
    /* Normalement c'est le seul (donc premier) input dans la div */
    ecwSetAttribute(this, "input", this.noeudDOM.getElementsByTagName("input")[0]);
    /* Double linkage */
    ecwSetAttribute(this.input, "ecwCalendar", this);
    /* Desactivation de l'autocompletion du navigateur sur le champ */
    this.input.setAttribute("autocomplete", "off");
    
    //[MA - E370022] recopier si pas d'id
    if(!this.input.id) {
    	this.input.id = this.input.name;
    }
  }
  /* Creation de l'image du calendrier */
  ecwSetAttribute(this, "image", document.createElement("SPAN"));
  addClass(this.image, "ecwImageCalendar");
  /* Double linkage */
  ecwSetAttribute(this.image, "ecwCalendar", this);
  /* L'id de l'image est celui du champ + _img */
  this.image.id = this.input.id + "_img";

  /* Gestion des evenements clavier */
  this.input.onkeydown = OnKey;

  /* Activation onclick sur l'image */
  this.activateImageOnClick();
  
    /* Recuperation du pattern de la date */
  this.pattern = this.noeudDOM.getAttribute("ecwPattern");
  if (!this.pattern) {
	  this.pattern=Calendar._TT["DEF_DATE_FORMAT"];
  }
  
  /* Si 'ecwDisplayPattern' est positionne a 'true', on definit le helpContent. */
  var displayPattern = this.noeudDOM.getAttribute("ecwDisplayPattern");
  if (null != displayPattern && "true" == displayPattern.trim().toLowerCase()) {
    this.input.ecwHelpContent = this.translatePattern(this.pattern);
  }

  var container = this.input.id + "_cal_container";
  /* Creation de la DIV contenant le calendrier */
  this.noeudDOM.appendChild(this.image);

  ecwSetAttribute(this, "cal", document.createElement("DIV"));  
  this.cal.id = container;
  this.cal.style.display = "none";
  this.cal.style.position = "absolute";
  /* Affichage devant les onglets et les listes */
  this.cal.style.zIndex = 100;

  /* Positionnement de la DIV juste en dessous du champ input attache */
  this.noeudDOM.insertBefore(this.cal, this.input);
  this.cal.style.marginTop = this.input.offsetHeight;

  /* Ajout d'un iframe pour parer au bug IE laissant apparaitre */
  /* une liste deroulante (<select>) par dessus une DIV */
  if (ECW_isIE) {
    var iframe = document.createElement("IFRAME");
    /* iframe invisible */
    iframe.style.display = "none";
    ecwSetAttribute(this, "iframe", iframe);
    /* Ajout de l'iframe en tant que premier noeud pour eviter de devoir
     * retrancher la largeur du champ INPUT lors de l'affichage. */
    this.noeudDOM.insertBefore(this.iframe, this.noeudDOM.firstChild);
  }
  /*------------------Modification DATE UTC-----------------------------*/
  //SI UTILISATION DE LA DATE UTC : ecwTimeZone a true
  var attrShowsTime = this.noeudDOM.getAttribute("ecwShowsTime");
  var attrTimeZone = this.noeudDOM.getAttribute("ecwTimeZone");
  if (attrShowsTime == "true" && attrTimeZone == "true") {
  	this.ecwTimeZone=true;
  	//creation d'un champ permettant le stockage de la date au format UTC + fuseau
  	var idInputIso = this.input.id+"_ISO";
  	if (ECW_isIE) {  		
  		ecwSetAttribute(this, "inputISO", document.createElement("<input name='"+idInputIso+"'>"));  		
  	} else {
  		ecwSetAttribute(this, "inputISO", document.createElement("INPUT"));
  		this.inputISO.name=idInputIso;
  	}  	
  	this.inputISO.id=idInputIso;
  	this.inputISO.type="hidden";  
  	this.noeudDOM.appendChild(this.inputISO);  	
  	/*  
	  * plusieurs cas de figure peuvent se produir
	  * 1) le champ date est vide : creation d'une nouvelle date ISO au fuseau UTC (GMT) 
	  * 	je considere la date comme local au poste client 
	  *
	  * 2) le champ date est present :	
	  *		a) la date est au format normal : afficher la date telle quelle et mettre a jour le champ
	  * 		cache date ISO avec le fuseau horaire local du poste client
	  *		b) la date est au format ISO : stocker cette date ISO dans le champ cache Date ISO 
	  * 		puis afficher la date en appliquant le fuseau horaire du poste client
	  * 
	  * FORMAT ISO : The formats are as follows. Exactly the components shown 
	  * here must be present, with exactly this punctuation. Note that the "T" appears 
	  * literally in the string, to indicate the beginning of the time element, 
	  * as specified in ISO 8601.
	  *	  
	  * Complete date plus hours, minutes and seconds:
	  * YYYY-MM-DDThh:mm:ssTZD (eg 1997-07-16T19:20:30+01:00)
	  * 
	  * YYYY = four-digit year
	  *  MM   = two-digit month (01=January, etc.)
	  *  DD   = two-digit day of month (01 through 31)
	  *  hh   = two digits of hour (00 through 23) (am/pm NOT allowed)
	  *  mm   = two digits of minute (00 through 59)
	  *  ss   = two digits of second (00 through 59)  
	  *  TZD  = time zone designator (Z or +hh:mm or -hh:mm)
	  * 
	  * This profile defines two ways of handling time zone offsets:
	  *	
	  *  1. Times are expressed in UTC (Coordinated Universal Time), with a special UTC designator ("Z").
	  *  2. Times are expressed in local time, together with a time zone offset in hours and minutes. 
	  *     A time zone offset of "+hh:mm" indicates that the date/time uses a local 
	  *     time zone which is "hh" hours and "mm" minutes ahead of UTC. A time zone 
	  *     offset of "-hh:mm" indicates that the date/time uses a local time zone which 
	  *     is "hh" hours and "mm" minutes behind UTC. 
	  * 
	  * example
	  * 1994-11-05T08:15:30-05:00 corresponds to November 5, 1994, 8:15:30 am, US Eastern Standard Time.
	  * 1994-11-05T13:15:30Z corresponds to the same instant.
	  * 
	  * Attention a l'heure d'ete / hiver
	  * si heure d'ete alors (pour Paris) GMT +2
	  * si heure d'hiver alors (pour Paris) GMT +1
	  * 
	  * Quelques exemples :
	  * 
	  * 2009-06-24T12:00:00Z = 24/06/2009 12:00:00 UTC mais dans le fuseau local 
	  * (par exemple en France) cela donne la date 24/06/2009 14:00:00
	  *
	  * 2009-06-24T12:00:00+03:00 = 24/06/2009 12:00:00 a Moscou mais dans le fuseau local
	  * (par exemple en France) cela donne la date du 24/06/2009 11:00:00 (heure d'ete)
	  * Explication : 2009-06-24T12:00:00+03:00 correspond a la date UTC + 3
	  * donc la date UTC = 24/06/2009 09:00:00. Cette date sur le fuseau local (poste client)
	  * est 24/06/2009 11:00:00 ( decalage de +2 car nous sommes en heure d'ete)
	  * 
	  * 
	 */	 
	this.setLocaleTimeZone();		
    var currentDateTxt = this.getValue();
    if (currentDateTxt && currentDateTxt!="") {    	
	    if (this.isIsoDate(currentDateTxt)) {
	    	//c'est une date au format ISO => ECW.Calendar.PATTERN_DATE_ISO
	    	//transformer la date en date standard en prenant le fuseau horaire local
	    	this.inputISO.value=currentDateTxt;
	    	var dateLocale = this.convertIsoToDate(this.inputISO.value);
	    	this.input.value = dateLocale.print(this.pattern);	    	
	    } else {
	    	//c'est une date standard, alors je considere que c'est la date avec le fuseau horaire
	    	// local au poste    	
	    	var dateUtc = Date.parseDate(currentDateTxt,this.pattern);	   
	    	var txtDateUtc = dateFormat(dateUtc,'isoUtcDateTime',true);
	    	this.inputISO.value = txtDateUtc;	    		
	    }
    }    
  }
}

/**
 * Initialise les variables concernant la timezone
 * @private
 */
ECW.Calendar.prototype.setLocaleTimeZone = function() {
	var rightNow = new Date();
	var jan1 = new Date(rightNow.getFullYear(), 0, 1, 0, 0, 0, 0);  // jan 1st
	var june1 = new Date(rightNow.getFullYear(), 6, 1, 0, 0, 0, 0); // june 1st
	var temp = jan1.toGMTString();
	var jan2 = new Date(temp.substring(0, temp.lastIndexOf(" ")-1));
	temp = june1.toGMTString();
	var june2 = new Date(temp.substring(0, temp.lastIndexOf(" ")-1));
	var std_time_offset = (jan1 - jan2) / (1000 * 60 * 60);
	var daylight_time_offset = (june1 - june2) / (1000 * 60 * 60);	
	ecwSetAttribute(this, "ecwCalLocalTimeOffset",std_time_offset);   
    ecwSetAttribute(this, "ecwCalStandardTimeOffset",std_time_offset);
    ecwSetAttribute(this, "ecwCalDaylightTimeOffset",daylight_time_offset);	
	if (std_time_offset == daylight_time_offset) {		
		ecwSetAttribute(this, "ecwCalSavingTime",false);// daylight savings time is NOT observed
	} else {
		// positive is southern, negative is northern hemisphere
		var hemisphere = std_time_offset - daylight_time_offset;
		ecwSetAttribute(this, "ecwCalSavingTimeOffset","+"+(-hemisphere));
		if (hemisphere >= 0) {
			std_time_offset = daylight_time_offset;
			ecwSetAttribute(this, "ecwCalSavingTimeOffset",(-hemisphere));
		}
		ecwSetAttribute(this, "ecwCalSavingTime",true); // daylight savings time is observed		
	} 
	ecwSetAttribute(this, "ecwCalCurrentOffset",std_time_offset);
	var idx = findIndexTableTimeZone(this.ecwCalStandardTimeOffset);		
	this.setTitleCalendarImage(messageTimeZone(idx));
}


ECW.Calendar.prototype.translatePattern = function() {
  var specialChar = new Array();
  specialChar["%%"] = "%";
  specialChar["%n"] = "\n";
  specialChar["%t"] = "\t";
  var str = this.pattern;
  var re = /%./g;
  var a = str.match(re);
  for (var i = 0; i < a.length; i++) {
    var tmp = ECW.traduction["calendar_" + a[i]];
    if (!tmp) {
      tmp = specialChar[a[i]];
    }
    if (tmp) {
      re = new RegExp(a[i], 'g');
      str = str.replace(re, tmp);
    }
  }
  return str;
}

/**
 * Actions des touches du clavier
 * @private
 */
ECW.Calendar.prototype.onKey = function(action, event) {

  if (action == "esc") {  	  	
    this.hide();
    return false;
  }
  else if (action == "pageDown") {
    this.show();
  }
  else {
    if (this.isDisplay) {
      /* Gestion des touches clavier assuree par jsCalendar */
      Calendar._keyEvent(event);
    }
  }
}

/**
 * Evenement execute lorsque une date est selectionnee dans le calendrier
 * @param cal (Calendar) Calendrier jsCalendar contenant les parametres
 * @private
 */
ECW.Calendar.prototype.dateChanged = function(cal) {
  /* On met en forme la date selectionnee grace au pattern */
  cal.ECWcalendar.input.value = cal.date.print(cal.ECWcalendar.pattern); 
  if (cal.ECWcalendar.ecwTimeZone) {
  	// Mettre a jour la Date ISO
  	cal.ECWcalendar.updateDateIso();  		  	
  }	
  /* Evenement onSelect() */
  if (cal.ECWcalendar.onSelect) {
    cal.ECWcalendar.onSelect();
  }
}

/**
 * Masque le calendrier
 * @private
 */
ECW.Calendar.prototype.hide = function() {	
  /* On masque la DIV */
  this.cal.style.display = "none";  
  /* On demande a jsCalendar de se masquer (relache les evenements clavier) */  
  if (this.jsCal) {
    this.jsCal.hide();    
  }
  /* Si l'iframe existe (pour IE), on cache l'iframe */
  if (this.iframe) 
    this.iframe.style.display = "none";
  /* On memorise le fait que le calendrier est masque */
  this.isDisplay = false;
}

/**
 * Affiche le calendrier
 * @private
 */
ECW.Calendar.prototype.show = function() {
  /* Creation du calendar uniquement sur demande */
  if (!this.jsCal) {

    /* Affichage de la saisie des heures */
    var paramShowsTime = (this.noeudDOM.getAttribute("ecwShowsTime") == "true");
    var paramTimeZone = (this.noeudDOM.getAttribute("ecwTimeZone") == "true");
	
    /* Creation du calendrier */
    ecwStartTimer("ECW.Calendar.setup");
    Calendar.setup( { flat: this.cal.id, flatCallback: this.dateChanged, ECWcalendar: this, cache: true, showsTime: paramShowsTime, timeZone: paramTimeZone} );
    ecwStopTimer("ECW.Calendar.setup");

    /* Recuperation du calendrier cree par jsCalendar */
    ecwSetAttribute(this, "jsCal", this.cal.firstChild.firstChild.calendar);

    /* Mise du pattern */
    this.jsCal.setDateFormat(this.pattern);

    /* Double linkage */
    ecwSetAttribute(this.jsCal, "ECWcalendar", this);

    /* Permet d'activer la navigation au clavier */
    this.jsCal.isPopup = true;
  }

  /* Positionnement de la date */
  var valueDate = this.input.value;
  if (valueDate) {
   //[MA - E370022] Setting default time value at 12:00:00 (Old value is 00:00:00) 
  //valueDate += " 12:00:00";
  //	var fmt = Calendar._TT["DEF_DATE_FORMAT"] + " %l:%M:%S"; 
    this.jsCal.parseDate(valueDate,this.pattern);
  }

  // on affiche la DIV en dehors de l'ecran pour obtenir ses dimensions
  this.cal.style.display = "block";
  this.cal.style.top = "0px";
  this.cal.style.left = "-2000px";
  /* Afficher le jsCalendar (+ intercepte les evenements clavier) */  
  this.jsCal.show();  
  /* Avant d'afficher le calendrier je regarde s'il sera visible completement dans la page
   ceci en comparant ses positions et ses largeur - hauteur par rapport a la largeur et la hauteur de la page */
  
  var largeurPage = this.ecwLayout.noeudDOM.clientWidth;
  var hauteurPage = this.ecwLayout.noeudDOM.clientHeight;
  var largeurCal = this.jsCal.element.offsetWidth;
  var hauteurCal = this.jsCal.element.offsetHeight;
  var xCal = getAbsolutePos(this.input).x;
  var yCal = getAbsolutePos(this.input).y + this.input.offsetHeight;
  var largeurInput = this.input.offsetWidth;

  // on controle si l'affichage du calendrier tient dans la page, en le placant a droite du champ input
  // si ce n'est pas le cas on le place a gauche du champ    
  if(((xCal + largeurCal)>=largeurPage) && (xCal-largeurCal>0)){
    this.cal.style.marginLeft = - largeurCal + largeurInput;
  }
  // on controle si l'affichage du calendrier tient dans la page, en le placant sous le champ input
  // si ce n'est pas le cas on le place au dessus du champ    
  if(((yCal+hauteurCal)>=hauteurPage) && (yCal-hauteurCal>0)){
    this.cal.style.marginTop = - hauteurCal;
  }
  
  // on annule le positionnement hors-ecran
  this.cal.style.top = "";
  this.cal.style.left = "";

  // on verifie que la table ne sort pas a droite / au dessus du layout
  var posCal = getAbsolutePos(this.jsCal.element);
  var posRoot = getAbsolutePos(this.ecwLayout.noeudDOM);
  if (posCal.y < posRoot.y) {
    this.cal.style.marginTop = this.input.offsetHeight;
  }
  if (posCal.x < posRoot.x) {
    this.cal.style.marginLeft = "";
  }

  /* Si l'iframe existe (pour IE) */
  if (this.iframe) {
    this.iframe.style.height = this.cal.offsetHeight;
    this.iframe.style.width = this.cal.offsetWidth;
    this.iframe.style.marginLeft = this.cal.style.marginLeft;
    this.iframe.style.marginTop = this.cal.style.marginTop;
    this.iframe.style.border = "0";
    this.iframe.style.position = "absolute";
    this.iframe.style.display = "block";
  }

  /* On memorise le fait que le calendrier est affiche */
  this.isDisplay = true;
  //Setter le title de l'icone TimeZone
  if (this.ecwTimeZone) {
  	var idx = findIndexTableTimeZone(this.ecwCalStandardTimeOffset);		
  	this.setTitleTimeZoneImage(messageTimeZone(idx));
  }
}

/**
 * D&eacute;sactive le Calendar et rend le champ disabled
 */
ECW.Calendar.prototype.setDisable = function() {
  /* Ajoute style disable */
  addClass(this.image, "ecwImageDisable");
  
  /* Positionne le champ disable */
  this.input.ecwControl.setDisable();
  
  /* Desactivation onclick sur l'image */
  this.desactivateImageOnClick();
}

/**
 * Active le Calendar et rend le champ saisissable
 */
ECW.Calendar.prototype.setEnable = function() {
  /* Enleve style disable */
  removeClass(this.image, "ecwImageDisable");
  
  /* Positionne le champ enable */
  this.input.ecwControl.setEnable();

  /* Activation onclick sur l'image */
  this.activateImageOnClick();
}

/**
 * Active l'evenement onclick sur l'image du Calendar
 * @private
 */
ECW.Calendar.prototype.activateImageOnClick = function() {
  /* Lors du clic sur l'image */
  /* On bascule l'affichage du calendrier */
  this.image.onclick = ecwCalImageOnClick;
}

/**
 * Methode appelee sur le click sur une image.
 * this reference l'image de l'ECW.Calendar.
 * @private
 */
function ecwCalImageOnClick() {
  if (this.ecwCalendar.isDisplay) {
    this.ecwCalendar.hide();
  } else {
    this.ecwCalendar.show();
  }
  /* On met le focus sur l'input associe */
  this.ecwCalendar.input.ecwControl.setFocus();
}

/**
 * Desactive l'evenement onclick sur l'image du Calendar
 * @private
 */
ECW.Calendar.prototype.desactivateImageOnClick = function() {
  /* onclick */
  this.image.onclick = ecwEmptyFunction;
}

