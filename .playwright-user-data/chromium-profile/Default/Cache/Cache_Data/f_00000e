  //alert("CMA REtour="+ ok +"\nflag="+ (2==ok)+"\necwEvent.target.onkeydownHtml="+ecwEvent.target.onkeydownHtml);
  if (0 == ok) {
    // le caractere est interdit    
    return false;         
  } else {
    // le caractere est autorise
    if (ecwEvent.target.onkeydownHtml) {      
      return (false != ecwEvent.target.onkeydownHtml()) && (2==ok);
    }    
    return (2==ok);
  }
   
};


/**
 * D&eacute;sactive l'aide &agrave; la saisie, c'est &agrave; dire le texte
 * contenu dans le contr&ocirc;le lorsque celui-ci n'est pas renseign&eacute;.
 */
ECW.TimeField.prototype.disableHelpContent = function() {
  if (this.emptyValue == this.input.value) {
    this.input.value = "";
  }
}

/**
 * Active l'aide &agrave; la saisie, c'est &agrave; dire le texte contenu
 * dans le contr&ocirc;le lorsque celui-ci n'est pas renseign&eacute;.
 */
ECW.TimeField.prototype.enableHelpContent = function() {
  if ("" == this.input.value) {
    this.input.value = this.emptyValue;
  }
}

/**
 * Evenement ajoute par ECW permettant de lancer un onchange
 * si le champ de saisie a change 
 * @private
 * @param event l'evenement fourni par le navigateur.
 * @return un booleen : toujours a TRUE et donc propagation des evenements
 */
ECW.TimeField.prototype.onEcwBlur = function(event) {	
	var ecwEvent = new ECW.Event(event);
	var noeudDOM = ecwEvent.target.parentNode;		
	if (noeudDOM.ecwTimeField.changeFlag) {
    	noeudDOM.ecwTimeField.changeFlag=false;    	
    	if (noeudDOM.ecwTimeField.input.onchange) noeudDOM.ecwTimeField.input.onchange();
    }
    if (noeudDOM.ecwTimeField.input.onblurHtml) noeudDOM.ecwTimeField.input.onblurHtml();
	return true;
}


