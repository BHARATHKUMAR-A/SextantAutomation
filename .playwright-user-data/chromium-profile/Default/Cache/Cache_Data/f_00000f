/**
 * Refresh de la popup.
 * @param popup Popup.
 * @type PopupWindow.
 * @private
 */
ECW.PopupManager.prototype.refreshPopup = function(popup) {
  var url = popup.url;
  var param = popup.param;
  this.closePopup(popup);
  openPopup(url, param);
}

/**
 * Test si une popup porte l'id.
 * @param id Identifiant.
 * @type String.
 * @private
 */
ECW.PopupManager.prototype.existPopup = function(id) {
  if (this.popupList.length > 0) {
    for (var i = 0; i < this.popupList.length; i++) {
      var lastPopup = this.popupList[i];
      if (lastPopup.id == id) {
        return true;
      }
    }
  }
  return false;
}

/**
 * Retourne la popup correspondant a l'id.
 * @param id Identifiant.
 * @type String.
 * @return popup ou null
 * @private
 */
ECW.PopupManager.prototype.getPopup = function(id) {
  if (this.popupList.length > 0) {
    for (var i = 0; i < this.popupList.length; i++) {
      var lastPopup = this.popupList[i];
      if (lastPopup.id == id) {
        return lastPopup;
      }
    }
  }
  return null;
}


