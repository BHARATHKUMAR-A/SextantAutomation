/**
 * Classe pour g&eacute;rer la couche sous la bo&icirc;te de dialogue
 * afin pour capter les &eacute;v&egrave;nements souris
 * @param boolean indiquant s'il s'agit d'un calque pour popup en plein ecran
 * @return Un nouvel objet UnderLay
 * @private
 */
ECW.UnderLayPopup = function(fullScreen) {

  var className = "ecwUnderLayPopup";
  if (fullScreen) {
    className = "ecwUnderLayPopupFullScreen";
  }

  if (ECW_isIE) {
    /* Creation IFRAME pour masquer les selects */
    this.underLayIFRAME = document.createElement("IFRAME");
    /* Peretre de rendre le focus au champ actif si l'utilisateur focus l'IFRAME */
    this.underLayIFRAME.className = className;
    /* Insertion du noeud dans le DOM du document */
    document.body.appendChild(this.underLayIFRAME);
  }
  /* creation d'un DIV */
  this.underLayDIV = document.createElement("DIV");

  /* Permettre de rendre le focus au champ actif si l'utilisateur clic dans l'underlay */
  this.underLayDIV.onmouseup = function() {
    if (ecwActiveUI && ecwActiveUI.champActif) {
      ecwActiveUI.champActif.setFocus();
    }
  }

  this.underLayDIV.className = className;
  /* Insertion du noeud dans le DOM du document */
  document.body.appendChild(this.underLayDIV);

}

/**
 * Force la hauteur de la zone griser a la hauteur totale
 * (en comptant la zone de scroll)
 * @private
 */
ECW.UnderLayPopup.prototype.forceHeight = function(flagWait) {	
	var iebody=(document.compatMode && document.compatMode != "BackCompat")? document.documentElement : document.body
	var hClient=iebody.clientHeight;
	var offsetHClient = (document.all)?iebody.scrollHeight:iebody.offsetHeight;
	var pourcentH = Math.ceil(((offsetHClient / hClient)*100));
	var posBottom = -(offsetHClient - hClient);	
	pourcentH = (pourcentH<110)?110:pourcentH;	//110 minimum comme dans la CSS 	
	posBottom = (posBottom>0)?0:posBottom;	//0 minimum comme dans la CSS 		
 	if (this.underLayIFRAME) {    	
    	this.underLayIFRAME.style.bottom = posBottom + "px";	
	    this.underLayIFRAME.style.height = pourcentH + "%";
  	}
  	if (this.underLayDIV) {
		//[MA-E370022] add scroll event
		//Jira [SIFAECW-667] Possibilit� de cliquer sur un bouton derri�re le popup
		//this.underLayDIV.style.bottom = posBottom + "px";	
		//this.underLayDIV.style.height = pourcentH + "%";
		this.underLayDIV.style.left = 0;
		this.underLayDIV.style.top = 0;	
		this.underLayDIV.style.height = iebody.scrollHeight;
		this.underLayDIV.style.width = iebody.scrollWidth;
  	}
  	 /* si flagWait est a true alors afficher un sablier sur l'ecran */
  	//if (flagWait) this.underLayDIV.className="ecwUnderLayPopupWait";  	
}

/**
 * Affiche la sous couche
 * @private
 */
ECW.UnderLayPopup.prototype.show = function() {
  if (this.underLayIFRAME) {
    this.underLayIFRAME.style.display = "";
  }
  if (this.underLayDIV) {
    this.underLayDIV.style.display = "";
  }
}

/**
 * Masque la sous couche
 * @private
 */
ECW.UnderLayPopup.prototype.hide = function() {
  if (this.underLayIFRAME) {
    this.underLayIFRAME.style.display = "none";
  }
  if (this.underLayDIV) {
    this.underLayDIV.style.display = "none";
  }
}

/**
 * @private
 */
ECW.UnderLayPopup.prototype.setIndex = function(newIndex) {
  if (this.underLayIFRAME) {
    this.underLayIFRAME.style.zIndex = newIndex;
  }
  if (this.underLayDIV) {
    this.underLayDIV.style.zIndex = newIndex;
  }
}

