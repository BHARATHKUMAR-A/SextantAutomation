/** 
 * active le recentrage auto de toutes les popups dans la fenetre 
 * @private
 */
ECW.PopupManager.prototype.initResizeWindow = function() {
  ecwActivePopupManager.onresizeOld = window.onresize;
  window.onresize = function() {
    if (ecwActivePopupManager) {
      ecwActivePopupManager.resizePopups();
    }
    if (ecwActivePopupManager.onresizeOld) {
      ecwActivePopupManager.onresizeOld();
    }
  }
  
  //[MA-E370022] add scroll event
  //Jira [SIFAECW-667] Possibilit� de cliquer sur un bouton derri�re le popup
  window.onscroll = function() {
    if (ecwActivePopupManager) {
      ecwActivePopupManager.resizePopups();
    }
    if (ecwActivePopupManager.onresizeOld) {
      ecwActivePopupManager.onresizeOld();
    }
  }
}

/** 
 * active le recentrage auto de toutes les popups dans la fenetre 
 * @private
 */
ECW.PopupManager.prototype.resizePopups = function() {
  for (var p = 0; p < ecwActivePopupManager.popupList.length; p++) {
    ecwActivePopupManager.popupList[p].setPosition();
  }
  //Resize de la zone grise  
  ecwActivePopupManager.setFullHeightUnderLay();
}

/** 
 * active le recentrage auto de toutes les popups dans la fenetre 
 * @private
 */
ECW.PopupManager.prototype.resizePopup = function() {
  if (ecwActivePopupManager) {
    p = ecwActivePopupManager.popupList.length - 1;
    ecwActivePopupManager.popupList[p].setPosition();
  }
}

/** 
 * Place la popup au niveau zindex le plus haut.
 * @param popup Popup.
 * @type PopupWindow.
 * @private
 */
ECW.PopupManager.prototype.setOnTop = function(popup) {

  // mettre le popup a afficher au bon niveau d'index / index
  newZindex = 100+(popup.index * 2);
  popup.popupNode.style.zIndex = newZindex;
  if (popup.fullScreen) {
    this.underLayFullScreen.setIndex(newZindex - 1);
  } else {
    this.underLayPopup.setIndex(newZindex - 1);
  }
}

/** 
 * Affiche le calque correspondant a la popup.
 * @param popup Popup.
 * @private.
 */
ECW.PopupManager.prototype.showUnderlay = function(popup) {
  if (popup.fullScreen) {
    this.underLayFullScreen.show();
  } else {
    this.underLayPopup.show();
  }
}

/** 
 * Masque le calque correspondant a la popup.
 * @param popup Popup.
 * @private.
 */
ECW.PopupManager.prototype.hideUnderlay = function(popup) {
  if (popup.fullScreen) {
    this.underLayFullScreen.hide();
  } else {
    this.underLayPopup.hide();
  }
}

/** 
 * Lors de la fermeture d'un popup fullscreen, il faut replacer le calque blanc en dessous de la derniere popup fullScreen.
 * @param popup Popup.
 * @private.
 */
ECW.PopupManager.prototype.repositionUnderlayFullScreen = function() {
  var size = this.popupList.length;
  if (size > 0) {
    for (var i = size - 1; i >= 0; i--) {
      var popup = this.popupList[i];
      if (popup.fullScreen) {
        this.underLayFullScreen.setIndex(popup.popupNode.style.zIndex - 1);
        this.underLayFullScreen.show();
      }
    }
  }
}

/** 
 * @private.
 */
ECW.PopupManager.prototype.activateHistory = function() {
  // initialise HistoryBar
  this.historyNode = document.createElement("div");
  this.historyNode.className = "ecwHistoryBar";
  document.body.appendChild(this.historyNode);
  this.refreshHistory();
}

/** 
 * @private.
 */
ECW.PopupManager.prototype.refreshHistory = function() {
  if (this.historyNode) {
    var myHistory = "<a href='#' onclick='ecwClosePopupsTo()'> " + ecw.I18N.get("MENU") + "</a>";
    for (var p = 0; p < this.popupList.length; p++) {
      myHistory += " > <a href='#' onclick='ecwClosePopupsTo(\"" + this.popupList[p].id + "\")'>" + this.popupList[p].getTitle() + "</a>";
    }
    this.historyNode.innerHTML = myHistory;
  }
}


