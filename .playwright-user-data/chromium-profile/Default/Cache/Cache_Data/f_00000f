/** 
 * @private.
 */
ECW.PopupManager.prototype.logOpenPopupHTML = function() {
  return ; // desactivation des log
  var newBR = document.createElement("BR");
  document.body.appendChild(newBR);
  var newB = document.createElement("b");
  var openPopupDelay = (timeStampEndOpenPopup - timeStampOpenPopup);

  var requestDelay = (timeStampEndRequest - timeStampStartRequest);
  var createPopupDelay = (timeStampEndCreatePopup - timeStampStartCreatePopup);
  var loadDelay = (timeStampEndLoad - timeStampStartLoad);

  var ecwDelay = (timeStampEndECW - timeStampStartECW);
  var centerDelay = (timeStampEndCenter - timeStampStartCenter);
  var scriptDelay = (timeStampEndScript - timeStampStartScript);
  var resteDelay = (timeStampEndOpenPopup - timeStampStartReste);

  var monHTML = "openPopup:" + openPopupDelay + " = request:" + requestDelay + " + loadHTML:" + loadDelay;
  monHTML += " + createPopup:" + createPopupDelay + " + ecw:" + ecwDelay + " + script:" + scriptDelay + " + center:" + centerDelay + " + reste:" + resteDelay;
  var sumDelay = (requestDelay + loadDelay + createPopupDelay + ecwDelay +  scriptDelay + centerDelay + resteDelay);
  monHTML += " = " + sumDelay;
  monHTML += " /// " + (openPopupDelay - sumDelay)


  newB.innerHTML = monHTML;
  document.body.appendChild(newB);
}

