/**
 * ecwGetTimeStamp : Retourne le nombre de milliemes de secondes ecoulees entre le 1/1/1970 0:00:00 et la date courante
 * @private
 */
function ecwGetTimeStamp() {
  return (new Date()).getTime();
}

/**
 * ecwGetFormValues : generer les parametres encodes (escape) a partir d'un form 
 * @param formElement Formulaire a traiter.
 */
function ecwGetFormValues(formElement) {
  var stringResult = "";
  var valueArr = null;
  var val = "";
  var cmd = "";
  var elts = formElement.elements;
  for (var i = 0; i < formElement.elements.length; i++) {
    var element = formElement.elements[i];
    switch (element.type) {
      case "hidden":
      case "text":
      case "textarea":
        stringResult += ecwGetParamInput(element);
        break;
      case "checkbox":
      case "radio":
        if (element.checked) {
          stringResult += ecwGetParamInput(element);
        }
        break;
      case "select-one":
        if (element.selectedIndex !=  - 1) {
          stringResult += ecwGetParamSelect(element, element.selectedIndex);
        }
        break;
      case "select-multiple":
        for (var j = 0; j < element.options.length; j++) {
          if (element.options[j].selected) {
            stringResult += ecwGetParamSelect(element, j);
          }
        }
        break;
    }
  }
  // supprime le dernier &
  stringResult = stringResult.substr(0, (stringResult.length - 1));
  return stringResult;
}

/**
 * ecwGetParamInput : genere le parametre encode (escape) a partir d'un element
 * @param element Element du dom de type textarea ou radio
 * @private
 */
function ecwGetParamInput(element) {
  return ecwGetNameValueEscaped(element.name, element.value);
}

/**
 * ecwGetParamSelect : genere le parametre encode (escape) a partir d'un element
 * @param element Element du dom de type select ou select-multiple
 * @private
 */
function ecwGetParamSelect(element, index) {
  return ecwGetNameValueEscaped(element.name, element.options[index].value);
}

/**
 * ecwGetNameValueEscaped : pour gerer les caracteres speciaux et le cas du + non echape
 * @param name Name de l'element
 * @param value Value de l'element
 * @private
 */
function ecwGetNameValueEscaped(name, value) {
  return name + "=" + escape(value).replace(new RegExp("\\+", "g"), "%2B") + "&";
}
