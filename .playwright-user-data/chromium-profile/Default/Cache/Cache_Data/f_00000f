 */
ECW.PopupManager.prototype.setFullHeightUnderLay = function(flagWait) {	
	this.underLayPopup.forceHeight(flagWait);
}

/**
 * Affichage de la fenetre d'attente lors du chargement.
 * @private
 */
ECW.PopupManager.prototype.createLoadingPopup = function() {
  this.loadingNode = document.createElement("div");
  this.loadingNode.id = "ecwLoadingPopup";
  this.loadingNode.style.display = "none";
  this.loadingNode.innerHTML = "<table><tr><td><div class='wait'>&nbsp;</div></td><td></td></tr></table>";
  document.body.appendChild(this.loadingNode);
}

/**
 * Ouverture d'une popup en postant les donnees du formulaires.
 * @param url Url.
 * @type String
 * @private
 */
ECW.PopupManager.prototype.openPopupSubmit = function(url, fullScreen) {

  // TODO : a revoir (form du popup)
  //  if (url!=null)   document.forms[0].action=url;
  //   url = document.forms[0].action;
  if (!url) {
    url = document.forms[0].action;
  }
  var param = ecwGetFormValues(document.forms[0]);
  this.openPopup(url, param, fullScreen);
}

/**
 * Ouverture d'une popup avec pour URL l'attribut action du formulaire.
 * @param form Formulaire.
 * @type Form
 * @private
 */
ECW.PopupManager.prototype.openPopupForm = function(form, fullScreen) {
  var url = form.getAttribute('action');
  var param = ecwGetFormValues(form);
  this.openPopup(url, param, fullScreen);
}

/**
 * Ouverture d'une popup a partir de l'url et des params.
 * @param url Url.
 * @type String
 * @param param Formulaire.
 * @type String
 * @private
 */
ECW.PopupManager.prototype.openPopup = function(url, param, fullScreen) {
  
  // Les popups géres leurs propre desactivation d'IHM (ihm grisée en dessous) 
  //dans ce cas on doit rendre inactive la desactivation auto des IHM
  // Desactivation des accesskey sur la boite de dialogue [SIFAECW-680]
  if ( window.ecwActiveUI && ecwAutoDisableIHM) {
    window.ecwActiveUI.enableIHM();
  }
  
  // mise en blanc dans param si inexistant
  if (!param) {
    param = "";
  }

  // affichage d'une log d'ouverture de popup
  this.logRequest(url, param);

  // affiche la popup d'attente
  $("#ecwLoadingPopup").show();

  // requete AJAX asynchrone avec jquery
  window.ajaxRequest = $.ajax({
    type: "POST",
    url: url,
    data: param,
    complete: function() {
      window.timeStampEndRequest = ecwGetTimeStamp();
      $("#ecwLoadingPopup").hide(); 
    },
    success: function(resultAJAX) {
      if (resultAJAX.indexOf("ltp/error.jsp") > 0) {
        ecwActivePopupManager.alertPopup(resultAJAX); 
      } else {
        ecwActivePopupManager.openPopupHTML(resultAJAX,null,fullScreen); 
      }
    },
    error: function(request, error) {
      window.ecwResponseText = request.responseText;
      ecwOpenPopupHTML(ecw.I18N.get("actionNotExist") + "<br><br><a href='javascript:void(0);' onclick='window.ecwActivePM.errorPopup(window.ecwResponseText)'>" + ecw.I18N.get("actionNotExistServerResponse") + " </a>", null); 
    }
  }
  );
}

/**
 * Affiche dans un popup un flux HTML.
 * @param html Flux HTML.
 * @type String
 * @param id Identifiant.
 * @type String
 * @private
 */
ECW.PopupManager.prototype.openPopupHTML = function(html, id, fullScreen) {
  
  
  // Les popups géres leurs propre desactivation d'IHM (ihm grisée en dessous) 
  //dans ce cas on doit rendre inactive la desactivation auto des IHM
  // Desactivation des accesskey sur la boite de dialogue [SIFAECW-680]
  if ( window.ecwActiveUI && ecwAutoDisableIHM && id!=ecwIdPopupBlockIHM) {
    window.ecwActiveUI.enableIHM();
  }
  
  if (window.ecwActiveUI) {
    window.ecwActiveUI.desactiveAccessKey();
  }

  // Desactivation d'eventuels popups 
  if (this.popupList.length > 0) {
    //this.popupList[this.popupList.length-1].popupNode.className="ecwWindowPopup off";
    this.popupList[this.popupList.length - 1].blur();
  }

  // et desactivation du champ ecw actif
  if (window.ecwActiveUI && window.ecwActiveUI.champActif) {
    window.ecwActiveUI.champActif.desactiver();
  }

  // nouvelle definition de popup
  var newIndex = this.popupList.length;
  if (!id) {
    id = "ecwPopup" + newIndex;
  }
  var maPopup = new ECW.PopupWindow(id, fullScreen);
  maPopup.index = newIndex;
  this.popupList.push(maPopup);
  this.ecwActivePopup = maPopup;
  this.setOnTop(maPopup);
  this.showUnderlay(maPopup);
  //window.onerror=null;

  popupInit = null;

  ecwActivePopup = this.ecwActivePopup;
  // insere le code HTML dans le corps de la popup
  ecwActivePopup.setBody(html);

  ecwActivePopup.UI = new ECW.UI(ecwActivePopup.id);
  ecwActivePopup.UI.activeAccessKey(ecwActivePopup.id);
  ecwActivePopup.UI.popup = this.ecwActivePopup;
  ecwActivePopup.UI.onEscape = function() {
    this.popup.close();
  }

  // evaluation des scripts apres chargement ECW
  ecwEvalScript(ecwActivePopup.bodyNode);

  ecwActivePopup.event = {};

  //if (popupInit && popupInit!=null) popupInit(this.ecwActivePopup);
  if (ecwActivePopup.onActivate) {
    ecwActivePopup.onActivate();
  }

  // positionner la popup au center de la fenetre
  this.ecwActivePopup.setPosition();

  if (!fullScreen) {
    // activer le drag de la popup sur le titre d'une balise uiTitle
    var premiereTable = ecwActivePopup.bodyNode.getElementsByTagName("TABLE")[0];
    if (premiereTable && premiereTable.className == "ecwBackgroundIhm") {
      ecwDrag.init(premiereTable.getElementsByTagName("TD")[0], ecwActivePopup.popupNode);
    }

    // activer le drag & drop du popup sur le premier div de class ecwTitlePopup
    var premiereDiv = ecwActivePopup.bodyNode.getElementsByTagName("div")[0];
    if (premiereDiv && premiereDiv.className == "ecwTitlePopup") {
      ecwDrag.init(premiereDiv, ecwActivePopup.popupNode);
    }
  }

  $("#" + ecwActivePopup.id).show();
}

/**
