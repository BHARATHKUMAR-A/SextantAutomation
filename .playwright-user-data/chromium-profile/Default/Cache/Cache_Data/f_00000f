/**
 * Constructeur.
 * @private
 */
ECW.PopupManager = function() {

  ecwSetAttribute(this, "loadingNode", null);
  ecwSetAttribute(this, "popupList", null);
  ecwSetAttribute(this, "ecwActivePopup", null);
  ecwSetAttribute(this, "popup", null);
  ecwSetAttribute(this, "ecwBeforeActiveUI", null);
  ecwSetAttribute(this, "historyNode", null);
  ecwSetAttribute(this, "ecwBeforeActiveUI", null);
  //instance active du gestionnaire de popup
  ecwSetAttribute(window, "ecwActivePopupManager", this);
  // tableau des popups charges
  ecwSetAttribute(this, "popupList", new Array);

  // creation  de la div loading
  this.createLoadingPopup();


  // activation du recentrage des popups dans la fenetre au changement de taille de la fenetre
  this.initResizeWindow();

  // sauvergarde l'environnement ECW
  ecwSetAttribute(this, "ecwBeforeActiveUI", null);
  if (window.ecwActiveUI) {
    this.ecwBeforeActiveUI = window.ecwActiveUI;
  }
  // gestion de l'historique : a preciser
  //this.activateHistory();

  // creation des calques pour griser le popup precedent et interdire l'acces a la souris
  ecwSetAttribute(this, "underLayPopup", new ECW.UnderLayPopup(false));
  this.underLayPopup.hide();
  ecwSetAttribute(this, "underLayFullScreen", new ECW.UnderLayPopup(true));
  this.underLayFullScreen.hide();

  if (ECW_isIE) {
    setTimeout("ecwActiveUI.setMessage('','');ecwActiveUI.clearMessage();", 0);
  }
}

/**
 * Redimensionnement de la zone griser
 * Delegue le redimensionnement de la zone griser a l'objet underLayPopup
