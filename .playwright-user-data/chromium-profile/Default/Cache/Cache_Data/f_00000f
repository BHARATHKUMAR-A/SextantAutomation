/**
 * Abandon de la requete en cours et supression du claque de chargement.
 * @private
 */
abortRequest = function() {
  $("#ecwLoadingPopup").hide();
  if (window.ajaxRequest) {
    window.ajaxRequest.abort();
  }
}

/**
 * Fermeture de la derniere popup 
 * -> qui ne doit pas être une popup de desactivation ! 
 * @param update ???
 * @type ???
 * @private
 */
ECW.PopupManager.prototype.close = function(update) {
  // si il n'existe encore un popup d'afficher
  if (ecwAutoDisableIHM) {  
     this.closeDesactivationsPopup(update);
  }
  if (this.popupList.length > 0) {
    var lastPopup = this.popupList[this.popupList.length - 1];
    this.closePopup(lastPopup, update);
  }
}

ECW.PopupManager.prototype.closeDesactivationsPopup = function(update) {
  // si il n'existe encore un popup d'afficher
  if (this.popupList.length > 0) {
    var lastPopup = this.popupList[this.popupList.length - 1];
    //remove all desactivation popup in the top of stack if needed
    while (this.popupList.length >0 && lastPopup.id == ecwIdPopupBlockIHM ) {
      this.closePopup(lastPopup, update);
      if (this.popupList.length >0) {
        lastPopup = this.popupList[this.popupList.length - 1];
      } 
    }
  }
}


/**
 * Fermeture de toutes les popup.
 * @private
 */
ECW.PopupManager.prototype.closeAllPopup = function() {
  while (this.popupList.length > 0) {
    this.closePopup(this.popupList[this.popupList.length - 1]);
  }
}

/**
 * Fermeture des popup jusque la popup id non incluse.
 * @param id Identifiant.
 * @type String.
 * @private
 */
ECW.PopupManager.prototype.closePopupsTo = function(id) {
  if (this.popupList.length > 0) {
    var lastPopup = this.popupList[this.popupList.length - 1];
    if (lastPopup.id != id) {
      this.closePopup(lastPopup);
      this.closePopupsTo(id);
    }
  }
}

/**
 * Fermeture de la popup et appel de la methode onReturnSubmit de la popup active.
 * @private
 */
ECW.PopupManager.prototype.closePopupSubmit = function() {
  var url = document.forms[0].action;
  var param = ecwGetFormValues(document.forms[0]);
  var form = document.forms[0].cloneNode(true);
  this.close();
  var ecwActivePopup = this.popupList[this.popupList.length - 1];
  if (ecwActivePopup && ecwActivePopup.onReturnSubmit) {
    ecwActivePopup.onReturnSubmit(url, param, form);
  }
}

/**
 * Fermeture de la popup.
 * @param popup Popup.
 * @type PopupWindo.
 * @param event Event.
 * @type event.
 * @private
 */
ECW.PopupManager.prototype.closePopup = function(popup, event) {

  abortRequest();

  document.body.removeChild(popup.popupNode);
  this.popupList.pop();
  this.hideUnderlay(popup);

  // a revoir
  //this.refreshHistory();
  var idActivePopup = null;
  if (this.popupList.length > 0) {
    // reactive l'ancien popup (avec ECW)
    ecwActivePopup = this.popupList[this.popupList.length - 1];
    idActivePopup = ecwActivePopup.id;
    ecwActiveUI = ecwActivePopup.UI;
    if (ecwActiveUI) {
      if (ecwActiveUI.champActif) {
        ecwActiveUI.champActif.activer();
        ecwActiveUI.champActif.setFocus();
        // pour preselectionner la zone
        if (ecwActiveUI.champActif.noeudDOM.select) {
          ecwActiveUI.champActif.noeudDOM.select();
        }
      }
    }
    // donne le focus actif a la popup
    ecwActivePopup.focus();
    this.setOnTop(ecwActivePopup);
    this.showUnderlay(ecwActivePopup);

    if (event) {
      ecwActivePopup.event = event;
    } else {
      ecwActivePopup.event = {};
    }

    if (ecwActivePopup.onActivate) {
      ecwActivePopup.onActivate();
    }
    ecwActivePopup.event = {};
    this.ecwActivePopup = ecwActivePopup;
  } else {
    if (this.ecwBeforeActiveUI) {
      ecwActiveUI = this.ecwBeforeActiveUI;
      if (ecwActiveUI.champActif) {
        ecwActiveUI.champActif.activer();
        if (ECW_isIE) {
          setTimeout("ecwActiveUI.champActif.setFocus();",0);
        } else {
          ecwActiveUI.champActif.setFocus();
        }
        
      }
    }
    if (window.onCloseLastPopup) {
      window.onCloseLastPopup(event);
    }
    this.ecwActivePopup = null;
  }
  if (ecwActiveUI && ecwActiveUI.ecwAccessKey) {
    /* Activation des accesskey sur la UI principale */
    ecwActiveUI.activeAccessKey(idActivePopup);
  }

  if (popup.fullScreen) {
    this.repositionUnderlayFullScreen();
  }

}

