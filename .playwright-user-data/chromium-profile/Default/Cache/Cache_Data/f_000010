}

/**
 * Deplacement vers le premier champ focussable de la ligne courante.
 * @private
 */
ECW.Grid.prototype.moveFirst = function() {
  var firstField = null;
  var rows = this.getRows();  
  var cell = rows[0].firstChild;
  while (cell) {
    //if (cell.nodeType==1 && this.isTabbed(cell) ){
    if (cell.nodeType==1 && this.isTabbed(cell) && cell.style.display!="none"){
        firstField = this.getField(cell);
    }
    if(firstField != null){
      break;
    }
    cell = cell.nextSibling;
  }
  
  if(firstField){
    this.setFocus(cell);
  } else {
    this.moveDown(cell);
  }
}

/**
 * Desactive le grid : passe la ligne de l'etat selectionne actif a l'etat selectionne non-actif.
 * @private
 */
ECW.Grid.prototype.desactiver = function() {
  //alert('ECW.Grid.prototype.desactiver');
  removeClass(this.noeudDOM, "ecwGridActive");
  this.focused = false;
  /* Si selection d'une ligne */
  if (this.getCurrentRow() && !isClass(this.getCurrentRow(), "ecwGridLineEmpty")) {
    //removeClass(this.getCurrentRow(), "ecwGridLineActive");
    //addClass(this.getCurrentRow(), "ecwGridLineSelect");
    $(this.getCurrentRow()).removeClass("ecwGridLineActive");
    $('td',this.getCurrentRow()).removeClass("ecwGridLineActive");
    $(this.getCurrentRow()).addClass("ecwGridLineSelect");    
    if (this.getCurrentCell()) {
      //removeClass(this.getCurrentCell(), "ecwGridCellActive");
      //addClass(this.getCurrentCell(), "ecwGridCellSelect");
      $(this.getCurrentCell()).removeClass("ecwGridCellActive");
      $(this.getCurrentCell()).addClass("ecwGridCellSelect");
    }
  }
}

/**
 * Active le grid : passe la ligne de l'etat selectionne non-actif a l'etat selectionne actif.
 * @private
 */
ECW.Grid.prototype.activer = function() {
  addClass(this.noeudDOM, "ecwGridActive");  
  if (this.getCurrentRow() && !isClass(this.getCurrentRow(), "ecwGridLineEmpty")) {  	
    //removeClass(this.getCurrentRow(), "ecwGridLineSelect");
    //addClass(this.getCurrentRow(), "ecwGridLineActive");    
    $(this.getCurrentRow()).removeClass("ecwGridLineSelect");
    $(this.getCurrentRow()).addClass("ecwGridLineActive");
    if (this.getCurrentCell()) {
      //removeClass(this.getCurrentCell(), "ecwGridCellSelect");
      //addClass(this.getCurrentCell(), "ecwGridCellActive");
      $(this.getCurrentCell()).removeClass("ecwGridCellSelect");
      $(this.getCurrentCell()).addClass("ecwGridCellActive");
      this.setFocus(this.getCurrentField());
    }
  } else {
    /* Lignes presentes */
    if (this.lignes && this.lignes.length > 0) {
      this.selectRow(0);
    }
  }

  if (this.getCurrentRow()) {
    this.showLine(this.getCurrentRow());
  }
}

