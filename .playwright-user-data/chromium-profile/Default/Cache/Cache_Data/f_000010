/**
 * Focus sur une cellule donnee.
 * @param TD
 * @private
 */
ECW.Grid.prototype.setFocus = function(cell) {
  var field = null;
  if (cell.tagName == "TD") {
    field = this.getField(cell);
  }
  if (field) {
    field.ecwGridField.focusAndSelect();
  }
}

/**
 * Deplacement vers la cellule de gauche.
 * @param TD
 * @private
 */
ECW.Grid.prototype.moveLeft = function(cell) {
  var newCell = this.searchLeft(cell);
  var field = this.getField(newCell);
  if (field) {
    field.ecwGridField.focusAndSelect();
  }
}

/**
 * Deplacement vers la cellule de droite.
 * @param TD
 * @private
 */
ECW.Grid.prototype.moveRight = function(cell) {
  var newCell = this.searchRight(cell);
  var field = this.getField(newCell);
  if (field && this.isTabbed(newCell)) {
    field.ecwGridField.focusAndSelect();
  }
}

/**
 * Deplacement vers la cellule du dessus.
 * @param TD
 * @private
 */
ECW.Grid.prototype.moveUp = function(cell) {
  var newCell = this.searchUp(cell);
  var field = this.getField(newCell);
  if (field) {
    field.ecwGridField.focusAndSelect();
  }
}

/**
 * Deplacement vers la cellule du dessous.
 * @param TD
 * @private
 */
ECW.Grid.prototype.moveDown = function(cell) {
  var newCell = this.searchDown(cell);  
  var field = this.getField(newCell);  
  if (field.ecwGridField.isHidden) {
  	//Ne pas selectionner un champ cache
  	var fields = newCell.parentNode.cells;
    for (var i=0;i<fields.length;i++){
    	var display = fields[i].style.display;      	
   		if  (!(display && display=="none")) {   			   			
   			 field = this.getField(fields[i]);  			 
   			 break;
   		}
    }
  }  
  if (field) {  	
    field.ecwGridField.focusAndSelect();
  }
}

/**
 * Recherche la cellule de gauche pouvant etre saisie.
 * @param TD
 * @private
 */
ECW.Grid.prototype.searchLeft = function(cell) {
  var currentRow = cell.parentNode;
  this.checkNodeStructure(currentRow, "tr", "ECW.Grid.prototype.searchLeft", "[7]: Impossible de trouver la ligne de la cellule courante.");

  /* Recherche de la cellule precedente dans la ligne */
  var trouve = false;
  var newCell = cell;
  while (!trouve) {
    /* si debut de ligne, allez a la fin. */
    /* todo : attention au #texte sous mozilla */
    /* c'est pour ca qu'on test pas l'existance d'un precedent mais l'index de la cellule */
    var cellIndex = newCell.cellIndex;    
    if (cellIndex != 0) {
      if (ECW_isIE) {
  	  	cellIndex = newCell.ecwcolindex * 1;
  	  }
  	  //Test si le champ precedent est cache
  	  var tmpPrevCell = cell.parentNode.cells[cellIndex - 1];
      var isHidden = (tmpPrevCell.style.display=="none")?true:false;
      if (isHidden) {
      	trouve = true;
      	break;
      }
      newCell = tmpPrevCell; //cell.parentNode.cells[cellIndex - 1];
      this.checkNodeStructure(newCell, "td", "ECW.Grid.prototype.searchLeft", "[8]: Impossible de trouver la cellule suivante !");
      trouve = this.isTabbed(newCell);
    } else {
      trouve = true;
    }
  }
  return newCell;
}

/**
 * Recherche la cellule de droite pouvant etre saisie.
 * @param TD
 * @private
 */
ECW.Grid.prototype.searchRight = function(cell) {
  var currentRow = cell.parentNode;
  this.checkNodeStructure(currentRow, "tr", "ECW.Grid.prototype.searchRight", "[9]: Impossible de trouver la ligne de la cellule courante!");
  //Recherche de la cellule suivante dans la ligne
  var trouve = false;
  var newCell = cell;
  while (!trouve) {
    var cellIndex = newCell.cellIndex;
    if (ECW_isIE) {
  	  	cellIndex = newCell.ecwcolindex * 1;
  	}
    if (cellIndex != this.getMaxCellIndex()) {
    	//Test si le champ suivant est cache on est sur le dernier champ visible
  	  	var tmpNextCell = cell.parentNode.cells[cellIndex + 1];
      	var isHidden = (tmpNextCell.style.display=="none")?true:false;
      	if (isHidden) {
      		trouve = true;
      		break;
      	}
      newCell = cell.parentNode.cells[cellIndex + 1]; 
      this.checkNodeStructure(newCell, "td", "ECW.Grid.prototype.searchRight", "[10]: Impossible de trouver la cellule suivante !");
      trouve = this.isTabbed(newCell);      
    } else {
      trouve = true;
    }
  }
  return newCell;
}

/**
 * Recherche la cellule du dessus pouvant etre saisie.
 * @param TD
 * @private
 */
ECW.Grid.prototype.searchUp = function(cell) {
  var currentRow = cell.parentNode;
  this.checkNodeStructure(currentRow, "tr", "ECW.Grid.prototype.searchUp", "[11]: Impossible de trouver la ligne de la cellule courante !");

  var newCell = cell;
  var rowIndex = currentRow.rowIndex;
  if (rowIndex != 0) {
  	var indexCol = cell.cellIndex;  
  	if (ECW_isIE) {  		
  		indexCol = cell.ecwcolindex * 1;
  	}
    newCell = currentRow.parentNode.rows[rowIndex - 1].cells[indexCol];
  } else {
    newCell = cell;
  }
  this.checkNodeStructure(newCell, "td", "ECW.Grid.prototype.searchUp", "[12]: Impossible de trouver la cellule suivante !");
  return newCell;
}

/**
 * Recherche la cellule du dessous pouvant etre saisie.
 * @param TD
 * @private
 */
ECW.Grid.prototype.searchDown = function(cell) {
  var currentRow = cell.parentNode;
  this.checkNodeStructure(currentRow, "tr", "ECW.Grid.prototype.searchDown", "[13]: Impossible de trouver la ligne de la cellule courante !");

  var newCell = cell;
  var rowIndex = currentRow.rowIndex;
  if (rowIndex + 1 != this.getMaxRowIndex()) {
  	//Pour IE (IE index differemment les colonnes si elles sont visible ou non)
  	var indexCol = cell.cellIndex;  
  	if (ECW_isIE) {  		
  		indexCol = cell.ecwcolindex * 1;
  	}
    newCell = currentRow.parentNode.rows[rowIndex + 1].cells[indexCol];
  } else {
    if (this.autoCreateLine) {    	
      newCell = this.createRow().getElementsByTagName("TD")[0];      
    } else {
      newCell = cell;
    }
  }
  this.checkNodeStructure(newCell, "td", "ECW.Grid.prototype.searchDown", "[14]: Impossible de trouver la cellule suivante !");
  return newCell;
}

/**
 * Controle de coherence.
 * @param node Node a controler
 * @param string TagName
 * @param string Fonction appelante
 * @param string Message
 * @private
 */
ECW.Grid.prototype.checkNodeStructure = function(received, expected, fonction,
  msg) {
  if (!received || (received.tagName != expected.toUpperCase())) {
    msg = "RuntimeError: Erreur de structure de la table.<br/>\n" + msg + "<br/>\n";
    msg += "Parametre inattendu dans la fonction '" + fonction + "'.<br/>\n";
    msg += received + " recu; " + expected + " attendu. <br/>\n";
    msg += "Contacter DSIN !";
    throw msg;
  }
}

/**
 * Retourne le nombre de ligne du grid.
 */
ECW.Grid.prototype.getNbLines = function() {
  return this.getRows().length;
}

/**
 * Ajoute une ligne en fin de grid.
 */
ECW.Grid.prototype.addLine = function() {
  if (!this.isActif()) {
    this.activer();
  }
  var existAscenseur = (this.lignes && this.lignes.length > this.nbligne);
  var newRow = this.createRow();
  //this.selectRow(newRow.rowIndex);
  var existAscenseurAfter = (this.lignes && this.lignes.length > this.nbligne);

  if (this.getNbLines() == 1) {
    this.fixerDimensions(false, false);
  } else if (existAscenseur != existAscenseurAfter) {
    this.fixerDimensions(false, existAscenseur);
  }
}

/**
 * Supprime une ligne a partir de son indice.
 * @param int
 */
ECW.Grid.prototype.removeLine = function(rowIndex) {
  if (!this.isActif()) {
    this.activer();
  }
  var rows = this.getRows();
  if (rowIndex >= 0 && rowIndex < rows.length) {

    if (rowIndex != 0) {
      this.moveUp(this.getTable().selectedCell);
      //newIndice = indice-1;
    } else if (this.getNbLines() != 1) {
      this.moveDown(this.getTable().selectedCell);

    }

    var existAscenseur = (this.lignes && this.lignes.length > this.nbligne);
    var rowToDelete = rows[rowIndex];
    rowToDelete.parentNode.removeChild(rowToDelete);
    var existAscenseurAfter = (this.lignes && this.lignes.length > this.nbligne);

    if (this.getNbLines() == 0) {

      this.getTable().selectedLine = null;
      this.getTable().currentLine = null;
      this.getTable().selectedField = null;
      this.getTable().selectedCell = null;
      this.fixerDimensions(false, false);

    } else {
      if (existAscenseur != existAscenseurAfter) {
        this.fixerDimensions(false, existAscenseur);
      }
    }
  }
}

