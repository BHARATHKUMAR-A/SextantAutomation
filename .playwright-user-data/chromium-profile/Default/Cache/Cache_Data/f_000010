/**
 * Cr&eacute;e un nouvelle ligne &agrave; la fin du tableau
 * et positionne le curseur sur la premiere cellule.
 * @return le node TR.
 * @private
 */
ECW.Grid.prototype.createRow = function() {
  var tbody = this.getTableBody();

  var lineNumber = 0;
  var lastRow = this.getLastRow();
  var fieldsLastRow = this.getRowFields(lastRow);
  
  var tabColHidden = new Array();
  
  if (fieldsLastRow && fieldsLastRow.length > 0) {     	
    var name = fieldsLastRow[0].name;
    name = name.replace("[", "").replace("]", "");//En PHP le name est suivi de []
    var str = fieldsLastRow[0].id.replace(name, "").replace("[", "").replace("]", ""); 
    lineNumber = parseInt(str)+1;
  }
  
  var newTR = this.emptyLine.cloneNode(true);
  if (this.alternateColor) {
    if (this.getRows().length % 2 == 0) {
      addClass(newTR, "ecwGridAlternateLine1");
    } else {
      addClass(newTR, "ecwGridAlternateLine2");
    }
  }
  
  tbody.appendChild(newTR);
  ecwSetAttribute(newTR, "ecwGrid", this);
  var newTD = newTR.getElementsByTagName("TD");
  var rowsHead = this.divTHead.getElementsByTagName("TR");
  var firstTdsHead = rowsHead[0].getElementsByTagName("TH");
  for (var i = 0; i < firstTdsHead.length; i++) {
    newTD[i].style.width = firstTdsHead[i].clientWidth;
  }

  var inputs = newTR.getElementsByTagName("INPUT");
  var selects = newTR.getElementsByTagName("SELECT");
  this.declareControls(inputs, selects, true);
  var fields = this.getRowFields(newTR);
  if (fields && fields.length > 0) {  	
    for (var i=0;i<fields.length;i++){
      var field = fields[i];
      field.id = field.id.replace("-1", lineNumber);
    }
    if (fields[0].ecwGridField.isHidden) { 
	    //Selection de la colonne non cache
	    for (var i=0;i<fields.length;i++){    	
	   		if  (!fields[i].ecwGridField.isHidden) {   			
	   			 fields[i].ecwGridField.focusAndSelect();   			 
	   			 break;
	   		}
	    }
    } else {
    	fields[0].ecwGridField.focusAndSelect();
	}
  }  
  return newTR;
}

