 */
ECW.Grid.prototype.getFieldEvent = function(event) {
  var field = null;
  if (event) {
    if (ECW_isGecko)
      field = event.currentTarget;
    else
      field = window.event.srcElement;
  }
  return field;
}

/**
 * Recherche le field input ou select d'ou provient l'evenement.
 * @param event
 * @return INPUT ou SELECT
 * @private
 */
ECW.Grid.prototype.getCommentZoneEvent = function(event) {
  var commentZone = null;
  if (event) {
    if (ECW_isGecko) {
      var pres = event.currentTarget.parentNode.getElementsByTagName('pre');
      if (pres.length == 1) {
        commentZone = pres[0];
      }
    } else {
      var pres = window.event.srcElement.parentNode.getElementsByTagName('pre');
      if (pres.length == 1) {
        commentZone = pres[0];
      }
    }
  }
  return commentZone;
}

