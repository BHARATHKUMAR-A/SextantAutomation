/**
 * onClick sur une ligne.
 * @param trTag Balise tr.
 * @param event Evenement.
 * @private
 */
function ecwGridCellOnClick(cell, event) {	
  removeClass(cell, "ecwTableLineOver");    
  if (!event) {
    event = window.event;
  }

  var grid = cell.parentNode.ecwGrid;
    
  if (!grid.isActif()) {  	
    grid.activer();
  }
  
  var field = grid.getField(cell);
  if (!field || !grid.isTabbed(cell)) {
    return ;
  }
	
  if (field && !field.ecwGridField.isModeEdit() && !field.ecwGridField.isModeReplace()) {
    grid.setCurrentCellEvent(event);	    
    //grid.selectCell(cell.parentNode.rowIndex, field.parentNode.cellIndex);
    grid.selectCell(cell.parentNode.rowIndex, field.parentNode.cellIndex,field);
    return true;
  }

  grid.stopEvent(event);
  return false;
}
