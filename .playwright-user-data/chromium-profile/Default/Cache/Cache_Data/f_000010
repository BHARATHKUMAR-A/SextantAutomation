 * @param event
 * @return boolean
 * @private
 */
ECW.Grid.prototype.ecwOnChange = function(event) {
  var onChangeParent = true;
  if (this.onChange) {
    onChangeParent = this.onChange(event);
  }
  if (onChangeParent) {
    var field = this.getFieldEvent(event);
    if (field && field.ecwGridField) {
      if (field.ecwGridField.isModified()) {
        this.setCellModified(this.getCell(field));
      } else {
        this.resetCellModified(this.getCell(field));
      }
    }
    return true;
  } else {
    return false;
  }
}

