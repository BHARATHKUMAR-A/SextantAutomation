/**
 * D&eacute;fini l'objet <b>ECW.Grid</b>
 * @private
 */
ECW.Grid = function(noeud, layout) {
  ecwStartTimer("ECW.Grid");

  ecwSetAttribute(this, "noeudDOM", noeud);
  ecwSetAttribute(this, "ecwLayout", layout);
  ecwSetAttribute(this, "ecwUI", layout.ecwUI);
  ecwSetAttribute(this.noeudDOM, "ecwGrid", this);
  ecwSetAttribute(this, "divTHead", null);
  ecwSetAttribute(this, "divTBody", null);  
  this.initNextAndPreviousField();  
  this.constructeur();
     
  ecwStopTimer("ECW.Grid");
}

/**
 * ToString.
 * @return string
 * @private
 */
ECW.Grid.prototype.toString = function() {
  return 'ECW.Grid';
}

/**
 * Pb sous IE: attachEvent: le this n'est pas un Input mais est (un document ou window ?)
 * Inconvenient de la methode uitlisee: on ne peut attacher qu'une seule fonction a un evenement.
 * @param INPUT
 * @private
 */
ECW.Grid.prototype.initInputs = function(inputs) {
  for (var i = 0; i < inputs.length; i++) {
    new ECW.GridFieldInput(this, inputs[i]);
  }
}

/**
 * Pb sous IE: attachEvent: le this n'est pas un Input mais est (un document ou window ?)
 * Inconvenient de la methode uitlisee: on ne peut attacher qu'une seule fonction a un evenement.
 * @param SELECT
 * @private
 */
ECW.Grid.prototype.initSelects = function(selects) {
  for (var i = 0; i < selects.length; i++) {
    new ECW.GridFieldSelect(this, selects[i]);
  }
}

/**
 * Noeud DOM
 * @private
 */
ECW.Grid.prototype.noeudDOM = null;

/**
 * Setter Noeud DOM
 * @param Noeud DOM
 * @private
 */
ECW.Grid.prototype.setNoeudDOM = function(noeudDOM) {
  this.noeudDOM = noeudDOM;
  /* Positionnement du Tabindex, */
  /* car sous Firefox 1.5, une div de style overflow:auto devient focusable */
  if (ECW_isGecko) {
    noeudDOM.tabIndex =  - 1;
  }
}

/**
 * Etat
 * @private
 */
ECW.Grid.prototype.focused = false;

/**
 * Setter etat
 * @param etat
 * @private
 */
ECW.Grid.prototype.setFocused = function(state) {
  if (state != this.focused) {
    if (state)
      this.activer();
    else
      this.desactiver();
  }
  this.focused = state;
}

