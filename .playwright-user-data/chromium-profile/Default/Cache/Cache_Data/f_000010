/**
 * Constructeur de l'objet Grid
 * @private
 */
ECW.Grid.prototype.constructeur = function() {

  var attrEcwNbLines = this.noeudDOM.attributes.ecwNbLines;
     
  if (attrEcwNbLines) {
    this.nbligne = attrEcwNbLines.nodeValue;
    this.nbligneInitial = attrEcwNbLines.nodeValue;
  }

  var wdivTHead = getFirstDivByClass(this.noeudDOM, "ecwGridHead");
  ecwSetAttribute(this, "divTHead", wdivTHead);
  var wdivTBody = getFirstDivByClass(this.noeudDOM, "ecwGridBody");
  if (!wdivTBody)
    return;

  var wdivEmptyLine = getFirstDivByClass(this.noeudDOM, "ecwGridEmptyLine");
  ecwSetAttribute(this, "divEmptyLine", wdivEmptyLine);
  var tableEmptyLine = getFirstChildByTagName(wdivEmptyLine, "TABLE");
  var emptyLine = getFirstChildByTagName(tableEmptyLine, "TR");
  ecwSetAttribute(this, "emptyLine", emptyLine);

  if (wdivTHead.getAttribute("ecwAlternateColor")
      && wdivTHead.getAttribute("ecwAlternateColor") == "true") {
    this.alternateColor = true;
  }

  if (wdivTHead.getAttribute("ecwAutoCreateLine")
      && wdivTHead.getAttribute("ecwAutoCreateLine") == "true") {
    this.autoCreateLine = true;
  }

  ecwSetAttribute(this, "divTBody", wdivTBody);
  wdivTBody.ecwGrid = this;

  /* Recherche des DIV pour ECW.TableV2 */
  this.searchStructureDOM();

  /* Traitement a effectuer sur les lignes */
  this.createTableLinesBehaviour();

  var inputs = this.getGridInputs();
  var selects = this.getGridSelects();
  this.declareControls(inputs, selects, false);

  if (inputs.length > 0) {
    this.moveFirst();
  }

  /* Dimensionnement de la table */
  this.fixerLargeurColonnes();
  this.fixerDimensions(true, false);

  var rows = this.getRows();
    
  for (var i = 0; i < rows.length; i++) {
    ecwSetAttribute(rows[i], "ecwGrid", this);    
  }

  if (!this.lastInputHidden) {

    /* Creation dernier champ invisible pour retour au premier */
    ecwSetAttribute(this, "lastInputHidden", document.createElement("INPUT"));
    ecwSetAttribute(this.lastInputHidden, "ecwGrid", this);
    this.lastInputHidden.className = "ecwInvisible";
    this.lastInputHidden.setAttribute("autocomplete", "off");
    /* Ajout du champ invisible en dernier */
    this.noeudDOM.parentNode.appendChild(this.lastInputHidden);
    /* Dernier champ cache -> active le grid */
    this.lastInputHidden.onfocus = function() {
      var grid = this.ecwGrid;
      if (grid.getCurrentField()) {
        grid.getCurrentField().ecwGridField.focusAndSelect();
      } else {
        if (grid.isActif()) {
          grid.desactiver();
          grid.focusNextField();
        } else {
          grid.activer();
        }
      }
    }

    /* Creation premier champ invisible pour aller au dernier */
    ecwSetAttribute(this, "firstInputHidden", document.createElement("INPUT"));
    ecwSetAttribute(this.firstInputHidden, "ecwGrid", this);
    this.firstInputHidden.className = "ecwInvisible";
    this.firstInputHidden.setAttribute("autocomplete", "off");
    /* Insertion du champ invisible avant le premier champ 'INPUT' */
    this.noeudDOM.parentNode.insertBefore(this.firstInputHidden, this.noeudDOM);
    /* Premier champ cache -> active le grid */
    this.firstInputHidden.onfocus = function() {
      var grid = this.ecwGrid;
      if (grid.getCurrentField()) {
        grid.getCurrentField().ecwGridField.focusAndSelect();
      } else {
        if (grid.isActif()) {
          grid.desactiver();
          grid.focusPreviousField();
        } else {
          grid.activer();
        }
      }
    }

  }

  if (this.emptyLine) {
    //Retirer la ligne pour que les champs ne soient pas postes
    this.emptyLine.parentNode.removeChild(emptyLine);
  }
}

/**
 * Initialisation du focus sur le champ precedent et suivant le grid
 * @private
 */
ECW.Grid.prototype.initNextAndPreviousField = function() {
  if (this.noeudDOM.getAttribute("ecwidPreviousField")) {
    this.idPreviousField = this.noeudDOM.getAttribute("ecwidPreviousField");
    var field = document.getElementById(this.idPreviousField);
    ecwSetAttribute(field, "ecwGrid", this);

    if (field.onfocus) {
      field.ecwonfocus = field.onfocus;
      field.onfocus = function(event) {
        this.ecwonfocus(event);
        this.ecwGrid.desactiver();
      }
    } else {
      field.onfocus = function(event) {
        this.ecwGrid.desactiver();
      }
    }
  }

  if (this.noeudDOM.getAttribute("ecwidNextField")) {
    this.idNextField = this.noeudDOM.getAttribute("ecwidNextField");
    var field = document.getElementById(this.idNextField);
    ecwSetAttribute(field, "ecwGrid", this);

    if (field.onfocus) {
      field.ecwonfocus = field.onfocus;
      field.onfocus = function(event) {
        this.ecwonfocus(event);
        this.ecwGrid.desactiver();
      }
    } else {
      field.onfocus = function(event) {
        this.ecwGrid.desactiver();
      }
    }
  }

  if (!this.idPreviousField || !this.idNextField) {
    this.initEcwButtonGroup();
  }
}

/**
 * Recherche du head et du body
 * @private
 */
ECW.Grid.prototype.searchStructureDOM = function() {

  /* <div class="ecwGridHead"> */
  this.searchTableHead();

  /* <div class="ecwGridBody"> */
  this.searchTableBody();

}

/**
 * Calcul la largeur des colonnes
 * @private
 */
ECW.Grid.prototype.fixerLargeurColonnes = function() {
  /* Determine la largeur des colonnes (max entre le head et body) */
  var rowsHead = this.divTHead.getElementsByTagName("TR");
  var firstTdsHead = rowsHead[0].getElementsByTagName("TH");

  var rowsBody, firstTdsBody = null;
  if (this.lignes && this.lignes.length > 0) {
    rowsBody = this.divTBody.getElementsByTagName("TR");
    firstTdsBody = rowsBody[0].getElementsByTagName("TD");
  } else if (this.emptyLine) {
    var wdivEmptyLine = getFirstDivByClass(this.noeudDOM, "ecwGridEmptyLine");
    rowsBody = this.divEmptyLine.getElementsByTagName("TR");
    firstTdsBody = this.emptyLine.getElementsByTagName("TD");
  }

  if (firstTdsBody) {
    var arrayWidth = new Array();
    for (var i = 0; i < firstTdsHead.length; i++) {
      if (firstTdsHead[i].offsetWidth > firstTdsBody[i].offsetWidth) {
        arrayWidth[i] = firstTdsHead[i].offsetWidth;
      } else {
        arrayWidth[i] = firstTdsBody[i].offsetWidth;
      }
    }

    for (var i = 0; i < firstTdsHead.length; i++) {
      firstTdsHead[i].style.width = arrayWidth[i];
    }

    for (var i = 0; i < rowsBody.length; i++) {
      var tdsBody = rowsBody[i].getElementsByTagName("TD");
      for (var j = 0; j < tdsBody.length; j++) {
        tdsBody[j].style.width = arrayWidth[j];
      }
    }
  }
}

/**
 * Calcul la hauteur et la largeur de la liste
 * @private
 */
ECW.Grid.prototype.fixerDimensions = function(firstInit, removeScroll) {

  /* Precise la hauteur du DIV principal en fonction du nb lignes maxi a afficher */
  if (this.noeudDOM.attributes.ecwNbLines) {
    this.nbligne = parseInt(this.noeudDOM.attributes.ecwNbLines.nodeValue, 10);
  }
  var hauteurEntete = 0;
  var hauteurTab = 0;

  /* Si l'entete existe */
  if (this.divTHead) {
    /* Recuperation de la valeur de offsetHeight */
    /* offsetHeight est uniquement valable si le noeud est visible */
    var offHeight = getFirstChildByTagName(this.noeudDOM, "THEAD").offsetHeight + 3;
    this.divTHead.style.height = offHeight;
    hauteurEntete = offHeight;
  }
  
  var tableDivTBody = getFirstChildByTagName(this.divTBody, "TABLE");
  /* Si la table contient au moins une ligne */
  if (this.lignes && this.lignes.length > 0) {
    /* Si c'est une combo, calcul de la hauteur au plus juste */
    hauteurTab = (this.lignes[0].offsetHeight) * this.nbligne;
  }
  /* Aucune ligne dans le tableau */
  else {

    if (this.divTBody) {
      /* Ajout d'une ligne pour le calcul de la hauteur d'une ligne */
      var tbodyVide = getFirstChildByTagName(this.divTBody, "TBODY");
      if (!tbodyVide) {
        tbodyVide = document.createElement("TBODY");
        tableDivTBody.appendChild(tbodyVide);
      }

      var trVide = document.createElement("TR");
      tbodyVide.appendChild(trVide);
      var tdVide = document.createElement("TD");
      trVide.appendChild(tdVide);
      tdVide.innerHTML = "LIGNE DE TEST";

      /* Calcul de la hauteur totale */
      var firstLine = getFirstChildByTagName(tbodyVide, "TR");
      hauteurTab = firstLine.offsetHeight * this.nbligne;

      /* Suppression de la ligne */
      tbodyVide.removeChild(trVide);
    }
  }
  if (this.divTBody) {
    this.divTBody.style.height = hauteurTab + 2;
  }

  /* Fixe la largeur de la liste */
  var wlargeur = 0;

  /* Pour eviter l'ascenseur horizontal en cas de manque de place */
  if (this.divTBody) {
    /* Position de la balise <table> */
    tableDivTBody.style.position = "absolute";
  }

  /* Si l'entete existe */
  if (this.divTHead) {
    //this.divTHead.style.width = tableDivTBody.offsetWidth;
    var tableTHead = getFirstChildByTagName(this.divTHead, 'TABLE');
    /* Si la table contient au moins une ligne */
    if (this.lignes != null && this.lignes.length > 0) {
      if (this.lignes[0].parentNode.offsetWidth > tableTHead.offsetWidth) {
        wlargeur = this.lignes[0].parentNode.offsetWidth;
      } else {
        wlargeur = tableTHead.offsetWidth;
      }
    } else {
      wlargeur = tableTHead.offsetWidth;
    }
  }
  /* Si l'entete n'existe pas */
  else {
    /* Si la table contient au moins une ligne */
    if (this.lignes != null && this.lignes.length > 0) {
      wlargeur = this.lignes[0].parentNode.offsetWidth;
    } else {
      wlargeur = 20;
    }
  }

  /* Pour Mozilla */
  if (ECW_isGecko && this.divTBody) {
    /* Position de la balise <table> */
    tableDivTBody.style.position = "";
  }

  /* Si l'ascenseur vertical s'affiche il faut ajouter la largeur de l'ascenseur */
  if (this.lignes && this.lignes.length > this.nbligne) {
    wlargeur += ecwScrollBarWidth;
  }
  if (!firstInit && removeScroll) {
    wlargeur -= ecwScrollBarWidth;
  }

  if (this.divTBody) {
    this.divTBody.style.width = wlargeur;
    /* Pour une table, calcul de la longueur, car position: static */
    this.noeudDOM.style.width = this.divTBody.offsetWidth;
  }

}

/**
 * Recherche de la DIV class="ecwGridHead" utilisee pour afficher les entetes de colonnes.
 * @private
 */
ECW.Grid.prototype.searchTableHead = function() {

  /* Recherche de la balise <TABLE> et de la balise <THEAD> */
  var currentTable = getFirstChildByTagName(this.noeudDOM, "TABLE");
  if (!(currentTable && currentTable.tHead)) {
    return ;
  }
}

/**
 * Recherche de la DIV class="ecwGridBody" utilisee pour afficher les donnees.
 * @private
 */
ECW.Grid.prototype.searchTableBody = function() {

  /* Positionnement du Tabindex, */
  /* car sous Firefox 1.5, une div de style overflow:auto devient focusable */
  if (ECW_isGecko) {
    this.divTBody.tabIndex = -1;
  }
}

/**
 * Cree le comportement des lignes sur les actions.
 * @private
 */
ECW.Grid.prototype.createTableLinesBehaviour = function() {

  if (this.noeudDOM.getElementsByTagName("TBODY").length > 0) {

    this.lignes = getFirstChildByTagName(this.divTBody, "TBODY").rows;
    /* Detection d'une table vide */
    this.detectEmptyTable();
    /* Retient l'ordre inital des lignes*/
    if (this.canReorder) {
      this.saveInitialOrder();
    }

    if (this.lignes) {
      var ligne;
      var nbLignes = this.lignes.length;
      for (var i = 0; i < nbLignes; ++i) {
        ligne = this.lignes[i];

        ecwSetAttribute(ligne, "ecwGrid", this);
        ligne.ecwGrid.triActif = 0;

        /* Precalcul du rowIndex pour gagner du temps sous Mozilla */
        this.processIndex(ligne, i);

        /* Sauvegarde du texte : utilise par ECW.ComboBox */
        ligne.chaineCar = ecwGetInnerText(ligne.getElementsByTagName("TD")[0]);
      }
    }
  }
}

/**
 * Detection d'un table vide.
 * @private
 */
ECW.Grid.prototype.detectEmptyTable = function() {

  /* Detection d'une table vide */
  if (this.lignes && this.lignes.length == 1) {
    if (isClass(this.lignes[0], "ecwGridLineEmpty")) {
      this.lignes = null;
    }
  }
}

/**
 * Focus le field suivant le grid
 * @private
 */
ECW.Grid.prototype.focusNextField = function() {
  if (this.idNextField && document.getElementById(this.idNextField)) {
    this.desactiver();
    ecwFocus(document.getElementById(this.idNextField));
  } else {
    this.moveFirstButton();
  }
}

/**
 * Focus le field precedent le grid
 * @private
 */
ECW.Grid.prototype.focusPreviousField = function() {
  if (this.idPreviousField && document.getElementById(this.idPreviousField)) {
    this.desactiver();
    ecwFocus(document.getElementById(this.idPreviousField));
  } else {
    this.moveFirstButton();
  }
}

/**
 * Mise a jour de l'index des lignes.
 * @param ligne Ligne concernee.
 * @param i Indice de la ligne.
 * @private
 */
ECW.Grid.prototype.processIndex = function(ligne, i) {

  /* Recalcul de l'index de ligne */
  if (ligne) {
    ligne.rIndex = i + 1;
  }
}

/**
 * Si blurOnTab == true, l'appuie sur la touche Tabulation provoque le focus
 * sur le premier bouton du groupe de bouton dont l'Id vaut "ecwButtonGroup";
 * Si blurOnTab == false, l'appuie sur la touche Tabulation provoque le focus 
 * sur le prochain controle de la grid ou
 * sur le premier controle apr&egrave;s la grid s'il n'y a plus de controle suivant dans la grid.
 * @private
 */
ECW.Grid.prototype.blurOnTab = false;

/**
 * Retourne la table contenant les lignes de saisies.
 * @return Table
 * @private
 */
ECW.Grid.prototype.getTable = function() {
  var table = this.divTBody.getElementsByTagName("TABLE")[0]
    this.checkNodeStructure(table, "table", "ECW.Grid.prototype.getRow", "[0]: Impossible de trouver la table !");
  return table;
}

/**
 * Retourne le body de la table contenant les lignes de saisies.
 * @return TBody
 * @private
 */
ECW.Grid.prototype.getTableBody = function() {
  var tbodies = this.getTable().tBodies;
  var tbody = null;
  if (!tbodies || tbodies.length == 0) {
    // cela peut arriver si la table ne contient pas de lignes.
    tbody = document.createElement("tbody");
    this.getTable().appendChild(tbody);
  } else {
    tbody = tbodies[0];
  }
  return tbody;
}

/**
 * Retourne les lignes de la table.
 * @return Rows
 * @private
 */
ECW.Grid.prototype.getRows = function() {
  return this.getTableBody().rows;
}

/**
 * Retourne le nombre de lignes de la table.
 * @return int
 * @private
 */
ECW.Grid.prototype.getRowsCount = function() {
  return this.getRows().length;
}

/**
 * Retourne le nombre de colonnes de la table.
 * @return int
 * @private
 */
ECW.Grid.prototype.getColumnsCount = function() {
  return this.getRows()[0].cells.length;
}

/**
 * Retourne les input de la table.
 * @return INPUT
 * @private
 */
ECW.Grid.prototype.getGridInputs = function() {
  return this.getTableBody().getElementsByTagName("INPUT");
}

/**
 * Retourne les select de la table.
 * @return SELECT
 * @private
 */
ECW.Grid.prototype.getGridSelects = function() {
  return this.getTableBody().getElementsByTagName("SELECT");
}

/**
 * Retourne les select de la ligne.
 * @return SELECT
 * @private
 */
ECW.Grid.prototype.getRowSelects = function(row) {
  return row.getElementsByTagName("SELECT");
}

/**
 * Retourne les input et select de la ligne.
 * @param TR
 * @private
 */
ECW.Grid.prototype.getRowFields = function(row) {
  var list = new Array();
  var tds = row.getElementsByTagName("TD");
  for (var i = 0; i < tds.length; i++) {
    var input = getFirstChildByTagName(tds[i], "INPUT");
    var select = getFirstChildByTagName(tds[i], "SELECT");
    if (input) {
      list.push(input);
    } else if (select) {
      list.push(select);
    }
  }
  return list;
}

/**
 * A partir d'un input ou select, on retourne le noeud td.
 * @param field de type input ou select
 * @return TD
 */
ECW.Grid.prototype.getCell = function(field) {
  var currentCell = field;
  while (currentCell != null && currentCell.tagName != "TD")
    currentCell = currentCell.parentNode;
  this.checkNodeStructure(currentCell, "TD", "ECW.Grid.prototype.getCell", 
    "[1]: Impossible de trouver la cellule du champ de saisie courant.");
  return currentCell;
}

/**
 * A partir d'un input ou select, on retourne le noeud tr.
 * @param field de type input ou select
 * @return TR
 */
ECW.Grid.prototype.getRow = function(field) {
  var currentRow = null;
  if (!field)
  	return null;
  if (field.tagName == "INPUT" || field.tagName == "SELECT") {
    var cell = this.getCell(field);
    if(cell){
      currentRow = cell.parentNode;
    }
  } else if (field.tagName == "TD") {
    currentRow = field.parentNode;
  } else {
    throw "RuntimeError :[2] Parametre inattendu sur la fonction ECW.Grid.prototype.getRow. " + field.tagName + " recu, INPUT ou TD attendu.";
  }
  this.checkNodeStructure(currentRow, "TR", "ECW.Grid.prototype.getRow", 
    "[3]: Impossible de trouver la ligne du champ de saisie courant.");
  return currentRow;
}

/**
 * Retourne l'indice de la ligne courante.
 * @return int
 * @private
 */
ECW.Grid.prototype.getCurrentRowIndex = function() {
  if (this.getCurrentRow()) {
    return this.getCurrentRow().rowIndex;
  }
  return  -1;
}

/**
 * A partir d'un td retourne l'iinput ou select.
 * @param TD
 * @return INPUT ou SELECT
 * @private
 */
ECW.Grid.prototype.getField = function(cell) {
  if (!cell) {
    return null;
  }
  var inputs = cell.getElementsByTagName("INPUT");
  if (inputs.length > 0) {
    return inputs[0];
  }
  var selects = cell.getElementsByTagName("SELECT");
  if (selects.length > 0) {
    return selects[0];
  }
  return null;
}

/**
 * Retourne l'indice max de colonne.
 * @return int
 * @private
 */
ECW.Grid.prototype.getMaxCellIndex = function() {
  return this.getColumnsCount() - 1;
}

/**
 * Retourne l'indice max de ligne.
 * @return int
 * @private
 */
ECW.Grid.prototype.getMaxRowIndex = function() {
  return this.getRows().length;
}

/**
 * Positionne la hauteur de la div.
 * @param int
 * @private
 */
ECW.Grid.prototype.setHeight = function(height) {
  var objRegExp = /[0-9]+(px)?/;
  if (!objRegExp.test(height)) {
    throw "RuntimeError setHeight: invalide value: " + height;
  }
  var result = objRegExp.exec(height);
  if (result && (result[1] != "px")) {
    height += "px";
  }
  this.noeudDOM.style.height = height;
}

