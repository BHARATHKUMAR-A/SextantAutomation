/**
 * Selection d'une cellule a selectionner suite au disabled du field actuellement en selection
 * @param cell TD
 * @private
 */
ECW.Grid.prototype.selectNextCell = function(cell) {
  
  var newField = this.getField(this.searchRight(cell));
  if(!newField)
    newField = this.getField(this.searchLeft(cell));
  if(!newField)
    newField = this.getField(this.searchDown(cell));
  if(!newField)
    newField = this.getField(this.searchUp(cell));
  if(newField){
    
    var table = this.getTable();
    var newCell = this.getCell(newField);
    var newRow = newCell.parentNode;
    var isActif = this.isActif();
    
    removeClass(table.selectedLine, "ecwGridLineSelect");
    removeClass(table.selectedCell, "ecwGridCellSelect");
    if(isActif){
      removeClass(table.currentLine, "ecwGridLineActive");
      removeClass(table.selectedCell, "ecwGridCellActive");
    }

    table.selectedCell = newCell;
    table.selectedField = newField;
    table.currentLine = newRow;
    table.selectedLine = newRow;

    addClass(table.selectedLine, "ecwGridLineSelect");
    addClass(table.selectedCell, "ecwGridCellSelect");
    if(isActif){
      addClass(table.currentLine, "ecwGridLineActive");
      addClass(table.selectedCell, "ecwGridCellActive");
    }
  }
}

