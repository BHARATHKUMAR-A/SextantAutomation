ECW.Grid.prototype.ecwOnFieldFocus = function(event) {

  var field = this.getFieldEvent(event);
  if (this.lastFocus && !this.lastFocus.disabled && !this.focused) {
    ecwFocus(this.lastFocus);
  } else {
    this.lastFocus = field;
    this.setCurrentCellEvent(event);
  }
  this.setFocused(true);
  var result = null;
  if (this.onFieldFocus) {
    result = this.onFieldFocus(event);
  } else {
    result = true;
  }
  return result;
}

/**
 * Action a lancer en fct de la touche.
 * @param event
 * @return boolean
 * @private
 */
ECW.Grid.prototype.ecwOnKeydown = function(event) {
  /*  if ((event.keyCode==32) && (event.ctrlKey)) { // Ctrl + Espace
  this.setSelectedRowEvent(event);
  return this.stopEvent(event);
  }
   */

  if (event.keyCode == 9) {
    if (event.shiftKey) {
      return this.ecwOnShiftTab(event);
    } else {
      return this.ecwOnTab(event);
    }
  }

  if ((event.keyCode == 9) && (this.blurOnTab())) {
    // TAB
    return this.ecwOnBlur(event);
  }

  var isPropagationEnabled = true;
  var field = this.getFieldEvent(event);

  if (!field.ecwGridField.isModeEdit()) {
    switch (event.keyCode) {
      case 13:
      case 14:
        isPropagationEnabled = this.ecwOnEnter(event);
        break;
      case 27:
        isPropagationEnabled = this.ecwOnEscape(event);
        break;
      case 37:
        isPropagationEnabled = this.ecwOnLeft(event);
        break;
      case 38:
        isPropagationEnabled = this.ecwOnUp(event);
        break;
      case 39:
        isPropagationEnabled = this.ecwOnRight(event);
        break;
      case 40:
        isPropagationEnabled = this.ecwOnDown(event);
        break;
      case 188:
        if (event.altKey) {
          isPropagationEnabled = this.ecwOnAssist(event)
        }
        ;
        break;
    }
  }

  if (isPropagationEnabled) {
    if (this.onKeydown) {
      return this.onKeydown(event);
    } else {
      return true;
    }
  }

}

