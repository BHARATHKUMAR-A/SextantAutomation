/**
 * D&eacute;fini l'objet <b>ECW.GridField</b>
 * @private
 */
ECW.GridField = function(){}

/**
 * ToString.
 * @return string
 * @private
 */
ECW.GridField.prototype.toString = function() {
  return 'ECW.GridField';
}

/**
 * Noeud DOM
 * @private
 */
ECW.GridField.prototype.noeudDOM = null;

/**
 * Grid
 * @private
 */
ECW.GridField.prototype.ecwGrid = null;

/**
 * Derniere valeur
 * @private
 */
ECW.GridField.prototype.lastValue = null;

/**
 * Valeur par defaut
 * @private
 */
ECW.GridField.prototype.defaultValue = null;

/**
 * Indique si la valeur est differente de la valeur par defaut
 * @return boolean
 * @private
 */
ECW.GridField.prototype.isDirty = function() {
  return (this.noeudDOM.value != this.defaultValue);
}

/**
 * Indique si la valeur est differente de la derniere valeur
 * @return boolean
 * @private
 */
ECW.GridField.prototype.isModified = function() {
  return (this.noeudDOM.value != this.lastValue);
}

/**
 * Constructeur de l'objet GridField
 * @param Grid
 * @param Node
 * @private
 */
ECW.GridField.prototype.constructeur = function(grid, noeud) {
  this.ecwGrid = grid;
  ecwSetAttribute(this, "noeudDOM", noeud);
  ecwSetAttribute(noeud, "ecwGridField", this);
  ecwSetAttribute(noeud, "ecwGrid", grid);
  this.lastValue = noeud.value;
  this.isHidden=(noeud.parentNode && noeud.parentNode.style.display && noeud.parentNode.style.display=="none")?true:false;
  this.initEvents();
}

/**
 * Initialisation des evenements
 * @private
 */
ECW.GridField.prototype.initEvents = function() {
  if (this.noeudDOM.onfocus) {
    this.noeudDOM.ecwonfocus = this.noeudDOM.onfocus;
    this.noeudDOM.onfocus = function(event) {

      this.ecwonfocus(event);
      this.ecwGridField.onFocus(event);
    }
  } else {
    this.noeudDOM.onfocus = function(event) {
      this.ecwGridField.onFocus(event);
    }
  }

  this.noeudDOM.onblur = function(event) {
    this.ecwGridField.onBlur(event);
  }
  this.noeudDOM.onkeydown = function(event) {
    this.ecwGridField.onKeydown(event);
  }
  this.noeudDOM.onkeypress = function(event) {
    this.ecwGridField.onKeypress(event);
  }
  this.noeudDOM.onkeyup = function(event) {
    this.ecwGridField.onKeyup(event);
  }
}

/**
 * Validation
 * @param event
 * @return boolean
 * @private
 */
ECW.GridField.prototype.validate = function(event) {
  event.isFieldModified = this.isModified();
  var ok = (this.isModified()) ? this.onChange(event): true;
  if (ok) {
    this.stopModeEdit(event);
    this.lastValue = this.noeudDOM.value;
  }
  return ok;
}

/**
 * Action a declencher sur le onBlur d'un champ.
 * @param event
 * @return boolean
 * @private
 */
ECW.GridField.prototype.onBlur = function(event) {
  if (window.event)
    event = window.event;
  /* stop l'eventuel mode d'edition */
  if (this.validate(event)) {
    return this.ecwGrid.ecwOnFieldBlur(event);
  }
  return this.stopEvent(event);
}

/**
 * Action a declencher sur le onFocus d'un champ.
 * @param event
 * @return boolean
 * @private
 */
ECW.GridField.prototype.onFocus = function(event) {
  if (window.event)
    event = window.event;
  return this.ecwGrid.ecwOnFieldFocus(event);
}

/**
 * On intercepte sur onKyDown les touche qui ne sont pas g&eacute;r&eacute;es
 * par la couche superieure (Grid ou metier).
 * @param event
 * @return boolean
 * @private
 */
ECW.GridField.prototype.onKeydown = function(event) {
  if (window.event)
    event = window.event;
  event.leaveEditMode = false;

  if (this.isModeEdit() || this.isModeReplace()) {
    /* Si escape ou Enter, on ne veut pas que les autres soient informe */
    if (event.keyCode == 27) {
      // Escape
      return this.onEditEscape(event);
    } else if (event.keyCode == 13 || event.keyCode == 14) {
      // enter
      return this.onEditEnter(event);
    }
    return this.ecwGrid.ecwOnKeydown(event);
  } else {
    if (event.keyCode == 46 || event.keyCode == 8) {
      // Suppr || Backspace
      this.onDelete(event);
    } else if (event.keyCode == 13 || event.keyCode == 14) {
      // enter
      return this.onEnter(event);
    }
    this.ecwGrid.ecwOnKeydown(event);
    return this.stopEvent(event);
  }

}

/**
 * Action de sortie de saisie.
 * @param event
 * @return boolean
 * @private
 */
ECW.GridField.prototype.onEditEscape = function(event) {
  this.stopModeEdit(event);
  this.noeudDOM.value = this.defaultValue;
  this.focusAndSelect();
  return this.stopEvent(event);
}

/**
 * Action d'entrer en mode saisie.
 * @param event
 * @return boolean
 * @private
 */
ECW.GridField.prototype.onEditEnter = function(event) {
  if (this.validate(event)) {
    this.focusAndSelect();
  } else {
    return this.stopEvent(event);
  }
}

/**
 * Action a declencher sur le onEnter.
 * @param event
 * @return boolean
 * @private
 */
ECW.GridField.prototype.onEnter = function(event) {
  this.startModeEdit();
  return this.stopEvent(event);
}

/**
 * Action a declencher sur le onDelete.
 * @param event
 * @return boolean
 * @private
 */
ECW.GridField.prototype.onDelete = function(event) {
  this.startModeReplace();
}

/*
 * On gere sur onKeyUp les touches qui ne sont pas interceptees avant,
 * donc arretees par onKeydown ou onKeypress de le field ou une couche superieure (Grid ou metier)
 * @param event
 * @return boolean
 * @private
 */
ECW.GridField.prototype.onKeyup = function(event) {
  return this.ecwGrid.ecwOnKeyup(event);
}

/*
 * Action a declencher sur le onKeypress.
 * @param event
 * @return boolean
 * @private
 */
ECW.GridField.prototype.onKeypress = function(event) {
  /*
   * Pour rendre le meme comportement sous FireFox et IE,
   * a savoir:
   * Avec IE, Keypress n'est pas appele pour les touches non imprimable
   * Avec FireFox, ces touches ont event.keyCode==0 et event.which!=0
   * Sous Mozzila, ces touches ont event.keyCode!=0 et event.which==0
   */
  if (window.event) {
    event = window.event;
    event.which = event.keyCode;
  }
  // Pour stopper la propagation des touches fonctions sous Mozzila
  else if (event.keyCode > 111) {
    return this.stopEvent(event);
  } else if (event.keyCode == 13) {
    return this.stopEvent(event);
  } else if (event.keyCode != 0) {
    return ;
  }

  if (this.ecwGrid.ecwOnKeypress(event)) {
    //    if (this.isModeEdit() || this.isModeReplace()) {
    //    } else {
    //      this.startModeReplace();
    //    }
  }
}

/**
 * Action a declencher sur la modification d'une valeur.
 * @param event
 * @return boolean
 * @private
 */
ECW.GridField.prototype.onChange = function(event) {

  if (!this.ecwGrid.validateControl(this)) {
    return this.stopEvent(event);
  } else {
    if (this.ecwGrid.ecwOnChange(event)) {
      if (this.isDirty()) {
        this.setModifiedClass();
      } else {
        this.resetModifiedClass();
      }
      return true;
    } else {
      return false;
    }
  }
}

/**
 * Arret de la propagation d'un event.
 * @param event
 * @return boolean
 * @private
 */
ECW.GridField.prototype.stopEvent = function(event) {
  this.ecwGrid.stopEvent(event);
}

/**
 * Retourn les parametres a poster.
 * @return string
 * @private
 */
ECW.GridField.prototype.getParam = function() {
  return this.noeudDOM.name + "=" + escape(this.noeudDOM.value).replace(new RegExp("\\+", "g"), "%2B") + "&";
}

/**
 * Marque le noeud comme modifie.
 * @private
 */
ECW.GridField.prototype.setModifiedClass = function() {
  addClass(this.noeudDOM, "modified");
}

/**
 * Marque le noeud comme non modifie.
 * @private
 */
ECW.GridField.prototype.resetModifiedClass = function() {
  removeClass(this.noeudDOM, "modified");
}

/**
 * Marque le noeud comme en erreur.
 * @private
 */
ECW.GridField.prototype.setError = function() {
  addClass(this.noeudDOM, "error");
}

/**
 * Marque le noeud comme non en erreur.
 * @private
 */
ECW.GridField.prototype.resetError = function() {
  removeClass(this.noeudDOM, "error");
}

/**
 * Marque le noeud comme disabled/enable.
 * @param boolean
 */
ECW.GridField.prototype.setDisabled = function(set) {
  
  this.noeudDOM.disabled = set;
  if (set) {
    removeClass(this.noeudDOM.parentNode, "ecwGridCellSelect");
    var grid = this.ecwGrid;
    /* Le field disable est-il le field courant ? */
    if (grid.getCurrentField().ecwGridField==this) {
      grid.selectNextCell(grid.getCell(this.noeudDOM));
    }
  }
}

