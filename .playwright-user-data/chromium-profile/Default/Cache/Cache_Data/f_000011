/**
 * D&eacute;fini l'objet <b>ECW.GridFieldSelect</b>
 * @param Grid
 * @param Node
 * @private
 */
ECW.GridFieldSelect = function(grid, noeud) {
  this.constructeur(grid, noeud);
  this.initDefaultValue();

  ecwSetAttribute(this.noeudDOM, "onkeydown", function(event) {
    return this.ecwGridField.onKeydown(event); 
  }
  );
  ecwSetAttribute(this.noeudDOM, "onchange", function(event) {
    this.ecwGridField.onChange(event); 
  }
  );

  if (this.noeudDOM.onclick) {
    this.noeudDOM.ecwonclick = this.noeudDOM.onclick;
    ecwSetAttribute(this.noeudDOM, "onclick", function(event) {
      this.ecwonclick(event); this.ecwGridField.onClick(event); 
    }
    );
  } else {
    ecwSetAttribute(this.noeudDOM, "onclick", function(event) {
      this.ecwGridField.onClick(event); 
    }
    );
  }

}

/**
 * ToString.
 * @return string
 * @private
 */
ECW.GridFieldSelect.prototype.toString = function() {
  return 'ECW.GridFieldSelect';
}

/**
 * GridFieldSelect herite de GridField.
 * @private
 */
ECW.GridFieldSelect.prototype = new ECW.GridField();

/**
 * GridFieldSelect herite de GridField.
 * @private
 */
ECW.GridFieldSelect.prototype.moveOption = 0;

/**
 * Initialisation des valeurs par defaut.
 * @private
 */
ECW.GridFieldSelect.prototype.initDefaultValue = function() {
  for (var i = 0; i < this.noeudDOM.options.length; ++i) {
    // ecwSelected car lors de la creation d'une nouvelle ligne, IE perd le selected
    if (this.noeudDOM.options[i].getAttribute("ecwSelected") == "selected") {
      this.noeudDOM.options[i].selected = true;
      this.defaultValue = this.noeudDOM.options[i].value;
      break;
    }
  }
  if (!this.defaultValue) {
    this.defaultValue = "";
  }
}

/**
 * Action a lancer en fct de la touche.
 * @param event
 * @return boolean
 * @private
 */
ECW.GridFieldSelect.prototype.onKeydown = function(event) {

  if (window.event)
    event = window.event;
  event.leaveEditMode = false;
  if (this.isModeEdit() || this.isModeReplace()) {
    /* Si escape ou Enter, on ne veut pas que les autres soient informe */
    if (event.keyCode == 27) {
      // Escape
      return this.onEditEscape(event);
    } else if (event.keyCode == 13 || event.keyCode == 14) {
      // enter
      return this.onEditEnter(event);
    }
  } else if (event.altKey && (event.keyCode == 37 || event.keyCode == 38 ||
    event.keyCode == 39 || event.keyCode == 40)) {
    this.startModeEdit();
    this.moveOption = 0;
    return false;
  } else if (!event.altKey) {
    if (event.keyCode == 37 || event.keyCode == 38) {
      this.moveOption = 1;
    } else if (event.keyCode == 39 || event.keyCode == 40) {
      this.moveOption =  - 1;
    } else if (event.keyCode == 13 || event.keyCode == 14) {
      // enter
      return this.onEnter(event);
    } else if (event.keyCode >= 48 && event.keyCode <= 90) {
      this.moveOption = 0;
      this.startModeEdit();
    }
  }

  return this.ecwGrid.ecwOnKeydown(event);
}

/**
 * Action a declencher sur la modification d'une valeur.
 * @param event
 * @return boolean
 * @private
 */
ECW.GridFieldSelect.prototype.onChange = function(event) {

  if (window.event)
    event = window.event;
  if (this.moveOption != 0 && !this.isModeEdit() && !this.isModeReplace()) {
    this.noeudDOM.selectedIndex = this.noeudDOM.selectedIndex + this.moveOption;
    this.moveOption = 0;
  }
  if (this.isModeEdit() || this.isModeReplace()) {
    this.moveOption = 0;
  }
  //  if (!this.getGrid().validateControl(this)) {
  //    return this.stopEvent(event);
  //  } else {
  if (this.ecwGrid.ecwOnChange(event)) {
    if (this.isDirty()) {
      this.setModifiedClass();
    } else {
      this.resetModifiedClass();
    }
    return true;
  } else {
    return false;
  }
  //  }
}

/**
 * Action a declencher sur le onFocus d'un champ.
 * @param event
 * @return boolean
 * @private
 */
ECW.GridFieldSelect.prototype.onFocus = function(event) {

  if (window.event)
    event = window.event;
  // Sous IE la selection reste sur l'INPUT precedent le SELECT
  if (ECW_isIE)
    document.selection.empty();

  var currentCellIndex = this.ecwGrid.getCurrentCellIndex();
  var currentRowIndex = this.ecwGrid.getCurrentRowIndex();
  var TD = this.noeudDOM.parentNode;
  var TR = TD.parentNode;
  var thisCellIndex = TD.cellIndex;
  var thisRowIndex = TR.rowIndex;
  if (currentCellIndex != thisCellIndex || currentRowIndex != thisRowIndex) {
    this.ecwGrid.setCurrentCellEvent(event);
    this.ecwGrid.stopEvent(event);
    return false;
  }
  this.ecwGrid.ecwOnFieldFocus(event);
  ;
  return true;
}

/**
 * Action a declencher sur le onClick d'un champ.
 * @param event
 * @return boolean
 * @private
 */
ECW.GridFieldSelect.prototype.onClick = function(event) {

  if (window.event)
    event = window.event;
  var field = this.noeudDOM;
  var currentField = this.ecwGrid.getCurrentField();
  if (field != currentField) {
    var cell = field.parentNode;
    this.ecwGrid.selectCell(cell.parentNode.rowIndex, cell.cellIndex);
    this.ecwGrid.setCurrentCellEvent(event);
    return true;

  }

  if (field && !field.ecwGridField.isModeEdit() && !field.ecwGridField.isModeReplace()) {
    this.ecwGrid.stopEvent(event);
    return false;
  }
  return true;
}
