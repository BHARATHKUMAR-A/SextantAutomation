/**
 * Debut du mode edition.
 * @private
 */
ECW.GridField.prototype.startModeEdit = function() {
  this.fieldEdit = this.noeudDOM;
  addClass(this.fieldEdit, "edit");
}

/**
 * Debut du mode replace.
 * @private
 */
ECW.GridField.prototype.startModeReplace = function() {
  this.fieldEdit = this.noeudDOM;
  addClass(this.fieldEdit, "edit");
  addClass(this.fieldEdit, "replace");
}

/**
 * Arret du mode edition.
 * @private
 */
ECW.GridField.prototype.stopModeEdit = function(event) {
  if (this.fieldEdit) {
    removeClass(this.fieldEdit, "edit");
    removeClass(this.fieldEdit, "replace");
    this.fieldEdit = undefined;
  }
  event.leaveEditMode = true;
}

/**
 * Indique si on est en mode edition.
 * @return boolean
 * @private
 */
ECW.GridField.prototype.isModeEdit = function() {
  if (!this.fieldEdit)
    return false;
  return this.fieldEdit && !isClass(this.fieldEdit, 'replace');
}

/**
 * Indique si on est en mode replace.
 * @return boolean
 * @private
 */
ECW.GridField.prototype.isModeReplace = function() {
  if (!this.fieldEdit)
    return false;
  return this.fieldEdit && isClass(this.fieldEdit, 'replace');
}

/**
 * Focus et select du field.
 * @private
 */
ECW.GridField.prototype.focusAndSelect = function() {	
  if(this.noeudDOM.disabled){
    return;
  }
  var field = this.noeudDOM;
  var champActif = this.ecwGrid.ecwUI.champActif;
  if (champActif && !champActif.noeudDOM.ecwGridField) {
    champActif.desactiver();
  }
  this.ecwGrid.ecwUI.champActif = this.noeudDOM.ecwControl;
  ecwFocus(field);
  if (field.tagName == "INPUT")
    field.select();
}

